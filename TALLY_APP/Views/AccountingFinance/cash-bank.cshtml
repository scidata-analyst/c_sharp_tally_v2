@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Cash & Bank Management</title>
    <partial name="_Styles" />
</head>

<body>

    <partial name="_Sidebar" />

    <partial name="_Header" model='@("Cash & Bank Management")' />

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== CASH & BANK MANAGEMENT ===================== -->
        <div class="page active" id="page-cash-bank">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Cash & Bank Management</div>
                    <div class="page-subtitle">Monitor all cash and bank account balances</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('bankModal')">
                    <i class="bi bi-plus-lg"></i> Add Bank Account
                </button>
            </div>
            
            <div class="row g-3 mb-4" id="bankSummaryCards">
                <!-- Loaded via API -->
            </div>

            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Bank Accounts</div>
                    <div class="table-actions">
                        <input class="table-search" placeholder="Search accounts..." oninput="handleBankSearch(event)">
                        <button class="btn-tally-outline" onclick="loadBanks()">
                            <i class="bi bi-arrow-clockwise"></i> Refresh
                        </button>
                    </div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('AccountName')" style="cursor:pointer;">
                                Account Name <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('BankName')" style="cursor:pointer;">
                                Bank Name <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('AccountNumber')" style="cursor:pointer;">
                                Account No. <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th>IFSC</th>
                            <th onclick="sortBy('OpeningBalance')" style="cursor:pointer;">
                                Balance <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">
                                Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="bankTableBody">
                        <!-- Loaded via API -->
                    </tbody>
                </table>

                <!-- Pagination Controls -->
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">
                        Showing <span id="bankShowingStart">0</span> to <span id="bankShowingEnd">0</span> of <span id="bankTotalRecords">0</span> records
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows per page:</label>
                        <select id="bankPageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changeBankPageSize()">
                            <option value="5">5</option>
                            <option value="10" selected>10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="bankPrevBtn" style="padding:6px 12px;" onclick="prevBankPage()">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <span id="bankPageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="bankNextBtn" style="padding:6px 12px;" onclick="nextBankPage()">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- ===================== MODALS ===================== -->

    <!-- Bank Modal -->
    <div class="tally-modal-overlay" id="bankModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Add Bank Account</div>
                <div class="modal-close" onclick="closeModal('bankModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <input type="hidden" id="bankId">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label class="form-label">Account Name *</label>
                            <input type="text" class="form-control-tally" id="bankAccountName" placeholder="e.g. SBI Current Account">
                            <div class="field-error" id="error-AccountName"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Account Type</label>
                            <select class="form-control-tally" id="bankAccountType">
                                <option value="Current">Current</option>
                                <option value="Savings">Savings</option>
                                <option value="OD / CC">OD / CC</option>
                            </select>
                            <div class="field-error" id="error-AccountType"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Bank Name *</label>
                            <input type="text" class="form-control-tally" id="bankName" placeholder="e.g. State Bank of India">
                            <div class="field-error" id="error-BankName"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Account Number *</label>
                            <input type="text" class="form-control-tally" id="bankAccountNumber" placeholder="XXXXXXXXXX">
                            <div class="field-error" id="error-AccountNumber"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">IFSC Code</label>
                            <input type="text" class="form-control-tally" id="bankIfscCode" placeholder="SBIN0001234">
                            <div class="field-error" id="error-IfscCode"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Opening Balance</label>
                            <input type="number" class="form-control-tally" id="bankOpeningBalance" placeholder="0.00">
                            <div class="field-error" id="error-OpeningBalance"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <select class="form-control-tally" id="bankStatus">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                            <div class="field-error" id="error-Status"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('bankModal')">Cancel</button>
                <button class="btn-tally-primary" id="btnSaveBank" onclick="saveBank()">
                    <i class="bi bi-check-lg"></i> Save Account
                </button>
            </div>
        </div>
    </div>

    <!-- Delete Confirm Modal -->
    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;">
            <div class="del-icon">🗑️</div>
            <h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete Bank Account?</h5>
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone. The record will be permanently removed.</p>
            <div class="d-flex justify-content-center gap-3">
                <button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button>
                <button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()">
                    <i class="bi bi-trash"></i> Yes, Delete
                </button>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <partial name="_Scripts" />

    <script>
        /**
         * @@typedef {Object} BankState
         * @@property {Array} data - List of bank accounts
         * @@property {number} page - Current page number
         * @@property {number} pageSize - Records per page
         * @@property {number} totalCount - Total number of records
         * @@property {number} totalPages - Total number of pages
         * @@property {string} search - Search query
         * @@property {string} sortColumn - Column to sort by
         * @@property {string} sortDirection - Sort direction (asc/desc)
         * @@property {number|null} editingId - ID of the record being edited
         * @@property {boolean} hasPreviousPage - Whether there is a previous page
         * @@property {boolean} hasNextPage - Whether there is a next page
         */
        let bankState = {
            data: [],
            page: 1,
            pageSize: 10,
            totalCount: 0,
            totalPages: 0,
            search: '',
            sortColumn: 'Id',
            sortDirection: 'asc',
            editingId: null,
            hasPreviousPage: false,
            hasNextPage: false
        };

        let bankSearchDebounceTimer;
        let deleteTargetId = null;

        /**
         * Loads bank accounts from the API based on current state.
         * @@returns {Promise<void>}
         */
        async function loadBanks() {
            try {
                const params = new URLSearchParams({
                    page: bankState.page,
                    pageSize: bankState.pageSize,
                    search: bankState.search,
                    sortColumn: bankState.sortColumn,
                    sortDirection: bankState.sortDirection
                });

                const response = await fetch(`/BankAccount/api/index?${params}`);
                if (!response.ok) throw new Error('Load failed');
                
                const result = await response.json();
                bankState.data = result.data || [];
                bankState.totalCount = result.totalCount || 0;
                bankState.totalPages = result.totalPages || 0;
                bankState.page = result.page || 1;
                bankState.hasPreviousPage = result.hasPreviousPage || false;
                bankState.hasNextPage = result.hasNextPage || false;
                
                renderBankTable();
                renderBankSummary();
                renderBankPagination();
                updateSortIcons();
            } catch (error) {
                console.error(error);
                showToast('Failed to load bank accounts', 'error');
            }
        }

        /**
         * Renders the bank table rows.
         */
        function renderBankTable() {
            const tbody = document.getElementById('bankTableBody');
            tbody.innerHTML = '';

            if (bankState.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text-muted);">No accounts found</td></tr>';
                return;
            }

            bankState.data.forEach(bank => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td class="font-weight-bold">${escapeHtml(bank.accountName)}</td>
                    <td>${escapeHtml(bank.bankName)}</td>
                    <td class="text-mono">${escapeHtml(bank.accountNumber)}</td>
                    <td class="text-mono">${escapeHtml(bank.ifscCode || '-')}</td>
                    <td class="font-weight-bold">₹${formatNumber(bank.openingBalance)}</td>
                    <td><span class="badge-tally ${bank.status === 'Active' ? 'badge-success' : 'badge-warning'}">${escapeHtml(bank.status)}</span></td>
                    <td>
                        <button class="btn-tally-edit" onclick="editBank(${bank.id})"><i class="bi bi-pencil"></i></button>
                        <button class="btn-tally-danger" onclick="deleteBank(${bank.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(row);
            });

            const start = ((bankState.page - 1) * bankState.pageSize) + 1;
            document.getElementById('bankShowingStart').textContent = bankState.totalCount > 0 ? start : 0;
            document.getElementById('bankShowingEnd').textContent = Math.min(start + bankState.pageSize - 1, bankState.totalCount);
            document.getElementById('bankTotalRecords').textContent = bankState.totalCount;
        }

        /**
         * Renders the bank summary cards.
         */
        function renderBankSummary() {
            const container = document.getElementById('bankSummaryCards');
            container.innerHTML = '';
            
            // Show first 3 banks in cards
            bankState.data.slice(0, 3).forEach((bank, idx) => {
                const accents = ['var(--primary)', 'var(--accent2)', 'var(--accent)'];
                const card = document.createElement('div');
                card.className = 'col-md-4';
                card.innerHTML = `
                    <div class="stat-card" style="--card-accent:${accents[idx % 3]}">
                        <div class="stat-label">${escapeHtml(bank.accountName)}</div>
                        <div class="stat-value">₹${formatNumber(bank.openingBalance)}</div>
                        <div class="stat-change up"><i class="bi bi-bank"></i> •••• ${bank.accountNumber.slice(-4)}</div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        /**
         * Renders the pagination controls for bank table.
         */
        function renderBankPagination() {
            const pageNumbersEl = document.getElementById('bankPageNumbers');
            pageNumbersEl.innerHTML = '';

            const maxButtons = 5;
            let startPage = Math.max(1, bankState.page - Math.floor(maxButtons / 2));
            let endPage = Math.min(bankState.totalPages, startPage + maxButtons - 1);
            if (endPage - startPage < maxButtons - 1) {
                startPage = Math.max(1, endPage - maxButtons + 1);
            }

            for (let i = startPage; i <= endPage; i++) {
                const btn = document.createElement('button');
                btn.className = `btn-tally-outline ${i === bankState.page ? 'active' : ''}`;
                btn.style.cssText = 'padding:6px 10px;min-width:36px;';
                btn.textContent = i;
                btn.onclick = () => goToBankPage(i);
                pageNumbersEl.appendChild(btn);
            }

            document.getElementById('bankPrevBtn').disabled = !bankState.hasPreviousPage;
            document.getElementById('bankNextBtn').disabled = !bankState.hasNextPage;
            document.getElementById('bankPageSizeSelect').value = bankState.pageSize;
        }

        /**
         * Navigates to a specific page.
         * @@param {number} page - Page number
         */
        function goToBankPage(page) {
            if (page < 1 || page > bankState.totalPages) return;
            bankState.page = page;
            loadBanks();
        }

        /**
         * Navigates to the previous page.
         */
        function prevBankPage() {
            if (bankState.hasPreviousPage) goToBankPage(bankState.page - 1);
        }

        /**
         * Navigates to the next page.
         */
        function nextBankPage() {
            if (bankState.hasNextPage) goToBankPage(bankState.page + 1);
        }

        /**
         * Changes the page size and reloads data.
         */
        function changeBankPageSize() {
            const select = document.getElementById('bankPageSizeSelect');
            bankState.pageSize = parseInt(select.value);
            bankState.page = 1;
            loadBanks();
        }

        /**
         * Handles the bank table sorting.
         * @@param {string} column - Column to sort by
         */
        function sortBy(column) {
            if (bankState.sortColumn === column) {
                bankState.sortDirection = bankState.sortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                bankState.sortColumn = column;
                bankState.sortDirection = 'asc';
            }
            bankState.page = 1;
            loadBanks();
        }

        /**
         * Updates sort icons in the table header.
         */
        function updateSortIcons() {
            document.querySelectorAll('th[onclick^="sortBy"]').forEach(th => {
                const icon = th.querySelector('i');
                if (icon) {
                    const colMatch = th.getAttribute('onclick').match(/'([^']+)'/);
                    if (colMatch) {
                        const col = colMatch[1];
                        if (col === bankState.sortColumn) {
                            icon.className = `bi bi-sort-${bankState.sortDirection === 'asc' ? 'down' : 'up'} ms-1`;
                            icon.style.color = 'var(--primary)';
                        } else {
                            icon.className = 'bi bi-arrow-down-up ms-1';
                            icon.style.color = 'var(--text-muted)';
                        }
                    }
                }
            });
        }

        /**
         * Opens a modal for adding or editing a bank account.
         * @@param {string} modalId - ID of the modal to open
         * @@param {Object|null} data - Data to populate the modal with
         */
        function openModal(modalId, data = null) {
            const overlay = document.getElementById(modalId);
            if (!overlay) return;

            if (modalId === 'bankModal') {
                resetBankForm();
                if (data) {
                    bankState.editingId = data.id;
                    document.querySelector('#bankModal .modal-title').textContent = 'Edit Bank Account';
                    document.getElementById('btnSaveBank').innerHTML = '<i class="bi bi-check-lg"></i> Update Account';
                    
                    document.getElementById('bankId').value = data.id;
                    document.getElementById('bankAccountName').value = data.accountName;
                    document.getElementById('bankAccountType').value = data.accountType;
                    document.getElementById('bankName').value = data.bankName;
                    document.getElementById('bankAccountNumber').value = data.accountNumber;
                    document.getElementById('bankIfscCode').value = data.ifscCode || '';
                    document.getElementById('bankOpeningBalance').value = data.openingBalance;
                    document.getElementById('bankStatus').value = data.status;
                } else {
                    bankState.editingId = null;
                    document.querySelector('#bankModal .modal-title').textContent = 'Add Bank Account';
                    document.getElementById('btnSaveBank').innerHTML = '<i class="bi bi-check-lg"></i> Save Account';
                }
            }
            overlay.classList.add('open');
        }

        /**
         * Closes a modal.
         * @@param {string} modalId - ID of the modal to close
         */
        function closeModal(modalId) {
            document.getElementById(modalId)?.classList.remove('open');
        }

        /**
         * Resets the bank form fields.
         */
        function resetBankForm() {
            document.getElementById('bankId').value = '';
            document.getElementById('bankAccountName').value = '';
            document.getElementById('bankAccountType').value = 'Current';
            document.getElementById('bankName').value = '';
            document.getElementById('bankAccountNumber').value = '';
            document.getElementById('bankIfscCode').value = '';
            document.getElementById('bankOpeningBalance').value = '';
            document.getElementById('bankStatus').value = 'Active';
            document.querySelectorAll('.field-error').forEach(el => el.textContent = '');
        }

        /**
         * Saves (creates or updates) a bank record.
         * @@returns {Promise<void>}
         */
        async function saveBank() {
            // Clear previous errors
            document.querySelectorAll('.field-error').forEach(el => { el.textContent = ''; el.style.display = 'none'; });

            const formData = {
                accountName: document.getElementById('bankAccountName').value.trim(),
                accountType: document.getElementById('bankAccountType').value,
                bankName: document.getElementById('bankName').value.trim(),
                accountNumber: document.getElementById('bankAccountNumber').value.trim(),
                ifscCode: document.getElementById('bankIfscCode').value.trim(),
                openingBalance: parseFloat(document.getElementById('bankOpeningBalance').value) || 0,
                status: document.getElementById('bankStatus').value
            };

            try {
                const url = bankState.editingId ? `/BankAccount/update/${bankState.editingId}` : `/BankAccount/create`;
                const method = bankState.editingId ? 'PUT' : 'POST';

                const response = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();
                if (!response.ok) {
                    if (result.errors) {
                        for (const [f, m] of Object.entries(result.errors)) showFieldError(f, m.join(', '));
                        return;
                    }
                    throw new Error(result.message || 'Save failed');
                }

                closeModal('bankModal');
                showToast('Bank account saved!', 'success');
                loadBanks();
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        /**
         * Prepares a bank account for editing.
         * @@param {number} id - Account ID
         */
        function editBank(id) {
            const bank = bankState.data.find(b => b.id === id);
            if (bank) openModal('bankModal', bank);
        }

        /**
         * Opens delete confirmation.
         * @@param {number} id - Account ID
         */
        function deleteBank(id) {
            deleteTargetId = id;
            openModal('deleteModal');
        }

        /**
         * Confirms deletion.
         */
        async function confirmDelete() {
            if (!deleteTargetId) return;
            try {
                const response = await fetch(`/BankAccount/delete/${deleteTargetId}`, { method: 'DELETE' });
                if (!response.ok) throw new Error('Delete failed');
                closeModal('deleteModal');
                showToast('Bank account deleted', 'success');
                loadBanks();
            } catch (error) {
                showToast('Error deleting account', 'error');
            } finally {
                deleteTargetId = null;
            }
        }

        /**
         * Handles the bank search input event with debouncing.
         * @@param {Event} e - Input event
         */
        function handleBankSearch(e) {
            clearTimeout(bankSearchDebounceTimer);
            const q = e.target.value.trim();
            bankSearchDebounceTimer = setTimeout(() => {
                bankState.search = q;
                bankState.page = 1;
                loadBanks();
            }, 500);
        }

        /**
         * Displays a field error.
         * @@param {string} field - Field name
         * @@param {string} msg - Error message
         */
        function showFieldError(field, msg) {
            const el = document.getElementById(`error-${field}`);
            if (el) { el.textContent = msg; el.style.display = 'block'; }
        }

        /**
         * Escapes HTML.
         * @@param {string} text - Text to escape
         * @@returns {string} Escaped text
         */
        function escapeHtml(text) {
            if (!text) return '';
            const d = document.createElement('div');
            d.textContent = text;
            return d.innerHTML;
        }

        /**
         * Formats a number to Indian locale.
         * @@param {number} num - Number to format
         * @@returns {string} Formatted number
         */
        function formatNumber(num) {
            if (num === null || num === undefined) return '0.00';
            return parseFloat(num).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        /**
         * Displays a toast notification.
         * @@param {string} message - Message
         * @@param {string} [type='success'] - Toast type
         */
        function showToast(message, type = 'success') {
            const icons = { success: '✅', error: '❌', info: 'ℹ️' };
            const container = document.getElementById('toastContainer');
            if(!container) return;
            const toast = document.createElement('div');
            toast.className = `tally-toast ${type}`;
            toast.innerHTML = `<span style="font-size:16px">${icons[type]}</span><span>${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                toast.style.transition = '0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadBanks();
            
            // Close modals on overlay click
            document.querySelectorAll('.tally-modal-overlay').forEach(overlay => {
                overlay.addEventListener('click', function(e) {
                    if (e.target === this) closeModal(this.id);
                });
            });
        });
    </script>
</body>

</html>
