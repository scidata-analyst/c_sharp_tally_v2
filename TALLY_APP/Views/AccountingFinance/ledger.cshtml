    <partial name="_Scripts" />

    <script>
        // ============================================================
        // STATE
        // ============================================================
        let currentPage = 'ledger';
        let ledgerState = {
            data: [],
            page: 1,
            pageSize: 10,
            totalCount: 0,
            totalPages: 0,
            search: '',
            sortColumn: 'Id',
            sortDirection: 'asc',
            editingId: null
        };
        let deleteTarget = null;
        let searchDebounceTimer = null;

        // ============================================================
        // MODAL MANAGEMENT
        // ============================================================
        function openModal(modalId, ledger = null) {
            const overlay = document.getElementById(modalId);
            if (overlay) {
                overlay.classList.add('open');
                if (ledger) {
                    // Edit mode - populate form
                    ledgerState.editingId = ledger.id;
                    document.getElementById('ledgerModalTitle').textContent = 'Edit Ledger';
                    populateForm(ledger);
                } else {
                    // Create mode - clear form
                    ledgerState.editingId = null;
                    document.getElementById('ledgerModalTitle').textContent = 'Create New Ledger';
                    clearForm();
                }
                clearErrors();
            }
        }

        function closeModal(modalId) {
            const overlay = document.getElementById(modalId);
            if (overlay) overlay.classList.remove('open');
        }

        function populateForm(ledger) {
            document.getElementById('LedgerName').value = ledger.ledgerName || '';
            document.getElementById('LedgerCode').value = ledger.ledgerCode || '';
            document.getElementById('GroupName').value = ledger.groupName || '';
            document.getElementById('AccountType').value = ledger.accountType || '';
            document.getElementById('OpeningBalance').value = ledger.openingBalance || '';
            document.getElementById('BalanceType').value = ledger.balanceType || 'Dr';
            document.getElementById('Description').value = ledger.description || '';
            document.getElementById('Currency').value = ledger.currency || 'INR';
            document.getElementById('Status').value = ledger.status || 'Active';
        }

        function clearForm() {
            document.getElementById('LedgerName').value = '';
            document.getElementById('LedgerCode').value = '';
            document.getElementById('GroupName').value = '';
            document.getElementById('AccountType').value = '';
            document.getElementById('OpeningBalance').value = '';
            document.getElementById('BalanceType').value = 'Dr';
            document.getElementById('Description').value = '';
            document.getElementById('Currency').value = 'INR';
            document.getElementById('Status').value = 'Active';
        }

        function clearErrors() {
            document.querySelectorAll('.field-error').forEach(el => el.textContent = '');
        }

        function showFieldError(fieldId, message) {
            const errorEl = document.getElementById('error-' + fieldId);
            if (errorEl) errorEl.textContent = message;
        }

        // Close on overlay click
        document.querySelectorAll('.tally-modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', function (e) {
                if (e.target === this) closeModal(this.id);
            });
        });

        // ============================================================
        // DATA LOADING
        // ============================================================
        async function loadLedgers() {
            const params = new URLSearchParams({
                page: ledgerState.page,
                pageSize: ledgerState.pageSize,
                search: ledgerState.search,
                sortColumn: ledgerState.sortColumn,
                sortDirection: ledgerState.sortDirection
            });

            try {
                const response = await fetch(`/LedgerAccount/api/index?${params}`);
                if (!response.ok) throw new Error('Network response was not ok');
                const result = await response.json();

                ledgerState.data = result.data || [];
                ledgerState.totalCount = result.totalCount || 0;
                ledgerState.totalPages = result.totalPages || 0;
                ledgerState.page = result.page || 1;
                ledgerState.hasPreviousPage = result.hasPreviousPage || false;
                ledgerState.hasNextPage = result.hasNextPage || false;

                renderTable();
                renderPagination();
                updateSortIcons();
            } catch (error) {
                console.error('Error fetching ledgers:', error);
                showToast('Failed to load ledgers', 'error');
            }
        }

        function renderTable() {
            const tbody = document.getElementById('ledgerTableBody');
            tbody.innerHTML = '';

            if (ledgerState.data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text-muted);">No records found</td></tr>`;
                return;
            }

            const start = ((ledgerState.page - 1) * ledgerState.pageSize) + 1;
            ledgerState.data.forEach((ledger, index) => {
                const row = document.createElement('tr');
                const serial = start + index;
                row.innerHTML = `
                    <td>${serial}</td>
                    <td>${escapeHtml(ledger.ledgerName)}</td>
                    <td>${escapeHtml(ledger.groupName)}</td>
                    <td>${escapeHtml(ledger.accountType)}</td>
                    <td class="amount-positive">₹${formatNumber(ledger.openingBalance)}</td>
                    <td><span class="badge-tally ${ledger.status === 'Active' ? 'badge-success' : 'badge-warning'}">${escapeHtml(ledger.status)}</span></td>
                    <td>
                        <button class="btn-tally-edit" onclick="editLedgerById(${ledger.id})"><i class="bi bi-pencil"></i></button>
                        <button class="btn-tally-danger" onclick="deleteLedger(${ledger.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(row);
            });

            document.getElementById('showingStart').textContent = ledgerState.totalCount > 0 ? start : 0;
            document.getElementById('showingEnd').textContent = Math.min(start + ledgerState.pageSize - 1, ledgerState.totalCount);
            document.getElementById('totalRecords').textContent = ledgerState.totalCount;
        }

        function renderPagination() {
            const pageNumbersEl = document.getElementById('pageNumbers');
            pageNumbersEl.innerHTML = '';

            // Generate page number buttons (up to 5)
            const maxButtons = 5;
            let startPage = Math.max(1, ledgerState.page - Math.floor(maxButtons / 2));
            let endPage = Math.min(ledgerState.totalPages, startPage + maxButtons - 1);
            if (endPage - startPage < maxButtons - 1) {
                startPage = Math.max(1, endPage - maxButtons + 1);
            }

            for (let i = startPage; i <= endPage; i++) {
                const btn = document.createElement('button');
                btn.className = `btn-tally-outline ${i === ledgerState.page ? 'active' : ''}`;
                btn.style.cssText = 'padding:6px 10px;min-width:36px;';
                btn.textContent = i;
                btn.onclick = () => goToPage(i);
                pageNumbersEl.appendChild(btn);
            }

            document.getElementById('prevBtn').disabled = !ledgerState.hasPreviousPage;
            document.getElementById('nextBtn').disabled = !ledgerState.hasNextPage;
            document.getElementById('pageSizeSelect').value = ledgerState.pageSize;
        }

        function goToPage(page) {
            if (page < 1 || page > ledgerState.totalPages) return;
            ledgerState.page = page;
            loadLedgers();
        }

        function prevPage() {
            if (ledgerState.hasPreviousPage) goToPage(ledgerState.page - 1);
        }

        function nextPage() {
            if (ledgerState.hasNextPage) goToPage(ledgerState.page + 1);
        }

        function changePageSize() {
            const select = document.getElementById('pageSizeSelect');
            ledgerState.pageSize = parseInt(select.value);
            ledgerState.page = 1; // Reset to first page
            loadLedgers();
        }

        function sortBy(column) {
            if (ledgerState.sortColumn === column) {
                ledgerState.sortDirection = ledgerState.sortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                ledgerState.sortColumn = column;
                ledgerState.sortDirection = 'asc';
            }
            ledgerState.page = 1;
            loadLedgers();
        }

        /**
         * Updates sort icons in the table header.
         */
        function updateSortIcons() {
            document.querySelectorAll('th[onclick^="sortBy"]').forEach(th => {
                const icon = th.querySelector('i');
                if (icon) {
                    const colMatch = th.getAttribute('onclick').match(/'([^']+)'/);
                    if (colMatch) {
                        const col = colMatch[1];
                        if (col === ledgerState.sortColumn) {
                            icon.className = `bi bi-sort-${ledgerState.sortDirection === 'asc' ? 'down' : 'up'} ms-1`;
                            icon.style.color = 'var(--primary)';
                        } else {
                            icon.className = 'bi bi-arrow-down-up ms-1';
                            icon.style.color = 'var(--text-muted)';
                        }
                    }
                }
            });
        }

        // ============================================================
        // CRUD OPERATIONS
        // ============================================================
        async function saveLedger() {
            clearErrors();

            const formData = {
                ledgerName: document.getElementById('LedgerName').value.trim(),
                ledgerCode: document.getElementById('LedgerCode').value.trim(),
                groupName: document.getElementById('GroupName').value,
                accountType: document.getElementById('AccountType').value,
                openingBalance: parseFloat(document.getElementById('OpeningBalance').value) || 0,
                balanceType: document.getElementById('BalanceType').value,
                description: document.getElementById('Description').value.trim(),
                currency: document.getElementById('Currency').value,
                status: document.getElementById('Status').value
            };

            // Client-side validation
            let hasError = false;
            if (!formData.ledgerName) { showFieldError('LedgerName', 'Ledger Name is required'); hasError = true; }
            if (!formData.ledgerCode) { showFieldError('LedgerCode', 'Ledger Code is required'); hasError = true; }
            if (!formData.groupName) { showFieldError('GroupName', 'Group is required'); hasError = true; }
            if (!formData.accountType) { showFieldError('AccountType', 'Account Type is required'); hasError = true; }
            if (!formData.balanceType) { showFieldError('BalanceType', 'Balance Type is required'); hasError = true; }
            if (!formData.currency) { showFieldError('Currency', 'Currency is required'); hasError = true; }
            if (!formData.status) { showFieldError('Status', 'Status is required'); hasError = true; }

            if (hasError) return;

            try {
                const url = ledgerState.editingId
                    ? `/LedgerAccount/update/${ledgerState.editingId}`
                    : `/LedgerAccount/create`;
                const method = ledgerState.editingId ? 'PUT' : 'POST';

                const response = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();

                if (!response.ok) {
                    if (response.status === 400 && result.errors) {
                        // Display server validation errors
                        for (const [field, messages] of Object.entries(result.errors)) {
                            showFieldError(field, messages.join(', '));
                        }
                        return;
                    }
                    throw new Error(result.message || 'Save failed');
                }

                closeModal('ledgerModal');
                showToast(ledgerState.editingId ? 'Ledger updated!' : 'Ledger created!', 'success');
                loadLedgers();
            } catch (error) {
                console.error('Save error:', error);
                showToast('Failed to save ledger: ' + error.message, 'error');
            }
        }

        function editLedgerById(id) {
            const ledger = ledgerState.data.find(l => l.id === id);
            if (ledger) {
                openModal('ledgerModal', ledger);
            } else {
                showToast('Ledger not found', 'error');
            }
        }

        function editLedger(id) {
            editLedgerById(id);
        }

        async function deleteLedger(id) {
            deleteTarget = { id };
            openModal('deleteModal');
        }

        async function confirmDelete() {
            if (!deleteTarget) return;

            try {
                const response = await fetch(`/LedgerAccount/delete/${deleteTarget.id}`, { method: 'DELETE' });
                if (!response.ok) throw new Error('Delete failed');

                closeModal('deleteModal');
                showToast('Ledger deleted successfully', 'success');
                loadLedgers();
            } catch (error) {
                showToast('Failed to delete ledger', 'error');
            } finally {
                deleteTarget = null;
            }
        }

        // ============================================================
        // SEARCH
        // ============================================================
        function handleSearch(e) {
            clearTimeout(searchDebounceTimer);
            const query = e.target.value.trim();
            searchDebounceTimer = setTimeout(() => {
                ledgerState.search = query;
                ledgerState.page = 1;
                loadLedgers();
            }, 500);
        }

        // ============================================================
        // UTILITY
        // ============================================================
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function formatNumber(num) {
            if (num === null || num === undefined) return '0';
            return parseFloat(num).toLocaleString('en-IN', { maximumFractionDigits: 2 });
        }

        // ============================================================
        // TOAST NOTIFICATIONS
        // ============================================================
        function showToast(message, type = 'success') {
            const icons = { success: '✅', error: '❌', info: 'ℹ️' };
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `tally-toast ${type}`;
            toast.innerHTML = `<span style="font-size:16px">${icons[type]}</span><span>${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                toast.style.transition = '0.3s ease';
                toast.style.pointerEvents = 'none';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // ============================================================
        // MODULE SEARCH
        // ============================================================
        document.getElementById('moduleSearch').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('.nav-sublink').forEach(link => {
                const text = link.textContent.toLowerCase();
                const item = link.closest('.nav-item');
                if (q && text.includes(q)) {
                    link.style.display = 'flex';
                    if (item) item.classList.add('open');
                    link.style.background = 'rgba(0,200,150,0.1)';
                    link.style.color = 'var(--primary)';
                } else if (!q) {
                    link.style.display = '';
                    link.style.background = '';
                    link.style.color = '';
                } else {
                    link.style.display = 'none';
                }
            });
            if (!q) {
                document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('open'));
            }
        });

        // ============================================================
        // TABLE SEARCH (delegates to server)
        // ============================================================
        document.querySelector('.table-search').addEventListener('input', handleSearch);

        // ============================================================
        // FULLSCREEN
        // ============================================================
        document.querySelector('[title="Full Screen"]')?.addEventListener('click', function () {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen();
                this.querySelector('i').className = 'bi bi-fullscreen-exit';
            } else {
                document.exitFullscreen();
                this.querySelector('i').className = 'bi bi-fullscreen';
            }
        });

        // ============================================================
        // KEYBOARD SHORTCUTS
        // ============================================================
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                document.querySelectorAll('.tally-modal-overlay.open').forEach(m => m.classList.remove('open'));
            }
            if (e.ctrlKey && e.key === 'l') { e.preventDefault(); /* nav to ledger */ }
        });

        // ============================================================
        // INITIALIZATION
        // ============================================================
        document.addEventListener('DOMContentLoaded', function () {
            loadLedgers();
            showToast('Ledger data loaded', 'info');
        });
    </script>
</body>

</html>

