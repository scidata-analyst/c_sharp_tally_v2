@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <partial name="_Styles" />
</head>

<body>

    <partial name="_Sidebar" />


    <partial name="_Header" model='@("Ledger Management")' />

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== LEDGER MANAGEMENT ===================== -->
        <div class="page active" id="page-ledger">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Ledger Management</div>
                    <div class="page-subtitle">Accounting & Finance · Create and manage ledger accounts</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('ledgerModal')">
                    <i class="bi bi-plus-lg"></i> New Ledger
                </button>
            </div>

            <!-- Stats -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--primary)">
                        <div class="stat-label">Total Ledgers</div>
                        <div class="stat-value">248</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--accent2)">
                        <div class="stat-label">Asset Accounts</div>
                        <div class="stat-value">62</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--accent)">
                        <div class="stat-label">Liability Accounts</div>
                        <div class="stat-value">48</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--danger)">
                        <div class="stat-label">Expense Accounts</div>
                        <div class="stat-value">84</div>
                    </div>
                </div>
            </div>

            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">All Ledger Accounts</div>
                    <div class="table-actions">
                        <input type="text" class="table-search" placeholder="Search ledger...">
                        <button class="btn-tally-outline"><i class="bi bi-funnel"></i> Filter</button>
                        <button class="btn-tally-outline"><i class="bi bi-download"></i> Export</button>
                    </div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('Id')" style="cursor:pointer;"># <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('LedgerName')" style="cursor:pointer;">Ledger Name <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('GroupName')" style="cursor:pointer;">Group <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('AccountType')" style="cursor:pointer;">Type <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('OpeningBalance')" style="cursor:pointer;">Opening Bal <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="ledgerTableBody">
                        <!-- Data will be loaded via AJAX -->
                    </tbody>
                </table>

                <!-- Pagination Controls -->
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">
                        Showing <span id="showingStart">0</span> to <span id="showingEnd">0</span> of <span id="totalRecords">0</span> records
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows per page:</label>
                        <select id="pageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changePageSize()">
                            <option value="5">5</option>
                            <option value="10" selected>10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="prevBtn" style="padding:6px 12px;" onclick="prevPage()"><i class="bi bi-chevron-left"></i></button>
                            <span id="pageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="nextBtn" style="padding:6px 12px;" onclick="nextPage()"><i class="bi bi-chevron-right"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- ===================== MODALS ===================== -->

    <!-- Ledger Modal -->
    <div class="tally-modal-overlay" id="ledgerModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title" id="ledgerModalTitle">Create New Ledger</div>
                <div class="modal-close" onclick="closeModal('ledgerModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label class="form-label">Ledger Name *</label>
                            <input type="text" class="form-control-tally" placeholder="e.g. HDFC Bank Account" id="LedgerName">
                            <div class="field-error" id="error-LedgerName"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Ledger Code *</label>
                            <input type="text" class="form-control-tally" placeholder="e.g. 001" id="LedgerCode">
                            <div class="field-error" id="error-LedgerCode"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Under Group *</label>
                            <select class="form-control-tally" id="GroupName">
                                <option value="">-- Select Group --</option>
                                <option value="Cash-in-Hand">Cash-in-Hand</option>
                                <option value="Bank Accounts">Bank Accounts</option>
                                <option value="Sundry Debtors">Sundry Debtors</option>
                                <option value="Sundry Creditors">Sundry Creditors</option>
                                <option value="Sales Accounts">Sales Accounts</option>
                                <option value="Purchase Accounts">Purchase Accounts</option>
                                <option value="Duties & Taxes">Duties & Taxes</option>
                                <option value="Fixed Assets">Fixed Assets</option>
                                <option value="Investments">Investments</option>
                            </select>
                            <div class="field-error" id="error-GroupName"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Account Type *</label>
                            <select class="form-control-tally" id="AccountType">
                                <option value="">-- Select Type --</option>
                                <option value="Asset">Asset</option>
                                <option value="Liability">Liability</option>
                                <option value="Revenue">Revenue</option>
                                <option value="Expense">Expense</option>
                            </select>
                            <div class="field-error" id="error-AccountType"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Opening Balance</label>
                            <input type="number" class="form-control-tally" placeholder="0.00" id="OpeningBalance" step="0.01">
                            <div class="field-error" id="error-OpeningBalance"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Balance Type</label>
                            <select class="form-control-tally" id="BalanceType">
                                <option value="Dr">Debit (Dr)</option>
                                <option value="Cr">Credit (Cr)</option>
                            </select>
                            <div class="field-error" id="error-BalanceType"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-group">
                            <label class="form-label">Description / Notes</label>
                            <textarea class="form-control-tally" rows="2" placeholder="Optional description..." id="Description"></textarea>
                            <div class="field-error" id="error-Description"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Currency</label>
                            <select class="form-control-tally" id="Currency">
                                <option value="INR">INR — Indian Rupee</option>
                                <option value="USD">USD — US Dollar</option>
                                <option value="EUR">EUR — Euro</option>
                            </select>
                            <div class="field-error" id="error-Currency"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <select class="form-control-tally" id="Status">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                            <div class="field-error" id="error-Status"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('ledgerModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveLedger()"><i class="bi bi-check-lg"></i> Save
                    Ledger</button>
            </div>
        </div>
    </div>

    <!-- Voucher Modal -->
    <div class="tally-modal-overlay" id="voucherModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Create Voucher</div>
                <div class="modal-close" onclick="closeModal('voucherModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Voucher Type *</label><select
                                class="form-control-tally">
                                <option>Payment</option>
                                <option>Receipt</option>
                                <option>Journal</option>
                                <option>Contra</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Voucher Date *</label><input type="date"
                                class="form-control-tally"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Party / Account *</label><input type="text"
                                class="form-control-tally" placeholder="Select or type party name"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Amount *</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Payment Mode</label><select
                                class="form-control-tally">
                                <option>Cash</option>
                                <option>Bank Transfer</option>
                                <option>Cheque</option>
                                <option>UPI</option>
                                <option>NEFT/RTGS</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Reference No.</label><input type="text"
                                class="form-control-tally" placeholder="Cheque / UTR / Ref No."></div>
                    </div>
                    <div class="col-12">
                        <div class="form-group"><label class="form-label">Narration</label><textarea
                                class="form-control-tally" rows="2"
                                placeholder="Brief description of this voucher..."></textarea></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('voucherModal')">Cancel</button>
                <button class="btn-tally-outline" onclick="showToast('Saved as Draft','info')"><i
                        class="bi bi-file-earmark"></i> Save Draft</button>
                <button class="btn-tally-primary"
                    onclick="closeModal('voucherModal');showToast('Voucher created successfully!','success')"><i
                        class="bi bi-check-lg"></i> Post Voucher</button>
            </div>
        </div>
    </div>

    <!-- Stock Item Modal -->
    <div class="tally-modal-overlay" id="stockModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Add Stock Item</div>
                <div class="modal-close" onclick="closeModal('stockModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="form-group"><label class="form-label">Item Name *</label><input type="text"
                                class="form-control-tally" placeholder="e.g. Steel Pipe 2 inch"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Item Code</label><input type="text"
                                class="form-control-tally" placeholder="ITM-001"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Category *</label><select
                                class="form-control-tally">
                                <option>Electrical</option>
                                <option>Pipes & Fittings</option>
                                <option>Building Materials</option>
                                <option>Electronics</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Unit of Measure *</label><select
                                class="form-control-tally">
                                <option>Pcs</option>
                                <option>Kg</option>
                                <option>Litre</option>
                                <option>Roll</option>
                                <option>Bag</option>
                                <option>Box</option>
                            </select></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Opening Qty</label><input type="number"
                                class="form-control-tally" placeholder="0"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Purchase Rate</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Selling Rate</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Valuation Method</label><select
                                class="form-control-tally">
                                <option>FIFO</option>
                                <option>LIFO</option>
                                <option>Average Cost</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Reorder Level</label><input type="number"
                                class="form-control-tally" placeholder="Minimum stock level"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">GST Rate (%)</label><select
                                class="form-control-tally">
                                <option>0%</option>
                                <option>5%</option>
                                <option>12%</option>
                                <option>18%</option>
                                <option>28%</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">HSN / SAC Code</label><input type="text"
                                class="form-control-tally" placeholder="8-digit HSN code"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('stockModal')">Cancel</button>
                <button class="btn-tally-primary"
                    onclick="closeModal('stockModal');showToast('Stock item added!','success')"><i
                        class="bi bi-check-lg"></i> Save Item</button>
            </div>
        </div>
    </div>

    <!-- Employee Modal -->
    <div class="tally-modal-overlay" id="employeeModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Add Employee</div>
                <div class="modal-close" onclick="closeModal('employeeModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">First Name *</label><input type="text"
                                class="form-control-tally" placeholder="First Name"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Last Name *</label><input type="text"
                                class="form-control-tally" placeholder="Last Name"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Employee ID</label><input type="text"
                                class="form-control-tally" placeholder="EMP-005"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Joining Date</label><input type="date"
                                class="form-control-tally"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Department *</label><select
                                class="form-control-tally">
                                <option>Accounts</option>
                                <option>HR</option>
                                <option>Sales</option>
                                <option>IT</option>
                                <option>Operations</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Designation *</label><input type="text"
                                class="form-control-tally" placeholder="e.g. Senior Manager"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Basic Salary *</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">HRA</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Allowances</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">PAN Number</label><input type="text"
                                class="form-control-tally" placeholder="ABCDE1234F"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Aadhar Number</label><input type="text"
                                class="form-control-tally" placeholder="XXXX XXXX XXXX"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">PF Applicable</label><select
                                class="form-control-tally">
                                <option>Yes</option>
                                <option>No</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">ESI Applicable</label><select
                                class="form-control-tally">
                                <option>Yes (if salary ≤21000)</option>
                                <option>No</option>
                            </select></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('employeeModal')">Cancel</button>
                <button class="btn-tally-primary"
                    onclick="closeModal('employeeModal');showToast('Employee added successfully!','success')"><i
                        class="bi bi-check-lg"></i> Save Employee</button>
            </div>
        </div>
    </div>

    <!-- GST Entry Modal -->
    <div class="tally-modal-overlay" id="gstModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Add GST Entry</div>
                <div class="modal-close" onclick="closeModal('gstModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Invoice Number *</label><input type="text"
                                class="form-control-tally" placeholder="INV-XXXX"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Invoice Date *</label><input type="date"
                                class="form-control-tally"></div>
                    </div>
                    <div class="col-md-8">
                        <div class="form-group"><label class="form-label">Party Name *</label><input type="text"
                                class="form-control-tally" placeholder="Customer / Supplier name"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Type</label><select
                                class="form-control-tally">
                                <option>B2B</option>
                                <option>B2C</option>
                                <option>Export</option>
                                <option>Import</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Party GSTIN</label><input type="text"
                                class="form-control-tally" placeholder="15-char GSTIN" maxlength="15"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Place of Supply</label><select
                                class="form-control-tally">
                                <option>Maharashtra (27)</option>
                                <option>Delhi (07)</option>
                                <option>Karnataka (29)</option>
                                <option>Tamil Nadu (33)</option>
                            </select></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Taxable Amount *</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">GST Rate</label><select
                                class="form-control-tally">
                                <option>0%</option>
                                <option>5%</option>
                                <option>12%</option>
                                <option>18%</option>
                                <option>28%</option>
                            </select></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Transaction Type</label><select
                                class="form-control-tally">
                                <option>Inter-state (IGST)</option>
                                <option>Intra-state (CGST+SGST)</option>
                            </select></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('gstModal')">Cancel</button>
                <button class="btn-tally-primary"
                    onclick="closeModal('gstModal');showToast('GST entry saved!','success')"><i
                        class="bi bi-check-lg"></i> Save Entry</button>
            </div>
        </div>
    </div>

    <!-- User Modal -->
    <div class="tally-modal-overlay" id="userModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Add System User</div>
                <div class="modal-close" onclick="closeModal('userModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Full Name *</label><input type="text"
                                class="form-control-tally" placeholder="User full name"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Email *</label><input type="email"
                                class="form-control-tally" placeholder="user@company.com"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Role *</label><select
                                class="form-control-tally">
                                <option>Super Admin</option>
                                <option>Accountant</option>
                                <option>HR Manager</option>
                                <option>Inventory Manager</option>
                                <option>Read Only</option>
                            </select></div>
                    </div>
