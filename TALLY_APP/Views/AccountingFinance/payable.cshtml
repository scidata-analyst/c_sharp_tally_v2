@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Accounts Payable & Receivable</title>
    <partial name="_Styles" />
</head>

<body>

    <partial name="_Sidebar" />

    <partial name="_Header" model='@("Accounts Payable & Receivable")' />

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== ACCOUNTS PAYABLE & RECEIVABLE ===================== -->
        <div class="page active" id="page-payable">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Accounts Payable & Receivable</div>
                    <div class="page-subtitle">Track outstanding payments and collections</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('partyModal')">
                    <i class="bi bi-plus-lg"></i> Add Party
                </button>
            </div>
            <div class="tally-tabs">
                <button class="tally-tab active" onclick="switchTab(this,'tab-receivable')">Receivable</button>
                <button class="tally-tab" onclick="switchTab(this,'tab-payable')">Payable</button>
                <button class="tally-tab" onclick="switchTab(this,'tab-parties')">Party Directory</button>
            </div>

            <!-- Receivable Tab -->
            <div id="tab-receivable">
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="stat-card" style="--card-accent:var(--primary)">
                            <div class="stat-label">Total Receivable</div>
                            <div class="stat-value">₹12,40,000</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card" style="--card-accent:var(--warning)">
                            <div class="stat-label">Overdue (>30 days)</div>
                            <div class="stat-value">₹3,20,000</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card" style="--card-accent:var(--danger)">
                            <div class="stat-label">Overdue (>60 days)</div>
                            <div class="stat-value">₹80,000</div>
                        </div>
                    </div>
                </div>
                <div class="data-table-wrapper">
                    <div class="table-toolbar">
                        <div class="table-title">Outstanding Receivables</div>
                        <div class="table-actions">
                            <input class="table-search" placeholder="Search party...">
                        </div>
                    </div>
                    <table class="tally-table">
                        <thead>
                            <tr>
                                <th>Invoice No.</th>
                                <th>Party</th>
                                <th>Invoice Date</th>
                                <th>Due Date</th>
                                <th>Amount</th>
                                <th>Aging</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Mock data for now, as focus is on Party Directory CRUD -->
                            <tr>
                                <td>INV-3421</td>
                                <td>Client XYZ Corp</td>
                                <td class="text-mono">01-02-2026</td>
                                <td class="text-mono">15-03-2026</td>
                                <td class="amount-positive">₹1,20,000</td>
                                <td><span class="badge-tally badge-success">Current</span></td>
                                <td><button class="btn-tally-edit"><i class="bi bi-send"></i> Remind</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Payable Tab -->
            <div id="tab-payable" style="display:none">
                <div class="data-table-wrapper">
                    <div class="table-toolbar">
                        <div class="table-title">Outstanding Payables</div>
                    </div>
                    <table class="tally-table">
                        <thead>
                            <tr>
                                <th>Bill No.</th>
                                <th>Supplier</th>
                                <th>Bill Date</th>
                                <th>Due Date</th>
                                <th>Amount</th>
                                <th>Aging</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>PO-891</td>
                                <td>Supplier ABC Pvt</td>
                                <td class="text-mono">01-03-2026</td>
                                <td class="text-mono">31-03-2026</td>
                                <td class="amount-negative">₹45,000</td>
                                <td><span class="badge-tally badge-success">Current</span></td>
                                <td><button class="btn-tally-primary" style="font-size:11px;padding:5px 10px;"><i class="bi bi-credit-card"></i> Pay</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Party Directory Tab -->
            <div id="tab-parties" style="display:none">
                <div class="data-table-wrapper">
                    <div class="table-toolbar">
                        <div class="table-title">Party Directory</div>
                        <div class="table-actions">
                            <input class="table-search" placeholder="Search parties..." oninput="handlePartySearch(event)">
                            <button class="btn-tally-outline" onclick="loadParties()">
                                <i class="bi bi-arrow-clockwise"></i> Refresh
                            </button>
                        </div>
                    </div>
                    <table class="tally-table">
                        <thead>
                            <tr>
                                <th onclick="sortBy('PartyName')" style="cursor:pointer;">
                                    Party Name <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                                </th>
                                <th onclick="sortBy('PartyType')" style="cursor:pointer;">
                                    Type <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                                </th>
                                <th onclick="sortBy('GSTIN')" style="cursor:pointer;">
                                    GSTIN <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                                </th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th onclick="sortBy('Status')" style="cursor:pointer;">
                                    Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                                </th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="partyTableBody">
                            <!-- Loaded via API -->
                        </tbody>
                    </table>

                    <!-- Pagination Controls -->
                    <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                        <div style="font-size:13px;color:var(--text-muted);">
                            Showing <span id="partyShowingStart">0</span> to <span id="partyShowingEnd">0</span> of <span id="partyTotalRecords">0</span> records
                        </div>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <label style="font-size:13px;color:var(--text-muted);">Rows per page:</label>
                            <select id="partyPageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changePartyPageSize()">
                                <option value="5">5</option>
                                <option value="10" selected>10</option>
                                <option value="25">25</option>
                                <option value="50">50</option>
                            </select>
                            <div style="display:flex;gap:4px;">
                                <button class="btn-tally-outline" id="partyPrevBtn" style="padding:6px 12px;" onclick="prevPartyPage()">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <span id="partyPageNumbers" style="display:flex;gap:2px;"></span>
                                <button class="btn-tally-outline" id="partyNextBtn" style="padding:6px 12px;" onclick="nextPartyPage()">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- ===================== MODALS ===================== -->

    <!-- Party Modal -->
    <div class="tally-modal-overlay" id="partyModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Add Party</div>
                <div class="modal-close" onclick="closeModal('partyModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <input type="hidden" id="partyId">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label class="form-label">Party Name *</label>
                            <input type="text" class="form-control-tally" id="partyName" placeholder="Company or individual name">
                            <div class="field-error" id="error-PartyName"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Party Type</label>
                            <select class="form-control-tally" id="partyType">
                                <option value="Customer">Customer</option>
                                <option value="Supplier">Supplier</option>
                                <option value="Both">Both</option>
                            </select>
                            <div class="field-error" id="error-PartyType"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">GSTIN</label>
                            <input type="text" class="form-control-tally" id="gstin" placeholder="15-char GSTIN" maxlength="15">
                            <div class="field-error" id="error-Gstin"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">PAN Number</label>
                            <input type="text" class="form-control-tally" id="panNumber" placeholder="ABCDE1234F">
                            <div class="field-error" id="error-PanNumber"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Phone</label>
                            <input type="tel" class="form-control-tally" id="phone" placeholder="+91 XXXXX XXXXX">
                            <div class="field-error" id="error-Phone"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control-tally" id="email" placeholder="party@email.com">
                            <div class="field-error" id="error-Email"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-group">
                            <label class="form-label">Address</label>
                            <textarea class="form-control-tally" id="address" rows="2"></textarea>
                            <div class="field-error" id="error-Address"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Credit Limit (₹)</label>
                            <input type="number" class="form-control-tally" id="creditLimit" placeholder="0">
                            <div class="field-error" id="error-CreditLimit"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Credit Period (Days)</label>
                            <input type="number" class="form-control-tally" id="creditPeriod" placeholder="30">
                            <div class="field-error" id="error-CreditPeriod"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <select class="form-control-tally" id="partyStatus">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                                <option value="Blacklisted">Blacklisted</option>
                            </select>
                            <div class="field-error" id="error-Status"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('partyModal')">Cancel</button>
                <button class="btn-tally-primary" id="btnSaveParty" onclick="saveParty()">
                    <i class="bi bi-check-lg"></i> Save Party
                </button>
            </div>
        </div>
    </div>

    <!-- Delete Confirm Modal -->
    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;">
            <div class="del-icon">🗑️</div>
            <h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete Party?</h5>
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone. The record will be permanently removed.</p>
            <div class="d-flex justify-content-center gap-3">
                <button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button>
                <button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()">
                    <i class="bi bi-trash"></i> Yes, Delete
                </button>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <partial name="_Scripts" />

    <script>
        /**
         * @@typedef {Object} PartyState
         * @@property {Array} data - List of parties
         * @@property {number} page - Current page number
         * @@property {number} pageSize - Records per page
         * @@property {number} totalCount - Total number of records
         * @@property {number} totalPages - Total number of pages
         * @@property {string} search - Search query
         * @@property {string} sortColumn - Column to sort by
         * @@property {string} sortDirection - Sort direction (asc/desc)
         * @@property {number|null} editingId - ID of the record being edited
         * @@property {boolean} hasPreviousPage - Whether there is a previous page
         * @@property {boolean} hasNextPage - Whether there is a next page
         */
        let partyState = {
            data: [],
            page: 1,
            pageSize: 10,
            totalCount: 0,
            totalPages: 0,
            search: '',
            sortColumn: 'Id',
            sortDirection: 'asc',
            editingId: null,
            hasPreviousPage: false,
            hasNextPage: false
        };

        let partySearchDebounceTimer;
        let deleteTargetId = null;

        /**
         * Loads parties from the API based on current state.
         * @@returns {Promise<void>}
         */
        async function loadParties() {
            try {
                const params = new URLSearchParams({
                    page: partyState.page,
                    pageSize: partyState.pageSize,
                    search: partyState.search,
                    sortColumn: partyState.sortColumn,
                    sortDirection: partyState.sortDirection
                });

                const response = await fetch(`/PartyDirectory/api/index?${params}`);
                if (!response.ok) throw new Error('Load failed');
                
                const result = await response.json();
                partyState.data = result.data || [];
                partyState.totalCount = result.totalCount || 0;
                partyState.totalPages = result.totalPages || 0;
                partyState.page = result.page || 1;
                partyState.hasPreviousPage = result.hasPreviousPage || false;
                partyState.hasNextPage = result.hasNextPage || false;
                
                renderPartyTable();
                renderPartyPagination();
                updateSortIcons();
            } catch (error) {
                console.error(error);
                showToast('Failed to load parties', 'error');
            }
        }

        /**
         * Renders the party table rows.
         */
        function renderPartyTable() {
            const tbody = document.getElementById('partyTableBody');
            tbody.innerHTML = '';

            if (partyState.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text-muted);">No parties found</td></tr>';
                return;
            }

            partyState.data.forEach(party => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td class="font-weight-bold">${escapeHtml(party.partyName)}</td>
                    <td><span class="badge-tally ${party.partyType === 'Supplier' ? 'badge-danger' : 'badge-success'}">${escapeHtml(party.partyType)}</span></td>
                    <td class="text-mono">${escapeHtml(party.gstin || 'N/A')}</td>
                    <td>${escapeHtml(party.phone || '-')}</td>
                    <td>${escapeHtml(party.email || '-')}</td>
                    <td><span class="badge-tally ${party.status === 'Active' ? 'badge-success' : 'badge-warning'}">${escapeHtml(party.status)}</span></td>
                    <td>
                        <button class="btn-tally-edit" onclick="editParty(${party.id})"><i class="bi bi-pencil"></i></button>
                        <button class="btn-tally-danger" onclick="deleteParty(${party.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(row);
            });

            const start = ((partyState.page - 1) * partyState.pageSize) + 1;
            document.getElementById('partyShowingStart').textContent = partyState.totalCount > 0 ? start : 0;
            document.getElementById('partyShowingEnd').textContent = Math.min(start + partyState.pageSize - 1, partyState.totalCount);
            document.getElementById('partyTotalRecords').textContent = partyState.totalCount;
        }

        /**
         * Renders the pagination controls for party table.
         */
        function renderPartyPagination() {
            const pageNumbersEl = document.getElementById('partyPageNumbers');
            pageNumbersEl.innerHTML = '';

            const maxButtons = 5;
            let startPage = Math.max(1, partyState.page - Math.floor(maxButtons / 2));
            let endPage = Math.min(partyState.totalPages, startPage + maxButtons - 1);
            if (endPage - startPage < maxButtons - 1) {
                startPage = Math.max(1, endPage - maxButtons + 1);
            }

            for (let i = startPage; i <= endPage; i++) {
                const btn = document.createElement('button');
                btn.className = `btn-tally-outline ${i === partyState.page ? 'active' : ''}`;
                btn.style.cssText = 'padding:6px 10px;min-width:36px;';
                btn.textContent = i;
                btn.onclick = () => goToPartyPage(i);
                pageNumbersEl.appendChild(btn);
            }

            document.getElementById('partyPrevBtn').disabled = !partyState.hasPreviousPage;
            document.getElementById('partyNextBtn').disabled = !partyState.hasNextPage;
            document.getElementById('partyPageSizeSelect').value = partyState.pageSize;
        }

        /**
         * Navigates to a specific page.
         * @@param {number} page - Page number
         */
        function goToPartyPage(page) {
            if (page < 1 || page > partyState.totalPages) return;
            partyState.page = page;
            loadParties();
        }

        /**
         * Navigates to the previous page.
         */
        function prevPartyPage() {
            if (partyState.hasPreviousPage) goToPartyPage(partyState.page - 1);
        }

        /**
         * Navigates to the next page.
         */
        function nextPartyPage() {
            if (partyState.hasNextPage) goToPartyPage(partyState.page + 1);
        }

        /**
         * Changes the page size and reloads data.
         */
        function changePartyPageSize() {
            const select = document.getElementById('partyPageSizeSelect');
            partyState.pageSize = parseInt(select.value);
            partyState.page = 1;
            loadParties();
        }

        /**
         * Handles the party table sorting.
         * @@param {string} column - Column to sort by
         */
        function sortBy(column) {
            if (partyState.sortColumn === column) {
                partyState.sortDirection = partyState.sortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                partyState.sortColumn = column;
                partyState.sortDirection = 'asc';
            }
            partyState.page = 1;
            loadParties();
        }

        /**
         * Updates sort icons in the table header.
         */
        function updateSortIcons() {
            document.querySelectorAll('th[onclick^="sortBy"]').forEach(th => {
                const icon = th.querySelector('i');
                if (icon) {
                    const colMatch = th.getAttribute('onclick').match(/'([^']+)'/);
                    if (colMatch) {
                        const col = colMatch[1];
                        if (col === partyState.sortColumn) {
                            icon.className = `bi bi-sort-${partyState.sortDirection === 'asc' ? 'down' : 'up'} ms-1`;
                            icon.style.color = 'var(--primary)';
                        } else {
                            icon.className = 'bi bi-arrow-down-up ms-1';
                            icon.style.color = 'var(--text-muted)';
                        }
                    }
                }
            });
        }

        /**
         * Opens a modal for adding or editing a party.
         * @@param {string} modalId - ID of the modal to open
         * @@param {Object|null} data - Data to populate the modal with
         */
        function openModal(modalId, data = null) {
            const overlay = document.getElementById(modalId);
            if (!overlay) return;

            if (modalId === 'partyModal') {
                resetPartyForm();
                if (data) {
                    partyState.editingId = data.id;
                    document.querySelector('#partyModal .modal-title').textContent = 'Edit Party';
                    document.getElementById('btnSaveParty').innerHTML = '<i class="bi bi-check-lg"></i> Update Party';
                    
                    document.getElementById('partyId').value = data.id;
                    document.getElementById('partyName').value = data.partyName;
                    document.getElementById('partyType').value = data.partyType;
                    document.getElementById('gstin').value = data.gstin || '';
                    document.getElementById('panNumber').value = data.panNumber || '';
                    document.getElementById('phone').value = data.phone || '';
                    document.getElementById('email').value = data.email || '';
                    document.getElementById('address').value = data.address || '';
                    document.getElementById('creditLimit').value = data.creditLimit;
                    document.getElementById('creditPeriod').value = data.creditPeriod;
                    document.getElementById('partyStatus').value = data.status;
                } else {
                    partyState.editingId = null;
                    document.querySelector('#partyModal .modal-title').textContent = 'Add Party';
                    document.getElementById('btnSaveParty').innerHTML = '<i class="bi bi-check-lg"></i> Save Party';
                }
            }
            overlay.classList.add('open');
        }

        /**
         * Closes a modal.
         * @@param {string} modalId - ID of the modal to close
         */
        function closeModal(modalId) {
            document.getElementById(modalId)?.classList.remove('open');
        }

        /**
         * Resets the party form fields.
         */
        function resetPartyForm() {
            document.getElementById('partyId').value = '';
            document.getElementById('partyName').value = '';
            document.getElementById('partyType').value = 'Customer';
            document.getElementById('gstin').value = '';
            document.getElementById('panNumber').value = '';
            document.getElementById('phone').value = '';
            document.getElementById('email').value = '';
            document.getElementById('address').value = '';
            document.getElementById('creditLimit').value = '';
            document.getElementById('creditPeriod').value = '';
            document.getElementById('partyStatus').value = 'Active';
            document.querySelectorAll('.field-error').forEach(el => el.textContent = '');
        }

        /**
         * Saves (creates or updates) a party record.
         * @@returns {Promise<void>}
         */
        async function saveParty() {
            // Clear previous errors
            document.querySelectorAll('.field-error').forEach(el => { el.textContent = ''; el.style.display = 'none'; });

            const formData = {
                partyName: document.getElementById('partyName').value.trim(),
                partyType: document.getElementById('partyType').value,
                gstin: document.getElementById('gstin').value.trim(),
                panNumber: document.getElementById('panNumber').value.trim(),
                phone: document.getElementById('phone').value.trim(),
                email: document.getElementById('email').value.trim(),
                address: document.getElementById('address').value.trim(),
                creditLimit: parseFloat(document.getElementById('creditLimit').value) || 0,
                creditPeriod: parseInt(document.getElementById('creditPeriod').value) || 0,
                status: document.getElementById('partyStatus').value
            };


            try {

                const url = partyState.editingId ? `/PartyDirectory/update/${partyState.editingId}` : `/PartyDirectory/create`;
                const method = partyState.editingId ? 'PUT' : 'POST';

                const response = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();
                if (!response.ok) {
                    if (result.errors) {
                        for (const [f, m] of Object.entries(result.errors)) showFieldError(f, m.join(', '));
                        return;
                    }
                    throw new Error(result.message || 'Save failed');
                }

                closeModal('partyModal');
                showToast('Party saved!', 'success');
                loadParties();
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        /**
         * Prepares a party for editing.
         * @@param {number} id - Party ID
         */
        function editParty(id) {
            const party = partyState.data.find(p => p.id === id);
            if (party) openModal('partyModal', party);
        }

        /**
         * Opens delete confirmation.
         * @@param {number} id - Party ID
         */
        function deleteParty(id) {
            deleteTargetId = id;
            openModal('deleteModal');
        }

        /**
         * Confirms deletion.
         */
        async function confirmDelete() {
            if (!deleteTargetId) return;
            try {
                const response = await fetch(`/PartyDirectory/delete/${deleteTargetId}`, { method: 'DELETE' });
                if (!response.ok) throw new Error('Delete failed');
                closeModal('deleteModal');
                showToast('Party deleted', 'success');
                loadParties();
            } catch (error) {
                showToast('Error deleting party', 'error');
            } finally {
                deleteTargetId = null;
            }
        }

        /**
         * Handles the party search input event with debouncing.
         * @@param {Event} e - Input event
         */
        function handlePartySearch(e) {
            clearTimeout(partySearchDebounceTimer);
            const q = e.target.value.trim();
            partySearchDebounceTimer = setTimeout(() => {
                partyState.search = q;
                partyState.page = 1;
                loadParties();
            }, 500);
        }

        /**
         * Switches between tabs.
         * @@param {HTMLElement} btn - Tab button
         * @@param {string} contentId - Content element ID
         */
        function switchTab(btn, contentId) {
            const tabs = btn.closest('.tally-tabs');
            tabs.querySelectorAll('.tally-tab').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');

            const page = btn.closest('.page');
            page.querySelectorAll('[id^="tab-"]').forEach(c => c.style.display = 'none');
            const target = document.getElementById(contentId);
            if (target) target.style.display = 'block';

            if (contentId === 'tab-parties') loadParties();
        }

        /**
         * Displays a field error.
         * @@param {string} field - Field name
         * @@param {string} msg - Error message
         */
        function showFieldError(field, msg) {
            const el = document.getElementById(`error-${field}`);
            if (el) { el.textContent = msg; el.style.display = 'block'; }
        }

        /**
         * Escapes HTML.
         * @@param {string} text - Text to escape
         * @@returns {string} Escaped text
         */
        function escapeHtml(text) {
            if (!text) return '';
            const d = document.createElement('div');
            d.textContent = text;
            return d.innerHTML;
        }

        /**
         * Displays a toast notification.
         * @@param {string} message - Message
         * @@param {string} [type='success'] - Toast type
         */
        function showToast(message, type = 'success') {
            const icons = { success: '✅', error: '❌', info: 'ℹ️' };
            const container = document.getElementById('toastContainer');
            if(!container) return;
            const toast = document.createElement('div');
            toast.className = `tally-toast ${type}`;
            toast.innerHTML = `<span style="font-size:16px">${icons[type]}</span><span>${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                toast.style.transition = '0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadParties();
            
            // Set today's date in date inputs
            const today = new Date().toISOString().split('T')[0];
            document.querySelectorAll('input[type=date]').forEach(input => { if (!input.value) input.value = today; });
            
            // Close modals on overlay click
            document.querySelectorAll('.tally-modal-overlay').forEach(overlay => {
                overlay.addEventListener('click', function(e) {
                    if (e.target === this) closeModal(this.id);
                });
            });
        });
    </script>
</body>

</html>
