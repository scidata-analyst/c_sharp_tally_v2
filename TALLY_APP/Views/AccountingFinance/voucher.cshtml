@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Voucher Entry</title>
    <partial name="_Styles" />
</head>

<body>

    <partial name="_Sidebar" />

    <partial name="_Header" model='@("Voucher Entry")' />

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== VOUCHER ENTRY ===================== -->
        <div class="page active" id="page-voucher">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Voucher Entry</div>
                    <div class="page-subtitle">Create payment, receipt, contra and journal vouchers</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('voucherModal')">
                    <i class="bi bi-plus-lg"></i> New Voucher
                </button>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--danger)">
                        <div class="stat-label">Payment Vouchers</div>
                        <div class="stat-value">142</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--primary)">
                        <div class="stat-label">Receipt Vouchers</div>
                        <div class="stat-value">98</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--accent2)">
                        <div class="stat-label">Journal Vouchers</div>
                        <div class="stat-value">56</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--accent)">
                        <div class="stat-label">Contra Vouchers</div>
                        <div class="stat-value">23</div>
                    </div>
                </div>
            </div>

            <!-- Voucher Type Quick Select -->
            <div class="tally-card mb-4">
                <div class="card-label mb-3">Quick Filter by Type</div>
                <div class="voucher-type-grid">
                    <button class="voucher-type-btn active" onclick="filterVoucherType(this,'')">
                        <span class="v-icon">📄</span>All
                    </button>
                    <button class="voucher-type-btn" onclick="filterVoucherType(this,'Payment')">
                        <span class="v-icon">💸</span>Payment
                    </button>
                    <button class="voucher-type-btn" onclick="filterVoucherType(this,'Receipt')">
                        <span class="v-icon">💵</span>Receipt
                    </button>
                    <button class="voucher-type-btn" onclick="filterVoucherType(this,'Journal')">
                        <span class="v-icon">📓</span>Journal
                    </button>
                    <button class="voucher-type-btn" onclick="filterVoucherType(this,'Contra')">
                        <span class="v-icon">🔄</span>Contra
                    </button>
                </div>
            </div>

            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Recent Vouchers</div>
                    <div class="table-actions">
                        <input type="text" class="table-search" placeholder="Search vouchers..." oninput="handleVoucherSearch(event)">
                        <button class="btn-tally-outline" onclick="loadVouchers()"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
                    </div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('VoucherNumber')" style="cursor:pointer;">
                                Voucher No. <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('VoucherType')" style="cursor:pointer;">
                                Type <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('VoucherDate')" style="cursor:pointer;">
                                Date <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th>Party / Account</th>
                            <th>Narration</th>
                            <th onclick="sortBy('Amount')" style="cursor:pointer;">
                                Amount <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">
                                Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="voucherTableBody">
                        <!-- Loaded via API -->
                    </tbody>
                </table>

                <!-- Pagination Controls -->
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">
                        Showing <span id="voucherShowingStart">0</span> to <span id="voucherShowingEnd">0</span> of <span id="voucherTotalRecords">0</span> records
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows per page:</label>
                        <select id="voucherPageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changeVoucherPageSize()">
                            <option value="5">5</option>
                            <option value="10" selected>10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="voucherPrevBtn" style="padding:6px 12px;" onclick="prevVoucherPage()">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <span id="voucherPageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="voucherNextBtn" style="padding:6px 12px;" onclick="nextVoucherPage()">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- ===================== MODALS ===================== -->

    <!-- Voucher Modal -->
    <div class="tally-modal-overlay" id="voucherModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Create Voucher</div>
                <div class="modal-close" onclick="closeModal('voucherModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <input type="hidden" id="voucherId">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Voucher Number *</label>
                            <input type="text" class="form-control-tally" id="voucherNumber" placeholder="PV-2024-001">
                            <div class="field-error" id="error-VoucherNumber"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Voucher Type *</label>
                            <select class="form-control-tally" id="voucherType">
                                <option value="Payment">Payment</option>
                                <option value="Receipt">Receipt</option>
                                <option value="Journal">Journal</option>
                                <option value="Contra">Contra</option>
                            </select>
                            <div class="field-error" id="error-VoucherType"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Voucher Date *</label>
                            <input type="date" class="form-control-tally" id="voucherDate">
                            <div class="field-error" id="error-VoucherDate"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Party ID</label>
                            <input type="number" class="form-control-tally" id="partyId" placeholder="Party ID">
                            <div class="field-error" id="error-PartyId"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Amount *</label>
                            <input type="number" class="form-control-tally" id="amount" placeholder="0.00" step="0.01">
                            <div class="field-error" id="error-Amount"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Payment Mode</label>
                            <select class="form-control-tally" id="paymentMode">
                                <option value="Cash">Cash</option>
                                <option value="Bank Transfer">Bank Transfer</option>
                                <option value="Cheque">Cheque</option>
                                <option value="UPI">UPI</option>
                                <option value="NEFT/RTGS">NEFT/RTGS</option>
                            </select>
                            <div class="field-error" id="error-PaymentMode"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Bank Account ID</label>
                            <input type="number" class="form-control-tally" id="bankAccountId" placeholder="Bank Account ID">
                            <div class="field-error" id="error-BankAccountId"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Reference No.</label>
                            <input type="text" class="form-control-tally" id="referenceNumber" placeholder="Cheque / UTR / Ref No.">
                            <div class="field-error" id="error-ReferenceNumber"></div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-group">
                            <label class="form-label">Narration</label>
                            <textarea class="form-control-tally" id="narration" rows="2" placeholder="Brief description of this voucher..."></textarea>
                            <div class="field-error" id="error-Narration"></div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <select class="form-control-tally" id="voucherStatus">
                                <option value="Posted">Posted</option>
                                <option value="Draft">Draft</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                            <div class="field-error" id="error-Status"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('voucherModal')">Cancel</button>
                <button class="btn-tally-primary" id="btnSaveVoucher" onclick="saveVoucher()">
                    <i class="bi bi-check-lg"></i> Save Voucher
                </button>
            </div>
        </div>
    </div>

    <!-- Delete Confirm Modal -->
    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;">
            <div class="del-icon">🗑️</div>
            <h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete Voucher?</h5>
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone. The record will be permanently removed.</p>
            <div class="d-flex justify-content-center gap-3">
                <button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button>
                <button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()">
                    <i class="bi bi-trash"></i> Yes, Delete
                </button>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <partial name="_Scripts" />

    <script>
        /**
         * @@typedef {Object} VoucherState
         * @@property {Array} data - List of vouchers
         * @@property {number} page - Current page number
         * @@property {number} pageSize - Records per page
         * @@property {number} totalCount - Total number of records
         * @@property {number} totalPages - Total number of pages
         * @@property {string} search - Search query
         * @@property {string} sortColumn - Column to sort by
         * @@property {string} sortDirection - Sort direction (asc/desc)
         * @@property {number|null} editingId - ID of the record being edited
         * @@property {boolean} hasPreviousPage - Whether there is a previous page
         * @@property {boolean} hasNextPage - Whether there is a next page
         */
        let voucherState = {
            data: [],
            page: 1,
            pageSize: 10,
            totalCount: 0,
            totalPages: 0,
            search: '',
            sortColumn: 'Id',
            sortDirection: 'desc',
            editingId: null,
            hasPreviousPage: false,
            hasNextPage: false
        };

        let voucherSearchDebounceTimer;
        let deleteTargetId = null;

        /**
         * Loads vouchers from the API based on current state.
         * @@returns {Promise<void>}
         */
        async function loadVouchers() {
            try {
                const params = new URLSearchParams({
                    page: voucherState.page,
                    pageSize: voucherState.pageSize,
                    search: voucherState.search,
                    sortColumn: voucherState.sortColumn,
                    sortDirection: voucherState.sortDirection
                });

                const response = await fetch(`/VoucherEntry/api/index?${params}`);
                if (!response.ok) throw new Error('Load failed');
                
                const result = await response.json();
                voucherState.data = result.data || [];
                voucherState.totalCount = result.totalCount || 0;
                voucherState.totalPages = result.totalPages || 0;
                voucherState.page = result.page || 1;
                voucherState.hasPreviousPage = result.hasPreviousPage || false;
                voucherState.hasNextPage = result.hasNextPage || false;
                
                renderVoucherTable();
                renderVoucherPagination();
                updateSortIcons();
            } catch (error) {
                console.error(error);
                showToast('Failed to load vouchers', 'error');
            }
        }

        /**
         * Renders the voucher table rows.
         */
        function renderVoucherTable() {
            const tbody = document.getElementById('voucherTableBody');
            tbody.innerHTML = '';

            if (voucherState.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text-muted);">No vouchers found</td></tr>';
                return;
            }

            voucherState.data.forEach(voucher => {
                const row = document.createElement('tr');
                
                let typeBadge = '';
                switch(voucher.voucherType) {
                    case 'Payment': typeBadge = '<span class="badge-tally badge-danger">Payment</span>'; break;
                    case 'Receipt': typeBadge = '<span class="badge-tally badge-success">Receipt</span>'; break;
                    case 'Journal': typeBadge = '<span class="badge-tally badge-accent">Journal</span>'; break;
                    case 'Contra': typeBadge = '<span class="badge-tally badge-info">Contra</span>'; break;
                    default: typeBadge = `<span class="badge-tally">${escapeHtml(voucher.voucherType)}</span>`;
                }

                let statusBadge = '';
                switch(voucher.status) {
                    case 'Posted': statusBadge = '<span class="badge-tally badge-success">Posted</span>'; break;
                    case 'Draft': statusBadge = '<span class="badge-tally badge-warning">Draft</span>'; break;
                    case 'Cancelled': statusBadge = '<span class="badge-tally badge-danger">Cancelled</span>'; break;
                    default: statusBadge = `<span class="badge-tally">${escapeHtml(voucher.status)}</span>`;
                }

                const amountClass = voucher.voucherType === 'Payment' ? 'amount-negative' : (voucher.voucherType === 'Receipt' ? 'amount-positive' : 'amount-neutral');
                const date = new Date(voucher.voucherDate).toLocaleDateString('en-IN');

                row.innerHTML = `
                    <td class="text-mono font-weight-bold">${escapeHtml(voucher.voucherNumber)}</td>
                    <td>${typeBadge}</td>
                    <td class="text-mono">${date}</td>
                    <td>${voucher.partyId ? 'Party #' + voucher.partyId : '<span class="text-muted">N/A</span>'}</td>
                    <td class="text-truncate" style="max-width: 200px;" title="${escapeHtml(voucher.narration)}">${escapeHtml(voucher.narration)}</td>
                    <td class="${amountClass}">₹${formatNumber(voucher.amount)}</td>
                    <td>${statusBadge}</td>
                    <td>
                        <button class="btn-tally-edit" onclick="editVoucher(${voucher.id})"><i class="bi bi-pencil"></i></button>
                        <button class="btn-tally-danger" onclick="deleteVoucher(${voucher.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(row);
            });

            const start = ((voucherState.page - 1) * voucherState.pageSize) + 1;
            document.getElementById('voucherShowingStart').textContent = voucherState.totalCount > 0 ? start : 0;
            document.getElementById('voucherShowingEnd').textContent = Math.min(start + voucherState.pageSize - 1, voucherState.totalCount);
            document.getElementById('voucherTotalRecords').textContent = voucherState.totalCount;
        }

        /**
         * Renders the pagination controls for voucher table.
         */
        function renderVoucherPagination() {
            const pageNumbersEl = document.getElementById('voucherPageNumbers');
            pageNumbersEl.innerHTML = '';

            const maxButtons = 5;
            let startPage = Math.max(1, voucherState.page - Math.floor(maxButtons / 2));
            let endPage = Math.min(voucherState.totalPages, startPage + maxButtons - 1);
            if (endPage - startPage < maxButtons - 1) {
                startPage = Math.max(1, endPage - maxButtons + 1);
            }

            for (let i = startPage; i <= endPage; i++) {
                const btn = document.createElement('button');
                btn.className = `btn-tally-outline ${i === voucherState.page ? 'active' : ''}`;
                btn.style.cssText = 'padding:6px 10px;min-width:36px;';
                btn.textContent = i;
                btn.onclick = () => goToVoucherPage(i);
                pageNumbersEl.appendChild(btn);
            }

            document.getElementById('voucherPrevBtn').disabled = !voucherState.hasPreviousPage;
            document.getElementById('voucherNextBtn').disabled = !voucherState.hasNextPage;
            document.getElementById('voucherPageSizeSelect').value = voucherState.pageSize;
        }

        /**
         * Navigates to a specific page.
         * @@param {number} page - Page number
         */
        function goToVoucherPage(page) {
            if (page < 1 || page > voucherState.totalPages) return;
            voucherState.page = page;
            loadVouchers();
        }

        /**
         * Navigates to the previous page.
         */
        function prevVoucherPage() {
            if (voucherState.hasPreviousPage) goToVoucherPage(voucherState.page - 1);
        }

        /**
         * Navigates to the next page.
         */
        function nextVoucherPage() {
            if (voucherState.hasNextPage) goToVoucherPage(voucherState.page + 1);
        }

        /**
         * Changes the page size and reloads data.
         */
        function changeVoucherPageSize() {
            const select = document.getElementById('voucherPageSizeSelect');
            voucherState.pageSize = parseInt(select.value);
            voucherState.page = 1;
            loadVouchers();
        }

        /**
         * Handles the voucher table sorting.
         * @@param {string} column - Column to sort by
         */
        function sortBy(column) {
            if (voucherState.sortColumn === column) {
                voucherState.sortDirection = voucherState.sortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                voucherState.sortColumn = column;
                voucherState.sortDirection = 'asc';
            }
            voucherState.page = 1;
            loadVouchers();
        }

        /**
         * Updates sort icons in the table header.
         */
        function updateSortIcons() {
            document.querySelectorAll('th[onclick^="sortBy"]').forEach(th => {
                const icon = th.querySelector('i');
                if (icon) {
                    const colMatch = th.getAttribute('onclick').match(/'([^']+)'/);
                    if (colMatch) {
                        const col = colMatch[1];
                        if (col === voucherState.sortColumn) {
                            icon.className = `bi bi-sort-${voucherState.sortDirection === 'asc' ? 'down' : 'up'} ms-1`;
                            icon.style.color = 'var(--primary)';
                        } else {
                            icon.className = 'bi bi-arrow-down-up ms-1';
                            icon.style.color = 'var(--text-muted)';
                        }
                    }
                }
            });
        }

        /**
         * Opens a modal for adding or editing a voucher.
         * @@param {string} modalId - ID of the modal to open
         * @@param {Object|null} data - Data to populate the modal with
         */
        function openModal(modalId, data = null) {
            const overlay = document.getElementById(modalId);
            if (!overlay) return;

            if (modalId === 'voucherModal') {
                resetVoucherForm();
                if (data) {
                    voucherState.editingId = data.id;
                    document.querySelector('#voucherModal .modal-title').textContent = 'Edit Voucher';
                    document.getElementById('btnSaveVoucher').innerHTML = '<i class="bi bi-check-lg"></i> Update Voucher';
                    
                    document.getElementById('voucherId').value = data.id;
                    document.getElementById('voucherNumber').value = data.voucherNumber;
                    document.getElementById('voucherType').value = data.voucherType;
                    document.getElementById('voucherDate').value = data.voucherDate.split('T')[0];
                    document.getElementById('partyId').value = data.partyId || '';
                    document.getElementById('amount').value = data.amount;
                    document.getElementById('paymentMode').value = data.paymentMode;
                    document.getElementById('bankAccountId').value = data.bankAccountId || '';
                    document.getElementById('referenceNumber').value = data.referenceNumber || '';
                    document.getElementById('narration').value = data.narration || '';
                    document.getElementById('voucherStatus').value = data.status;
                } else {
                    voucherState.editingId = null;
                    document.querySelector('#voucherModal .modal-title').textContent = 'Create Voucher';
                    document.getElementById('btnSaveVoucher').innerHTML = '<i class="bi bi-check-lg"></i> Post Voucher';
                }
            }
            overlay.classList.add('open');
        }

        /**
         * Closes a modal.
         * @@param {string} modalId - ID of the modal to close
         */
        function closeModal(modalId) {
            document.getElementById(modalId)?.classList.remove('open');
        }

        /**
         * Resets the voucher form fields.
         */
        function resetVoucherForm() {
            document.getElementById('voucherId').value = '';
            document.getElementById('voucherNumber').value = '';
            document.getElementById('voucherType').value = 'Payment';
            document.getElementById('voucherDate').value = new Date().toISOString().split('T')[0];
            document.getElementById('partyId').value = '';
            document.getElementById('amount').value = '';
            document.getElementById('paymentMode').value = 'Cash';
            document.getElementById('bankAccountId').value = '';
            document.getElementById('referenceNumber').value = '';
            document.getElementById('narration').value = '';
            document.getElementById('voucherStatus').value = 'Posted';
            document.querySelectorAll('.field-error').forEach(el => el.textContent = '');
        }

        /**
         * Saves (creates or updates) a voucher record.
         * @@returns {Promise<void>}
         */
        async function saveVoucher() {
            // Clear previous errors
            document.querySelectorAll('.field-error').forEach(el => { el.textContent = ''; el.style.display = 'none'; });

            const formData = {
                voucherNumber: document.getElementById('voucherNumber').value.trim(),
                voucherType: document.getElementById('voucherType').value,
                voucherDate: document.getElementById('voucherDate').value,
                partyId: document.getElementById('partyId').value ? parseInt(document.getElementById('partyId').value) : null,
                amount: parseFloat(document.getElementById('amount').value) || 0,
                paymentMode: document.getElementById('paymentMode').value,
                bankAccountId: document.getElementById('bankAccountId').value ? parseInt(document.getElementById('bankAccountId').value) : null,
                referenceNumber: document.getElementById('referenceNumber').value.trim(),
                narration: document.getElementById('narration').value.trim(),
                status: document.getElementById('voucherStatus').value
            };

            let hasError = false;
            if (!formData.voucherNumber) { showFieldError('VoucherNumber', 'Required'); hasError = true; }
            if (!formData.voucherDate) { showFieldError('VoucherDate', 'Required'); hasError = true; }
            if (formData.amount <= 0) { showFieldError('Amount', 'Must be greater than 0'); hasError = true; }
            
            if (hasError) return;

            try {
                const url = voucherState.editingId ? `/VoucherEntry/update/${voucherState.editingId}` : `/VoucherEntry/create`;
                const method = voucherState.editingId ? 'PUT' : 'POST';

                const response = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();
                if (!response.ok) {
                    if (result.errors) {
                        for (const [f, m] of Object.entries(result.errors)) showFieldError(f, m.join(', '));
                        return;
                    }
                    throw new Error(result.message || 'Save failed');
                }

                closeModal('voucherModal');
                showToast(voucherState.editingId ? 'Voucher updated!' : 'Voucher posted!', 'success');
                loadVouchers();
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        /**
         * Prepares a voucher for editing.
         * @@param {number} id - Voucher ID
         */
        function editVoucher(id) {
            const voucher = voucherState.data.find(v => v.id === id);
            if (voucher) openModal('voucherModal', voucher);
        }

        /**
         * Opens delete confirmation.
         * @@param {number} id - Voucher ID
         */
        function deleteVoucher(id) {
            deleteTargetId = id;
            openModal('deleteModal');
        }

        /**
         * Confirms deletion.
         */
        async function confirmDelete() {
            if (!deleteTargetId) return;
            try {
                const response = await fetch(`/VoucherEntry/delete/${deleteTargetId}`, { method: 'DELETE' });
                if (!response.ok) throw new Error('Delete failed');
                closeModal('deleteModal');
                showToast('Voucher deleted', 'success');
                loadVouchers();
            } catch (error) {
                showToast('Error deleting voucher', 'error');
            } finally {
                deleteTargetId = null;
            }
        }

        /**
         * Handles the voucher search input event with debouncing.
         * @@param {Event} e - Input event
         */
        function handleVoucherSearch(e) {
            clearTimeout(voucherSearchDebounceTimer);
            const q = e.target.value.trim();
            voucherSearchDebounceTimer = setTimeout(() => {
                voucherState.search = q;
                voucherState.page = 1;
                loadVouchers();
            }, 500);
        }

        /**
         * Filters vouchers by type.
         * @@param {HTMLElement} btn - Button element
         * @@param {string} type - Voucher type
         */
        function filterVoucherType(btn, type) {
            document.querySelectorAll('.voucher-type-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            voucherState.search = type;
            voucherState.page = 1;
            loadVouchers();
        }

        /**
         * Displays a field error.
         * @@param {string} field - Field name
         * @@param {string} msg - Error message
         */
        function showFieldError(field, msg) {
            const el = document.getElementById(`error-${field}`);
            if (el) { el.textContent = msg; el.style.display = 'block'; }
        }

        /**
         * Escapes HTML.
         * @@param {string} text - Text to escape
         * @@returns {string} Escaped text
         */
        function escapeHtml(text) {
            if (!text) return '';
            const d = document.createElement('div');
            d.textContent = text;
            return d.innerHTML;
        }

        /**
         * Formats a number to Indian locale.
         * @@param {number} num - Number to format
         * @@returns {string} Formatted number
         */
        function formatNumber(num) {
            if (num === null || num === undefined) return '0.00';
            return parseFloat(num).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        /**
         * Displays a toast notification.
         * @@param {string} message - Message
         * @@param {string} [type='success'] - Toast type
         */
        function showToast(message, type = 'success') {
            const icons = { success: '✅', error: '❌', info: 'ℹ️' };
            const container = document.getElementById('toastContainer');
            if(!container) return;
            const toast = document.createElement('div');
            toast.className = `tally-toast ${type}`;
            toast.innerHTML = `<span style="font-size:16px">${icons[type]}</span><span>${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                toast.style.transition = '0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadVouchers();
            
            // Close modals on overlay click
            document.querySelectorAll('.tally-modal-overlay').forEach(overlay => {
                overlay.addEventListener('click', function(e) {
                    if (e.target === this) closeModal(this.id);
                });
            });
        });
    </script>
</body>

</html>
