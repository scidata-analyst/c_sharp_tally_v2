@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Bank Reconciliation</title>
    <partial name="_Styles" />
</head>

<body>

    <partial name="_Sidebar" />

    <partial name="_Header" model='@("Bank Reconciliation")' />

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== BANK RECONCILIATION ===================== -->
        <div class="page active" id="page-bank-recon">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Bank Reconciliation</div>
                    <div class="page-subtitle">Match bank statements with book entries</div>
                </div>
                <button class="btn-tally-primary"><i class="bi bi-arrow-left-right"></i> Start Reconciliation</button>
            </div>
            <div class="row g-3 mb-4" id="reconSummaryCards">
                <!-- Loaded via API -->
            </div>

            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Reconciliation History</div>
                    <div class="table-actions">
                        <input class="table-search" placeholder="Search sessions..." oninput="handleReconSearch(event)">
                    </div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('StatementDate')" style="cursor:pointer;">
                                Date <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th>Bank Account</th>
                            <th onclick="sortBy('BankBalance')" style="cursor:pointer;">
                                Bank Balance <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('BookBalance')" style="cursor:pointer;">
                                Book Balance <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('UnreconciledAmount')" style="cursor:pointer;">
                                Difference <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">
                                Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="reconTableBody">
                        <!-- Loaded via API -->
                    </tbody>
                </table>

                <!-- Pagination Controls -->
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">
                        Showing <span id="reconShowingStart">0</span> to <span id="reconShowingEnd">0</span> of <span id="reconTotalRecords">0</span> records
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows per page:</label>
                        <select id="reconPageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changeReconPageSize()">
                            <option value="5">5</option>
                            <option value="10" selected>10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="reconPrevBtn" style="padding:6px 12px;" onclick="prevReconPage()">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <span id="reconPageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="reconNextBtn" style="padding:6px 12px;" onclick="nextReconPage()">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- Generic Modal (used for view/delete) -->
    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;">
            <div class="del-icon">🗑️</div>
            <h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete Session?</h5>
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone. The reconciliation record will be permanently removed.</p>
            <div class="d-flex justify-content-center gap-3">
                <button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button>
                <button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()">
                    <i class="bi bi-trash"></i> Yes, Delete
                </button>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <partial name="_Scripts" />

    <script>
        /**
         * @@typedef {Object} ReconState
         * @@property {Array} data - List of reconciliation sessions
         * @@property {number} page - Current page number
         * @@property {number} pageSize - Records per page
         * @@property {number} totalCount - Total number of records
         * @@property {number} totalPages - Total number of pages
         * @@property {string} search - Search query
         * @@property {string} sortColumn - Column to sort by
         * @@property {string} sortDirection - Sort direction (asc/desc)
         * @@property {boolean} hasPreviousPage - Whether there is a previous page
         * @@property {boolean} hasNextPage - Whether there is a next page
         */
        let reconState = {
            data: [],
            page: 1,
            pageSize: 10,
            totalCount: 0,
            totalPages: 0,
            search: '',
            sortColumn: 'Id',
            sortDirection: 'asc',
            hasPreviousPage: false,
            hasNextPage: false
        };

        let reconSearchDebounceTimer;
        let deleteTargetId = null;

        /**
         * Loads reconciliations from the API based on current state.
         * @@returns {Promise<void>}
         */
        async function loadReconciliations() {
            try {
                const params = new URLSearchParams({
                    page: reconState.page,
                    pageSize: reconState.pageSize,
                    search: reconState.search,
                    sortColumn: reconState.sortColumn,
                    sortDirection: reconState.sortDirection
                });

                const response = await fetch(`/BankReconciliation/api/index?${params}`);
                if (!response.ok) throw new Error('Load failed');
                
                const result = await response.json();
                reconState.data = result.data || [];
                reconState.totalCount = result.totalCount || 0;
                reconState.totalPages = result.totalPages || 0;
                reconState.page = result.page || 1;
                reconState.hasPreviousPage = result.hasPreviousPage || false;
                reconState.hasNextPage = result.hasNextPage || false;
                
                renderReconTable();
                renderReconSummary();
                renderPagination();
                updateSortIcons();
            } catch (error) {
                console.error(error);
                showToast('Failed to load reconciliations', 'error');
            }
        }

        /**
         * Renders the reconciliation table rows.
         */
        function renderReconTable() {
            const tbody = document.getElementById('reconTableBody');
            tbody.innerHTML = '';

            if (reconState.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text-muted);">No records found</td></tr>';
                return;
            }

            reconState.data.forEach(item => {
                const row = document.createElement('tr');
                const diff = item.bankBalance - item.bookBalance;
                row.innerHTML = `
                    <td>${new Date(item.statementDate).toLocaleDateString('en-IN')}</td>
                    <td>${escapeHtml(item.bankAccountName || 'N/A')}</td>
                    <td class="font-weight-bold">₹${item.bankBalance.toLocaleString('en-IN')}</td>
                    <td class="font-weight-bold">₹${item.bookBalance.toLocaleString('en-IN')}</td>
                    <td class="${diff === 0 ? 'text-success' : 'text-danger'} font-weight-bold">₹${item.unreconciledAmount.toLocaleString('en-IN')}</td>
                    <td><span class="badge-tally ${item.status === 'Reconciled' ? 'badge-success' : 'badge-warning'}">${escapeHtml(item.status)}</span></td>
                    <td>
                        <button class="btn-tally-edit" onclick="viewRecon(${item.id})"><i class="bi bi-eye"></i></button>
                        <button class="btn-tally-danger" onclick="deleteRecon(${item.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(row);
            });

            const start = ((reconState.page - 1) * reconState.pageSize) + 1;
            document.getElementById('reconShowingStart').textContent = reconState.totalCount > 0 ? start : 0;
            document.getElementById('reconShowingEnd').textContent = Math.min(start + reconState.pageSize - 1, reconState.totalCount);
            document.getElementById('reconTotalRecords').textContent = reconState.totalCount;
        }

        /**
         * Renders the summary cards at the top.
         */
        function renderReconSummary() {
            const container = document.getElementById('reconSummaryCards');
            if (reconState.data.length === 0) {
                container.innerHTML = '<div class="col-12 text-center py-4 text-muted">No reconciliation data found</div>';
                return;
            }

            const latest = reconState.data[0];
            container.innerHTML = `
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--primary)">
                        <div class="stat-label">Bank Balance</div>
                        <div class="stat-value">₹${latest.bankBalance.toLocaleString('en-IN')}</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--accent2)">
                        <div class="stat-label">Book Balance</div>
                        <div class="stat-value">₹${latest.bookBalance.toLocaleString('en-IN')}</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:${latest.unreconciledAmount === 0 ? 'var(--success)' : 'var(--danger)'}">
                        <div class="stat-label">Unreconciled</div>
                        <div class="stat-value">₹${latest.unreconciledAmount.toLocaleString('en-IN')}</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--warning)">
                        <div class="stat-label">Pending Items</div>
                        <div class="stat-value">${latest.pendingItems}</div>
                    </div>
                </div>
            `;
        }

        /**
         * Renders the pagination controls.
         */
        function renderPagination() {
            const pageNumbersEl = document.getElementById('reconPageNumbers');
            pageNumbersEl.innerHTML = '';

            const maxButtons = 5;
            let startPage = Math.max(1, reconState.page - Math.floor(maxButtons / 2));
            let endPage = Math.min(reconState.totalPages, startPage + maxButtons - 1);
            if (endPage - startPage < maxButtons - 1) {
                startPage = Math.max(1, endPage - maxButtons + 1);
            }

            for (let i = startPage; i <= endPage; i++) {
                const btn = document.createElement('button');
                btn.className = `btn-tally-outline ${i === reconState.page ? 'active' : ''}`;
                btn.style.cssText = 'padding:6px 10px;min-width:36px;';
                btn.textContent = i;
                btn.onclick = () => goToReconPage(i);
                pageNumbersEl.appendChild(btn);
            }

            document.getElementById('reconPrevBtn').disabled = !reconState.hasPreviousPage;
            document.getElementById('reconNextBtn').disabled = !reconState.hasNextPage;
            document.getElementById('reconPageSizeSelect').value = reconState.pageSize;
        }

        /**
         * Navigates to a specific page.
         * @@param {number} page - Page number
         */
        function goToReconPage(page) {
            if (page < 1 || page > reconState.totalPages) return;
            reconState.page = page;
            loadReconciliations();
        }

        /**
         * Navigates to the previous page.
         */
        function prevReconPage() {
            if (reconState.hasPreviousPage) goToReconPage(reconState.page - 1);
        }

        /**
         * Navigates to the next page.
         */
        function nextReconPage() {
            if (reconState.hasNextPage) goToReconPage(reconState.page + 1);
        }

        /**
         * Changes the page size and reloads data.
         */
        function changeReconPageSize() {
            const select = document.getElementById('reconPageSizeSelect');
            reconState.pageSize = parseInt(select.value);
            reconState.page = 1;
            loadReconciliations();
        }

        /**
         * Handles the table sorting.
         * @@param {string} column - Column to sort by
         */
        function sortBy(column) {
            if (reconState.sortColumn === column) {
                reconState.sortDirection = reconState.sortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                reconState.sortColumn = column;
                reconState.sortDirection = 'asc';
            }
            reconState.page = 1;
            loadReconciliations();
        }

        /**
         * Updates sort icons in the table header.
         */
        function updateSortIcons() {
            document.querySelectorAll('th[onclick^="sortBy"]').forEach(th => {
                const icon = th.querySelector('i');
                if (icon) {
                    const colMatch = th.getAttribute('onclick').match(/'([^']+)'/);
                    if (colMatch) {
                        const col = colMatch[1];
                        if (col === reconState.sortColumn) {
                            icon.className = `bi bi-sort-${reconState.sortDirection === 'asc' ? 'down' : 'up'} ms-1`;
                            icon.style.color = 'var(--primary)';
                        } else {
                            icon.className = 'bi bi-arrow-down-up ms-1';
                            icon.style.color = 'var(--text-muted)';
                        }
                    }
                }
            });
        }

        /**
         * Handles the search input with debouncing.
         * @@param {Event} e - Input event
         */
        function handleReconSearch(e) {
            clearTimeout(reconSearchDebounceTimer);
            const q = e.target.value.trim();
            reconSearchDebounceTimer = setTimeout(() => {
                reconState.search = q;
                reconState.page = 1;
                loadReconciliations();
            }, 500);
        }

        /**
         * Views a reconciliation session.
         * @@param {number} id - Session ID
         */
        function viewRecon(id) {
            // Implementation for viewing details
            showToast('Opening reconciliation details...', 'info');
        }

        /**
         * Opens delete confirmation.
         * @@param {number} id - Session ID
         */
        function deleteRecon(id) {
            deleteTargetId = id;
            openModal('deleteModal');
        }

        /**
         * Confirms deletion.
         */
        async function confirmDelete() {
            if (!deleteTargetId) return;
            try {
                const response = await fetch(`/BankReconciliation/delete/${deleteTargetId}`, { method: 'DELETE' });
                if (!response.ok) throw new Error('Delete failed');
                closeModal('deleteModal');
                showToast('Session deleted', 'success');
                loadReconciliations();
            } catch (error) {
                showToast('Error deleting session', 'error');
            } finally {
                deleteTargetId = null;
            }
        }

        /**
         * Opens a modal.
         * @@param {string} modalId - Modal ID
         */
        function openModal(modalId) {
            document.getElementById(modalId)?.classList.add('open');
        }

        /**
         * Closes a modal.
         * @@param {string} modalId - Modal ID
         */
        function closeModal(modalId) {
            document.getElementById(modalId)?.classList.remove('open');
        }

        /**
         * Escapes HTML.
         * @@param {string} text - Text to escape
         * @@returns {string} Escaped text
         */
        function escapeHtml(text) {
            if (!text) return '';
            const d = document.createElement('div');
            d.textContent = text;
            return d.innerHTML;
        }

        /**
         * Displays a toast.
         * @@param {string} message - Message
         * @@param {string} [type='success'] - Toast type
         */
        function showToast(message, type = 'success') {
            const icons = { success: '✅', error: '❌', info: 'ℹ️' };
            const container = document.getElementById('toastContainer');
            if(!container) return;
            const toast = document.createElement('div');
            toast.className = `tally-toast ${type}`;
            toast.innerHTML = `<span style="font-size:16px">${icons[type]}</span><span>${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                toast.style.transition = '0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadReconciliations();
            
            // Close modals on overlay click
            document.querySelectorAll('.tally-modal-overlay').forEach(overlay => {
                overlay.addEventListener('click', function(e) {
                    if (e.target === this) closeModal(this.id);
                });
            });
        });
    </script>
</body>

</html>
