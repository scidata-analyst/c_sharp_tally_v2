@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Multi-currency Support</title>
    <partial name="_Styles" />
</head>

<body>

    <partial name="_Sidebar" />

    <partial name="_Header" model='@("Multi-currency Support")' />

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== MULTI-CURRENCY SUPPORT ===================== -->
        <div class="page active" id="page-multicurrency">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Multi-currency Support</div>
                    <div class="page-subtitle">Manage foreign currency accounts and exchange rates</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('currencyModal')">
                    <i class="bi bi-plus-lg"></i> Add Currency
                </button>
            </div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Currency Exchange Rates</div>
                    <div class="table-actions">
                        <input class="table-search" placeholder="Search currencies..." oninput="handleCurrencySearch(event)">
                        <button class="btn-tally-outline" onclick="loadCurrencies()">
                            <i class="bi bi-arrow-clockwise"></i> Refresh Rates
                        </button>
                    </div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('CurrencyName')" style="cursor:pointer;">
                                Currency <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('CurrencyCode')" style="cursor:pointer;">
                                Code <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th>Symbol</th>
                            <th onclick="sortBy('BuyRate')" style="cursor:pointer;">
                                Buy Rate <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('SellRate')" style="cursor:pointer;">
                                Sell Rate <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th onclick="sortBy('LastUpdated')" style="cursor:pointer;">
                                Last Updated <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i>
                            </th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="currencyTableBody">
                        <!-- Loaded via API -->
                    </tbody>
                </table>

                <!-- Pagination Controls -->
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">
                        Showing <span id="currencyShowingStart">0</span> to <span id="currencyShowingEnd">0</span> of <span id="currencyTotalRecords">0</span> records
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows per page:</label>
                        <select id="currencyPageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changeCurrencyPageSize()">
                            <option value="5">5</option>
                            <option value="10" selected>10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="currencyPrevBtn" style="padding:6px 12px;" onclick="prevCurrencyPage()">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <span id="currencyPageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="currencyNextBtn" style="padding:6px 12px;" onclick="nextCurrencyPage()">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- ===================== MODALS ===================== -->

    <!-- Currency Modal -->
    <div class="tally-modal-overlay" id="currencyModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Add Currency</div>
                <div class="modal-close" onclick="closeModal('currencyModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <input type="hidden" id="currencyId">
                    <div class="col-md-8">
                        <div class="form-group">
                            <label class="form-label">Currency Name *</label>
                            <input type="text" class="form-control-tally" id="currencyName" placeholder="e.g. Japanese Yen">
                            <div class="field-error" id="error-CurrencyName"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Currency Code</label>
                            <input type="text" class="form-control-tally" id="currencyCode" placeholder="JPY" maxlength="3">
                            <div class="field-error" id="error-CurrencyCode"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Symbol</label>
                            <input type="text" class="form-control-tally" id="currencySymbol" placeholder="¥" maxlength="3">
                            <div class="field-error" id="error-Symbol"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Buy Rate (vs INR)</label>
                            <input type="number" class="form-control-tally" id="currencyBuyRate" placeholder="0.000" step="0.001">
                            <div class="field-error" id="error-BuyRate"></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">Sell Rate (vs INR)</label>
                            <input type="number" class="form-control-tally" id="currencySellRate" placeholder="0.000" step="0.001">
                            <div class="field-error" id="error-SellRate"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('currencyModal')">Cancel</button>
                <button class="btn-tally-primary" id="btnSaveCurrency" onclick="saveCurrency()">
                    <i class="bi bi-check-lg"></i> Save Currency
                </button>
            </div>
        </div>
    </div>

    <!-- Delete Confirm Modal -->
    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;">
            <div class="del-icon">🗑️</div>
            <h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete Entry?</h5>
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone. The record will be permanently removed.</p>
            <div class="d-flex justify-content-center gap-3">
                <button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button>
                <button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()">
                    <i class="bi bi-trash"></i> Yes, Delete
                </button>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <partial name="_Scripts" />

    <script>
        /**
         * @@typedef {Object} CurrencyState
         * @@property {Array} data - List of currency exchange rates
         * @@property {number} page - Current page number
         * @@property {number} pageSize - Records per page
         * @@property {number} totalCount - Total number of records
         * @@property {number} totalPages - Total number of pages
         * @@property {string} search - Search query
         * @@property {string} sortColumn - Column to sort by
         * @@property {string} sortDirection - Sort direction (asc/desc)
         * @@property {number|null} editingId - ID of the record being edited
         * @@property {boolean} hasPreviousPage - Whether there is a previous page
         * @@property {boolean} hasNextPage - Whether there is a next page
         */
        let currencyState = {
            data: [],
            page: 1,
            pageSize: 10,
            totalCount: 0,
            totalPages: 0,
            search: '',
            sortColumn: 'Id',
            sortDirection: 'asc',
            editingId: null,
            hasPreviousPage: false,
            hasNextPage: false
        };

        let currencySearchDebounceTimer;
        let deleteTarget = null;

        /**
         * Loads currencies from the API based on current state.
         * @@returns {Promise<void>}
         */
        async function loadCurrencies() {
            try {
                const params = new URLSearchParams({
                    page: currencyState.page,
                    pageSize: currencyState.pageSize,
                    search: currencyState.search,
                    sortColumn: currencyState.sortColumn,
                    sortDirection: currencyState.sortDirection
                });

                const response = await fetch(`/CurrencyExchange/api/index?${params}`);
                if (!response.ok) throw new Error('Load failed');
                
                const result = await response.json();
                currencyState.data = result.data || [];
                currencyState.totalCount = result.totalCount || 0;
                currencyState.totalPages = result.totalPages || 0;
                currencyState.page = result.page || 1;
                currencyState.hasPreviousPage = result.hasPreviousPage || false;
                currencyState.hasNextPage = result.hasNextPage || false;
                
                renderCurrencyTable();
                renderCurrencyPagination();
                updateSortIcons();
            } catch (error) {
                console.error(error);
                showToast('Failed to load currencies', 'error');
            }
        }

        /**
         * Renders the currency table rows.
         */
        function renderCurrencyTable() {
            const tbody = document.getElementById('currencyTableBody');
            tbody.innerHTML = '';

            if (currencyState.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text-muted);">No currencies found</td></tr>';
                return;
            }

            currencyState.data.forEach(curr => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td class="font-weight-bold">${escapeHtml(curr.currencyName)}</td>
                    <td class="text-mono">${escapeHtml(curr.currencyCode)}</td>
                    <td class="text-center">${escapeHtml(curr.currencySymbol || '')}</td>
                    <td class="amount-positive">₹${curr.buyRate.toFixed(4)}</td>
                    <td class="amount-negative">₹${curr.sellRate.toFixed(4)}</td>
                    <td class="text-muted" style="font-size:11px">${new Date(curr.lastUpdated).toLocaleString('en-IN')}</td>
                    <td>
                        <button class="btn-tally-edit" onclick="editCurrency(${curr.id})"><i class="bi bi-pencil"></i></button>
                        <button class="btn-tally-danger" onclick="deleteCurrency(${curr.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(row);
            });

            const start = ((currencyState.page - 1) * currencyState.pageSize) + 1;
            document.getElementById('currencyShowingStart').textContent = currencyState.totalCount > 0 ? start : 0;
            document.getElementById('currencyShowingEnd').textContent = Math.min(start + currencyState.pageSize - 1, currencyState.totalCount);
            document.getElementById('currencyTotalRecords').textContent = currencyState.totalCount;
        }

        /**
         * Renders the pagination controls for currency table.
         */
        function renderCurrencyPagination() {
            const pageNumbersEl = document.getElementById('currencyPageNumbers');
            pageNumbersEl.innerHTML = '';

            const maxButtons = 5;
            let startPage = Math.max(1, currencyState.page - Math.floor(maxButtons / 2));
            let endPage = Math.min(currencyState.totalPages, startPage + maxButtons - 1);
            if (endPage - startPage < maxButtons - 1) {
                startPage = Math.max(1, endPage - maxButtons + 1);
            }

            for (let i = startPage; i <= endPage; i++) {
                const btn = document.createElement('button');
                btn.className = `btn-tally-outline ${i === currencyState.page ? 'active' : ''}`;
                btn.style.cssText = 'padding:6px 10px;min-width:36px;';
                btn.textContent = i;
                btn.onclick = () => goToCurrencyPage(i);
                pageNumbersEl.appendChild(btn);
            }

            document.getElementById('currencyPrevBtn').disabled = !currencyState.hasPreviousPage;
            document.getElementById('currencyNextBtn').disabled = !currencyState.hasNextPage;
            document.getElementById('currencyPageSizeSelect').value = currencyState.pageSize;
        }

        /**
         * Navigates to a specific page.
         * @@param {number} page - Page number
         */
        function goToCurrencyPage(page) {
            if (page < 1 || page > currencyState.totalPages) return;
            currencyState.page = page;
            loadCurrencies();
        }

        /**
         * Navigates to the previous page.
         */
        function prevCurrencyPage() {
            if (currencyState.hasPreviousPage) goToCurrencyPage(currencyState.page - 1);
        }

        /**
         * Navigates to the next page.
         */
        function nextCurrencyPage() {
            if (currencyState.hasNextPage) goToCurrencyPage(currencyState.page + 1);
        }

        /**
         * Changes the page size and reloads data.
         */
        function changeCurrencyPageSize() {
            const select = document.getElementById('currencyPageSizeSelect');
            currencyState.pageSize = parseInt(select.value);
            currencyState.page = 1;
            loadCurrencies();
        }

        /**
         * Handles the currency table sorting.
         * @@param {string} column - Column to sort by
         */
        function sortBy(column) {
            if (currencyState.sortColumn === column) {
                currencyState.sortDirection = currencyState.sortDirection === 'asc' ? 'desc' : 'asc';
            } else {
                currencyState.sortColumn = column;
                currencyState.sortDirection = 'asc';
            }
            currencyState.page = 1;
            loadCurrencies();
        }

        /**
         * Updates sort icons in the table header.
         */
        function updateSortIcons() {
            document.querySelectorAll('th[onclick^="sortBy"]').forEach(th => {
                const icon = th.querySelector('i');
                if (icon) {
                    const colMatch = th.getAttribute('onclick').match(/'([^']+)'/);
                    if (colMatch) {
                        const col = colMatch[1];
                        if (col === currencyState.sortColumn) {
                            icon.className = `bi bi-sort-${currencyState.sortDirection === 'asc' ? 'down' : 'up'} ms-1`;
                            icon.style.color = 'var(--primary)';
                        } else {
                            icon.className = 'bi bi-arrow-down-up ms-1';
                            icon.style.color = 'var(--text-muted)';
                        }
                    }
                }
            });
        }

        /**
         * Opens a modal for adding or editing a currency.
         * @@param {string} modalId - ID of the modal to open
         * @@param {Object|null} data - Data to populate the modal with
         */
        function openModal(modalId, data = null) {
            const overlay = document.getElementById(modalId);
            if (!overlay) return;

            if (modalId === 'currencyModal') {
                resetCurrencyForm();
                if (data) {
                    currencyState.editingId = data.id;
                    document.querySelector('#currencyModal .modal-title').textContent = 'Edit Currency';
                    document.getElementById('btnSaveCurrency').innerHTML = '<i class="bi bi-check-lg"></i> Update Currency';
                    
                    document.getElementById('currencyId').value = data.id;
                    document.getElementById('currencyName').value = data.currencyName;
                    document.getElementById('currencyCode').value = data.currencyCode;
                    document.getElementById('currencySymbol').value = data.currencySymbol;
                    document.getElementById('currencyBuyRate').value = data.buyRate;
                    document.getElementById('currencySellRate').value = data.sellRate;
                } else {
                    currencyState.editingId = null;
                    document.querySelector('#currencyModal .modal-title').textContent = 'Add Currency';
                    document.getElementById('btnSaveCurrency').innerHTML = '<i class="bi bi-check-lg"></i> Save Currency';
                }
            }
            overlay.classList.add('open');
        }

        /**
         * Closes a modal.
         * @@param {string} modalId - ID of the modal to close
         */
        function closeModal(modalId) {
            document.getElementById(modalId)?.classList.remove('open');
        }

        /**
         * Resets the currency form fields.
         */
        function resetCurrencyForm() {
            document.getElementById('currencyId').value = '';
            document.getElementById('currencyName').value = '';
            document.getElementById('currencyCode').value = '';
            document.getElementById('currencySymbol').value = '';
            document.getElementById('currencyBuyRate').value = '';
            document.getElementById('currencySellRate').value = '';
            document.querySelectorAll('.field-error').forEach(el => el.textContent = '');
        }

        /**
         * Saves (creates or updates) a currency record.
         * @@returns {Promise<void>}
         */
        async function saveCurrency() {
            // Clear previous errors
            document.querySelectorAll('.field-error').forEach(el => { el.textContent = ''; el.style.display = 'none'; });

            const formData = {
                currencyName: document.getElementById('currencyName').value.trim(),
                currencyCode: document.getElementById('currencyCode').value.trim(),
                symbol: document.getElementById('currencySymbol').value.trim(),
                buyRate: parseFloat(document.getElementById('currencyBuyRate').value) || 0,
                sellRate: parseFloat(document.getElementById('currencySellRate').value) || 0,
                lastUpdated: new Date().toISOString(),
                status: 'Active'
            };

            try {
                const url = currencyState.editingId ? `/CurrencyExchange/update/${currencyState.editingId}` : `/CurrencyExchange/create`;
                const method = currencyState.editingId ? 'PUT' : 'POST';

                const response = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });

                const result = await response.json();
                if (!response.ok) {
                    if (result.errors) {
                        for (const [f, m] of Object.entries(result.errors)) showFieldError(f, m.join(', '));
                        return;
                    }
                    throw new Error(result.message || 'Save failed');
                }

                closeModal('currencyModal');
                showToast('Currency saved!', 'success');
                loadCurrencies();
            } catch (error) {
                showToast(error.message, 'error');
            }
        }

        /**
         * Prepares a currency for editing by loading its data into the modal.
         * @@param {number} id - ID of the currency to edit
         */
        function editCurrency(id) {
            const curr = currencyState.data.find(c => c.id === id);
            if (curr) openModal('currencyModal', curr);
        }

        /**
         * Opens the delete confirmation modal for a currency.
         * @@param {number} id - ID of the currency to delete
         */
        function deleteCurrency(id) {
            deleteTarget = { id, type: 'currency' };
            openModal('deleteModal');
        }

        /**
         * Confirms the deletion of a record.
         * @@returns {Promise<void>}
         */
        async function confirmDelete() {
            if (!deleteTarget) return;
            try {
                const response = await fetch(`/CurrencyExchange/delete/${deleteTarget.id}`, { method: 'DELETE' });
                if (!response.ok) throw new Error('Delete failed');
                closeModal('deleteModal');
                showToast('Currency deleted', 'success');
                loadCurrencies();
            } catch (error) {
                showToast('Error deleting currency', 'error');
            } finally {
                deleteTarget = null;
            }
        }

        /**
         * Handles the currency search input event with debouncing.
         * @@param {Event} e - Input event
         */
        function handleCurrencySearch(e) {
            clearTimeout(currencySearchDebounceTimer);
            const q = e.target.value.trim();
            currencySearchDebounceTimer = setTimeout(() => {
                currencyState.search = q;
                currencyState.page = 1;
                loadCurrencies();
            }, 500);
        }

        /**
         * Displays a field error message.
         * @@param {string} field - Field name
         * @@param {string} msg - Error message
         */
        function showFieldError(field, msg) {
            const el = document.getElementById(`error-${field}`);
            if (el) { el.textContent = msg; el.style.display = 'block'; }
        }

        /**
         * Escapes HTML characters in a string.
         * @@param {string} text - String to escape
         * @@returns {string} Escaped string
         */
        function escapeHtml(text) {
            if (!text) return '';
            const d = document.createElement('div');
            d.textContent = text;
            return d.innerHTML;
        }

        /**
         * Displays a toast notification.
         * @@param {string} message - Message to display
         * @@param {string} [type='success'] - Toast type (success, error, info)
         */
        function showToast(message, type = 'success') {
            const icons = { success: '✅', error: '❌', info: 'ℹ️' };
            const container = document.getElementById('toastContainer');
            if(!container) return;
            const toast = document.createElement('div');
            toast.className = `tally-toast ${type}`;
            toast.innerHTML = `<span style="font-size:16px">${icons[type]}</span><span>${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                toast.style.transition = '0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        /**
         * Initialization on DOM content loaded.
         */
        document.addEventListener('DOMContentLoaded', () => {
            loadCurrencies();
            
            // Close modals on overlay click
            document.querySelectorAll('.tally-modal-overlay').forEach(overlay => {
                overlay.addEventListener('click', function(e) {
                    if (e.target === this) closeModal(this.id);
                });
            });
        });
    </script>
</body>

</html>
