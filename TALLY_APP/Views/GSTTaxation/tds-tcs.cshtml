@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — TDS / TCS Entries</title>
    <partial name="_Styles" />
</head>
<body>
    <partial name="_Sidebar" />
    <partial name="_Header" model='@("TDS / TCS")' />

    <main class="main-content">
        <div class="page active" id="page-tds">
            <div class="page-title-row">
                <div>
                    <div class="page-title">TDS / TCS Entries</div>
                    <div class="page-subtitle">GST & Taxation · Record and track Tax Deducted/Collected at Source</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('tdsModal')"><i class="bi bi-plus-lg"></i> New TDS/TCS Entry</button>
            </div>
            <div class="row g-3 mb-4" id="summaryCards"></div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">TDS/TCS Records</div>
                    <div class="table-actions"><input class="table-search" placeholder="Search entries..." oninput="handleSearch(event)"></div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('Id')" style="cursor:pointer;"># <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Section')" style="cursor:pointer;">Section <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('PartyName')" style="cursor:pointer;">Party <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>PAN Number</th>
                            <th onclick="sortBy('PaymentAmount')" style="cursor:pointer;">Base Amount <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('TdsAmount')" style="cursor:pointer;">TDS Amount <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Certificate #</th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">Showing <span id="showingStart">0</span> to <span id="showingEnd">0</span> of <span id="totalRecords">0</span> records</div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows:</label>
                        <select id="pageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changePageSize()"><option value="5">5</option><option value="10" selected>10</option><option value="25">25</option><option value="50">50</option></select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="prevBtn" style="padding:6px 12px;" onclick="prevPage()"><i class="bi bi-chevron-left"></i></button>
                            <span id="pageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="nextBtn" style="padding:6px 12px;" onclick="nextPage()"><i class="bi bi-chevron-right"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- TDS Modal -->
    <div class="tally-modal-overlay" id="tdsModal">
        <div class="tally-modal" style="max-width:700px;">
            <div class="modal-header">
                <div class="modal-title" id="modalTitle">New TDS/TCS Entry</div>
                <div class="modal-close" onclick="closeModal('tdsModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><div class="form-group"><label class="form-label">IT Section *</label><select class="form-control-tally" id="Section" onchange="setRate()"><option value="194C">194C - Contractor (1%)</option><option value="194J">194J - Professional (10%)</option><option value="194I">194I - Rent (10%)</option><option value="194H">194H - Commission (5%)</option><option value="206C">206C - TCS (0.1%)</option></select><div class="field-error" id="error-Section"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Status</label><select class="form-control-tally" id="Status"><option value="Deducted">Deducted / Collected</option><option value="Paid">Deposited to Govt</option><option value="Filed">Return Filed</option></select><div class="field-error" id="error-Status"></div></div></div>

                    <div class="col-md-6"><div class="form-group"><label class="form-label">Party Name *</label><input type="text" class="form-control-tally" id="PartyName"><div class="field-error" id="error-PartyName"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Party PAN *</label><input type="text" class="form-control-tally" id="PanNumber" placeholder="ABCDE1234F"><div class="field-error" id="error-PanNumber"></div></div></div>
                    <div class="col-md-12"><div class="form-group"><label class="form-label">Party ID</label><input type="number" class="form-control-tally" id="PartyId"><div class="field-error" id="error-PartyId"></div></div></div>

                    <div class="col-md-4"><div class="form-group"><label class="form-label">Base Amount *</label><input type="number" step="0.01" class="form-control-tally calc" id="PaymentAmount"><div class="field-error" id="error-PaymentAmount"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">TDS Rate (%) *</label><input type="number" step="0.01" class="form-control-tally calc" id="TdsRate"><div class="field-error" id="error-TdsRate"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">TDS Amount</label><input type="number" step="0.01" class="form-control-tally" id="TdsAmount" readonly style="background:var(--bg-tertiary);"><div class="field-error" id="error-TdsAmount"></div></div></div>
                    
                    <div class="col-md-12"><div class="form-group"><label class="form-label">Certificate Number (Form 16/16A)</label><input type="text" class="form-control-tally" id="CertificateNumber"><div class="field-error" id="error-CertificateNumber"></div></div></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('tdsModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveRecord()"><i class="bi bi-check-lg"></i> Save Entry</button>
            </div>
        </div>
    </div>

    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;"><div class="del-icon">🗑️</div><h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete Entry?</h5><p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone.</p><div class="d-flex justify-content-center gap-3"><button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button><button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()"><i class="bi bi-trash"></i> Yes, Delete</button></div></div>
    </div>

    <div class="toast-container" id="toastContainer"></div>
    <partial name="_Scripts" />

    <script>
        let st = { data: [], page: 1, pageSize: 10, totalCount: 0, totalPages: 0, search: '', sortColumn: 'Id', sortDirection: 'desc', hasPreviousPage: false, hasNextPage: false, editingId: null };
        let deleteTarget = null; let searchTimer = null;

        const rates = { '194C': 1, '194J': 10, '194I': 10, '194H': 5, '206C': 0.1 };
        function setRate() {
            const sec = document.getElementById('Section').value;
            if (rates[sec]) {
                document.getElementById('TdsRate').value = rates[sec];
                calcTds();
            }
        }

        function calcTds() {
            const amt = parseFloat(document.getElementById('PaymentAmount').value) || 0;
            const r = parseFloat(document.getElementById('TdsRate').value) || 0;
            document.getElementById('TdsAmount').value = ((amt * r) / 100).toFixed(2);
        }
        document.querySelectorAll('.calc').forEach(e => e.addEventListener('input', calcTds));

        function openModal(id, item = null) { const o = document.getElementById(id); if (!o) return; o.classList.add('open'); if (id === 'tdsModal') { clearErrors(); if (item) { st.editingId = item.id; document.getElementById('modalTitle').textContent = 'Edit TDS/TCS Entry'; document.getElementById('Section').value = item.section||'194C'; document.getElementById('PartyName').value = item.partyName||''; document.getElementById('PanNumber').value = item.panNumber||''; document.getElementById('PartyId').value = item.partyId||''; document.getElementById('PaymentAmount').value = item.paymentAmount||0; document.getElementById('TdsRate').value = item.tdsRate||0; document.getElementById('TdsAmount').value = item.tdsAmount||0; document.getElementById('CertificateNumber').value = item.certificateNumber||''; document.getElementById('Status').value = item.status||'Deducted'; } else { st.editingId = null; document.getElementById('modalTitle').textContent = 'New TDS/TCS Entry'; document.getElementById('Section').value='194C'; ['PartyName','PanNumber','PartyId','CertificateNumber'].forEach(f=>document.getElementById(f).value=''); ['PaymentAmount','TdsRate','TdsAmount'].forEach(f=>document.getElementById(f).value='0'); document.getElementById('Status').value='Deducted'; setRate(); } } }
        function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }
        function clearErrors() { document.querySelectorAll('.field-error').forEach(el => el.textContent = ''); }
        function showFieldError(f, msg) { const el = document.getElementById('error-' + f); if (el) el.textContent = msg; }

        async function loadData() {
            const params = new URLSearchParams({ page: st.page, pageSize: st.pageSize, search: st.search, sortColumn: st.sortColumn, sortDirection: st.sortDirection });
            try { const r = await fetch(`/TDSTCSEntry/api/index?${params}`); if (!r.ok) throw new Error(); const d = await r.json(); Object.assign(st, { data: d.data||[], totalCount: d.totalCount||0, totalPages: d.totalPages||0, page: d.page||1, hasPreviousPage: d.hasPreviousPage||false, hasNextPage: d.hasNextPage||false }); renderTable(); renderPagination(); renderSummary(); } catch(e) { showToast('Failed to load','error'); }
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody'); tbody.innerHTML = '';
            if (!st.data.length) { tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--text-muted);">No records found</td></tr>'; return; }
            const s = ((st.page-1)*st.pageSize)+1;
            st.data.forEach((item, i) => {
                const badge = {'Deducted':'badge-warning','Paid':'badge-primary','Filed':'badge-success'};
                const row = document.createElement('tr');
                row.innerHTML = `<td>${s+i}</td><td><span class="badge-tally badge-info">${esc(item.section)}</span></td><td style="font-weight:600">${esc(item.partyName)}</td><td class="text-mono">${esc(item.panNumber)}</td><td>₹${fmt(item.paymentAmount)}</td><td style="font-weight:600;color:var(--danger)">₹${fmt(item.tdsAmount)} <small>(${item.tdsRate}%)</small></td><td>${esc(item.certificateNumber||'-')}</td><td><span class="badge-tally ${badge[item.status]||'badge-info'}">${esc(item.status)}</span></td><td><button class="btn-tally-edit" onclick="editItem(${item.id})"><i class="bi bi-pencil"></i></button> <button class="btn-tally-danger" onclick="deleteItem(${item.id})"><i class="bi bi-trash"></i></button></td>`;
                tbody.appendChild(row);
            });
            document.getElementById('showingStart').textContent = st.totalCount > 0 ? s : 0; document.getElementById('showingEnd').textContent = Math.min(s+st.pageSize-1, st.totalCount); document.getElementById('totalRecords').textContent = st.totalCount;
        }

        function renderSummary() {
            document.getElementById('summaryCards').innerHTML = `<div class="col-md-3"><div class="stat-card" style="--card-accent:var(--accent)"><div class="stat-label">Total Entries</div><div class="stat-value">${st.totalCount}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--danger)"><div class="stat-label">Total TDS Amount</div><div class="stat-value">₹${fmt(st.data.reduce((a,i)=>a+i.tdsAmount,0))}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--warning)"><div class="stat-label">Pending Deposit</div><div class="stat-value">${st.data.filter(i=>i.status==='Deducted').length}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--success)"><div class="stat-label">Returns Filed</div><div class="stat-value">${st.data.filter(i=>i.status==='Filed').length}</div></div></div>`;
        }

        function renderPagination() { const el = document.getElementById('pageNumbers'); el.innerHTML = ''; const max=5; let s=Math.max(1,st.page-Math.floor(max/2)); let e=Math.min(st.totalPages,s+max-1); if(e-s<max-1) s=Math.max(1,e-max+1); for(let i=s;i<=e;i++){const b=document.createElement('button');b.className=`btn-tally-outline ${i===st.page?'active':''}`;b.style.cssText='padding:6px 10px;min-width:36px;';b.textContent=i;b.onclick=()=>goToPage(i);el.appendChild(b);} document.getElementById('prevBtn').disabled=!st.hasPreviousPage; document.getElementById('nextBtn').disabled=!st.hasNextPage; document.getElementById('pageSizeSelect').value=st.pageSize; }

        function goToPage(p){if(p<1||p>st.totalPages)return;st.page=p;loadData();} function prevPage(){if(st.hasPreviousPage)goToPage(st.page-1);} function nextPage(){if(st.hasNextPage)goToPage(st.page+1);} function changePageSize(){st.pageSize=parseInt(document.getElementById('pageSizeSelect').value);st.page=1;loadData();}
        function sortBy(col){if(st.sortColumn===col)st.sortDirection=st.sortDirection==='asc'?'desc':'asc';else{st.sortColumn=col;st.sortDirection='asc';}st.page=1;loadData();}
        function handleSearch(e){clearTimeout(searchTimer);searchTimer=setTimeout(()=>{st.search=e.target.value.trim();st.page=1;loadData();},500);}

        async function saveRecord(){clearErrors();const fd={section:document.getElementById('Section').value,partyName:document.getElementById('PartyName').value.trim(),panNumber:document.getElementById('PanNumber').value.trim(),partyId: (document.getElementById("PartyId").value) ? parseInt(document.getElementById("PartyId").value) : null,paymentAmount: (document.getElementById("PaymentAmount").value) ? parseFloat(document.getElementById("PaymentAmount").value) : null,tdsRate: (document.getElementById("TdsRate").value) ? parseFloat(document.getElementById("TdsRate").value) : null,tdsAmount: (document.getElementById("TdsAmount").value) ? parseFloat(document.getElementById("TdsAmount").value) : null,certificateNumber:document.getElementById('CertificateNumber').value.trim(),status:document.getElementById('Status').value};try{const url=st.editingId?`/TDSTCSEntry/update/${st.editingId}`:`/TDSTCSEntry/create`;const m=st.editingId?'PUT':'POST';const r=await fetch(url,{method:m,headers:{'Content-Type':'application/json'},body:JSON.stringify(fd)});const d=await r.json();if(!r.ok){if(r.status===400&&d.errors){for(const[f,msgs]of Object.entries(d.errors))showFieldError(f,msgs.join(', '));return;}throw new Error(d.message||'Failed');}closeModal('tdsModal');showToast(st.editingId?'Entry updated!':'Entry saved!','success');loadData();}catch(e){showToast('Save failed: '+e.message,'error');}}

        function editItem(id){const item=st.data.find(i=>i.id===id);if(item)openModal('tdsModal',item);} function deleteItem(id){deleteTarget={id};openModal('deleteModal');}
        async function confirmDelete(){if(!deleteTarget)return;try{const r=await fetch(`/TDSTCSEntry/delete/${deleteTarget.id}`,{method:'DELETE'});if(!r.ok)throw new Error();closeModal('deleteModal');showToast('Deleted','success');loadData();}catch(e){showToast('Delete failed','error');}finally{deleteTarget=null;}}

        function esc(t){if(!t)return'';const d=document.createElement('div');d.textContent=t;return d.innerHTML;} function fmt(n){return parseFloat(n||0).toLocaleString('en-IN',{maximumFractionDigits:2});}
        function showToast(msg,type='success'){const icons={success:'✅',error:'❌',info:'ℹ️'};const c=document.getElementById('toastContainer');if(!c)return;const t=document.createElement('div');t.className=`tally-toast ${type}`;t.innerHTML=`<span style="font-size:16px">${icons[type]}</span><span>${msg}</span>`;c.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(20px)';t.style.transition='0.3s ease';setTimeout(()=>t.remove(),300);},3000);}

        document.addEventListener('DOMContentLoaded',()=>{loadData();document.querySelectorAll('.tally-modal-overlay').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)closeModal(this.id);}));});
        document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.tally-modal-overlay.open').forEach(m=>m.classList.remove('open'));});
    </script>
</body>
</html>





