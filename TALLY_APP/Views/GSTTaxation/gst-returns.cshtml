@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — GST Returns</title>
    <partial name="_Styles" />
</head>
<body>
    <partial name="_Sidebar" />
    <partial name="_Header" model='@("GST Returns")' />

    <main class="main-content">
        <div class="page active" id="page-gst-returns">
            <div class="page-title-row">
                <div>
                    <div class="page-title">GST Returns Filing</div>
                    <div class="page-subtitle">GST & Taxation · Manage GSTR-1, GSTR-3B filings</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('returnModal')"><i class="bi bi-file-earmark-check"></i> File Return</button>
            </div>
            <div class="row g-3 mb-4" id="summaryCards"></div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Returns History</div>
                    <div class="table-actions"><input class="table-search" placeholder="Search returns..." oninput="handleSearch(event)"></div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('Id')" style="cursor:pointer;"># <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('ReturnType')" style="cursor:pointer;">Form <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Period')" style="cursor:pointer;">Period <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('DueDate')" style="cursor:pointer;">Due Date <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('NetPayable')" style="cursor:pointer;">Net Tax Payable <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('FiledDate')" style="cursor:pointer;">Filed On <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">Showing <span id="showingStart">0</span> to <span id="showingEnd">0</span> of <span id="totalRecords">0</span> records</div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows:</label>
                        <select id="pageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changePageSize()"><option value="5">5</option><option value="10" selected>10</option><option value="25">25</option><option value="50">50</option></select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="prevBtn" style="padding:6px 12px;" onclick="prevPage()"><i class="bi bi-chevron-left"></i></button>
                            <span id="pageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="nextBtn" style="padding:6px 12px;" onclick="nextPage()"><i class="bi bi-chevron-right"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Return Modal -->
    <div class="tally-modal-overlay" id="returnModal">
        <div class="tally-modal" style="max-width:800px;">
            <div class="modal-header">
                <div class="modal-title" id="modalTitle">File GST Return</div>
                <div class="modal-close" onclick="closeModal('returnModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <h6 style="margin-bottom: 15px; color: var(--primary);">Return Details</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Return Form *</label><select class="form-control-tally" id="ReturnType"><option value="GSTR-1">GSTR-1 (Outward Supplies)</option><option value="GSTR-3B">GSTR-3B (Summary)</option><option value="GSTR-9">GSTR-9 (Annual)</option></select><div class="field-error" id="error-ReturnType"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Period (e.g. Apr 2024) *</label><input type="text" class="form-control-tally" id="Period" placeholder="MMM YYYY"><div class="field-error" id="error-Period"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Due Date *</label><input type="date" class="form-control-tally" id="DueDate"><div class="field-error" id="error-DueDate"></div></div></div>
                </div>

                <h6 style="margin-bottom: 15px; color: var(--primary);">Tax Summary</h6>
                <div class="row g-3">
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Total Outward Supplies</label><input type="number" step="0.01" class="form-control-tally" id="TotalOutward"><div class="field-error" id="error-TotalOutward"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Tax Collected (Output Tax)</label><input type="number" step="0.01" class="form-control-tally calc" id="TaxCollected"><div class="field-error" id="error-TaxCollected"></div></div></div>
                    
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Total Inward Supplies</label><input type="number" step="0.01" class="form-control-tally" id="TotalInward"><div class="field-error" id="error-TotalInward"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">ITC Available (Input Tax)</label><input type="number" step="0.01" class="form-control-tally calc" id="ItcAvailable"><div class="field-error" id="error-ItcAvailable"></div></div></div>

                    <div class="col-md-6"><div class="form-group"><label class="form-label">Status</label><select class="form-control-tally" id="Status"><option value="Prepared">Prepared</option><option value="Filed">Filed</option><option value="Overdue">Overdue</option></select><div class="field-error" id="error-Status"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Net Tax Payable</label><input type="number" step="0.01" class="form-control-tally" id="NetPayable" readonly style="background:var(--bg-tertiary);font-weight:600;"><div class="field-error" id="error-NetPayable"></div></div></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('returnModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveRecord()"><i class="bi bi-check-lg"></i> Save Return</button>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;"><div class="del-icon">🗑️</div><h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete Return?</h5><p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone.</p><div class="d-flex justify-content-center gap-3"><button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button><button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()"><i class="bi bi-trash"></i> Yes, Delete</button></div></div>
    </div>

    <div class="toast-container" id="toastContainer"></div>
    <partial name="_Scripts" />

    <script>
        let st = { data: [], page: 1, pageSize: 10, totalCount: 0, totalPages: 0, search: '', sortColumn: 'Id', sortDirection: 'desc', hasPreviousPage: false, hasNextPage: false, editingId: null };
        let deleteTarget = null; let searchTimer = null;

        function openModal(id, item = null) { const o = document.getElementById(id); if (!o) return; o.classList.add('open'); if (id === 'returnModal') { clearErrors(); if (item) { st.editingId = item.id; document.getElementById('modalTitle').textContent = 'Edit Return'; document.getElementById('ReturnType').value = item.returnType||'GSTR-1'; document.getElementById('Period').value = item.period||''; document.getElementById('DueDate').value = item.dueDate ? item.dueDate.substring(0,10) : ''; document.getElementById('TotalOutward').value = item.totalOutward||0; document.getElementById('TaxCollected').value = item.taxCollected||0; document.getElementById('TotalInward').value = item.totalInward||0; document.getElementById('ItcAvailable').value = item.itcAvailable||0; document.getElementById('NetPayable').value = item.netPayable||0; document.getElementById('Status').value = item.status||'Prepared'; } else { st.editingId = null; document.getElementById('modalTitle').textContent = 'File Return'; document.getElementById('ReturnType').value='GSTR-1'; document.getElementById('Period').value = ''; document.getElementById('DueDate').value = new Date().toISOString().substring(0,10); ['TotalOutward','TaxCollected','TotalInward','ItcAvailable','NetPayable'].forEach(f=>document.getElementById(f).value='0'); document.getElementById('Status').value='Prepared'; } } }
        function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }
        function clearErrors() { document.querySelectorAll('.field-error').forEach(el => el.textContent = ''); }
        function showFieldError(f, msg) { const el = document.getElementById('error-' + f); if (el) el.textContent = msg; }

        function calc() {
            const out = parseFloat(document.getElementById('TaxCollected').value)||0;
            const inn = parseFloat(document.getElementById('ItcAvailable').value)||0;
            const net = Math.max(0, out - inn);
            const el = document.getElementById('NetPayable');
            el.value = net.toFixed(2);
            el.style.color = net > 0 ? 'var(--danger)' : 'var(--success)';
        }
        document.querySelectorAll('.calc').forEach(e => e.addEventListener('input', calc));

        async function loadData() {
            const params = new URLSearchParams({ page: st.page, pageSize: st.pageSize, search: st.search, sortColumn: st.sortColumn, sortDirection: st.sortDirection });
            try { const r = await fetch(`/GSTReturn/api/index?${params}`); if (!r.ok) throw new Error(); const d = await r.json(); Object.assign(st, { data: d.data||[], totalCount: d.totalCount||0, totalPages: d.totalPages||0, page: d.page||1, hasPreviousPage: d.hasPreviousPage||false, hasNextPage: d.hasNextPage||false }); renderTable(); renderPagination(); renderSummary(); } catch(e) { showToast('Failed to load','error'); }
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody'); tbody.innerHTML = '';
            if (!st.data.length) { tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text-muted);">No records found</td></tr>'; return; }
            const s = ((st.page-1)*st.pageSize)+1;
            st.data.forEach((item, i) => {
                const sBadge = {'Filed':'badge-success','Overdue':'badge-danger','Prepared':'badge-warning'};
                const row = document.createElement('tr');
                row.innerHTML = `<td>${s+i}</td><td><span class="badge-tally badge-primary">${esc(item.returnType)}</span></td><td style="font-weight:600">${esc(item.period)}</td><td>${item.dueDate?new Date(item.dueDate).toLocaleDateString('en-IN'):'-'}</td><td style="font-weight:600;color:${item.netPayable>0?'var(--danger)':'var(--success)'}">₹${fmt(item.netPayable)}</td><td><span class="badge-tally ${sBadge[item.status]||'badge-info'}">${esc(item.status)}</span></td><td>${item.filedDate?new Date(item.filedDate).toLocaleDateString('en-IN'):'Not filed'}</td><td><button class="btn-tally-outline" style="padding:4px 8px;font-size:12px;margin-right:4px;" onclick="upload(${item.id})"><i class="bi bi-cloud-arrow-up"></i></button><button class="btn-tally-edit" onclick="editItem(${item.id})"><i class="bi bi-pencil"></i></button> <button class="btn-tally-danger" onclick="deleteItem(${item.id})"><i class="bi bi-trash"></i></button></td>`;
                tbody.appendChild(row);
            });
            document.getElementById('showingStart').textContent = st.totalCount > 0 ? s : 0; document.getElementById('showingEnd').textContent = Math.min(s+st.pageSize-1, st.totalCount); document.getElementById('totalRecords').textContent = st.totalCount;
        }

        function renderSummary() {
            document.getElementById('summaryCards').innerHTML = `<div class="col-md-3"><div class="stat-card" style="--card-accent:var(--accent)"><div class="stat-label">Total Filings</div><div class="stat-value">${st.totalCount}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--danger)"><div class="stat-label">Total Net Payable</div><div class="stat-value">₹${fmt(st.data.reduce((a,i)=>a+i.netPayable,0))}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--warning)"><div class="stat-label">Pending Filings</div><div class="stat-value">${st.data.filter(i=>i.status==='Prepared').length}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--success)"><div class="stat-label">Completed</div><div class="stat-value">${st.data.filter(i=>i.status==='Filed').length}</div></div></div>`;
        }

        function renderPagination() { const el = document.getElementById('pageNumbers'); el.innerHTML = ''; const max=5; let s=Math.max(1,st.page-Math.floor(max/2)); let e=Math.min(st.totalPages,s+max-1); if(e-s<max-1) s=Math.max(1,e-max+1); for(let i=s;i<=e;i++){const b=document.createElement('button');b.className=`btn-tally-outline ${i===st.page?'active':''}`;b.style.cssText='padding:6px 10px;min-width:36px;';b.textContent=i;b.onclick=()=>goToPage(i);el.appendChild(b);} document.getElementById('prevBtn').disabled=!st.hasPreviousPage; document.getElementById('nextBtn').disabled=!st.hasNextPage; document.getElementById('pageSizeSelect').value=st.pageSize; }

        function goToPage(p){if(p<1||p>st.totalPages)return;st.page=p;loadData();} function prevPage(){if(st.hasPreviousPage)goToPage(st.page-1);} function nextPage(){if(st.hasNextPage)goToPage(st.page+1);} function changePageSize(){st.pageSize=parseInt(document.getElementById('pageSizeSelect').value);st.page=1;loadData();}
        function sortBy(col){if(st.sortColumn===col)st.sortDirection=st.sortDirection==='asc'?'desc':'asc';else{st.sortColumn=col;st.sortDirection='asc';}st.page=1;loadData();}
        function handleSearch(e){clearTimeout(searchTimer);searchTimer=setTimeout(()=>{st.search=e.target.value.trim();st.page=1;loadData();},500);}

        async function upload(id) {
            showToast('Generating JSON payload for GST portal...','info');
            setTimeout(() => { showToast('Payload ready! Redirecting...','success'); }, 2000);
        }

        async function saveRecord(){clearErrors();const fd={returnType:document.getElementById('ReturnType').value,period:document.getElementById('Period').value.trim(),dueDate:document.getElementById('DueDate').value||new Date().toISOString().substring(0,10),totalOutward:parseFloat(document.getElementById('TotalOutward').value)||0,taxCollected:parseFloat(document.getElementById('TaxCollected').value)||0,totalInward:parseFloat(document.getElementById('TotalInward').value)||0,itcAvailable:parseFloat(document.getElementById('ItcAvailable').value)||0,netPayable:parseFloat(document.getElementById('NetPayable').value)||0,status:document.getElementById('Status').value,filedDate:document.getElementById('Status').value==='Filed'?new Date().toISOString():null};try{const url=st.editingId?`/GSTReturn/update/${st.editingId}`:`/GSTReturn/create`;const m=st.editingId?'PUT':'POST';const r=await fetch(url,{method:m,headers:{'Content-Type':'application/json'},body:JSON.stringify(fd)});const d=await r.json();if(!r.ok){if(r.status===400&&d.errors){for(const[f,msgs]of Object.entries(d.errors))showFieldError(f,msgs.join(', '));return;}throw new Error(d.message||'Failed');}closeModal('returnModal');showToast(st.editingId?'Updated!':'Saved!','success');loadData();}catch(e){showToast('Save failed: '+e.message,'error');}}

        function editItem(id){const item=st.data.find(i=>i.id===id);if(item)openModal('returnModal',item);} function deleteItem(id){deleteTarget={id};openModal('deleteModal');}
        async function confirmDelete(){if(!deleteTarget)return;try{const r=await fetch(`/GSTReturn/delete/${deleteTarget.id}`,{method:'DELETE'});if(!r.ok)throw new Error();closeModal('deleteModal');showToast('Deleted','success');loadData();}catch(e){showToast('Delete failed','error');}finally{deleteTarget=null;}}

        function esc(t){if(!t)return'';const d=document.createElement('div');d.textContent=t;return d.innerHTML;} function fmt(n){return parseFloat(n||0).toLocaleString('en-IN',{maximumFractionDigits:2});}
        function showToast(msg,type='success'){const icons={success:'✅',error:'❌',info:'ℹ️'};const c=document.getElementById('toastContainer');if(!c)return;const t=document.createElement('div');t.className=`tally-toast ${type}`;t.innerHTML=`<span style="font-size:16px">${icons[type]}</span><span>${msg}</span>`;c.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(20px)';t.style.transition='0.3s ease';setTimeout(()=>t.remove(),300);},3000);}

        document.addEventListener('DOMContentLoaded',()=>{loadData();document.querySelectorAll('.tally-modal-overlay').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)closeModal(this.id);}));});
        document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.tally-modal-overlay.open').forEach(m=>m.classList.remove('open'));});
    </script>
</body>
</html>
