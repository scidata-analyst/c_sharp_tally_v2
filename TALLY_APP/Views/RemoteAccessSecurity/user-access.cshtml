@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — User Access Control</title>
    <partial name="_Styles" />
</head>
<body>
    <partial name="_Sidebar" />
    <partial name="_Header" model='@("User Management")' />

    <main class="main-content">
        <div class="page active" id="page-users">
            <div class="page-title-row">
                <div>
                    <div class="page-title">System Users</div>
                    <div class="page-subtitle">Security · Manage user accounts and module access</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('userModal')"><i class="bi bi-person-plus"></i> Add New User</button>
            </div>
            <div class="row g-3 mb-4" id="summaryCards"></div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Registered Users</div>
                    <div class="table-actions"><input class="table-search" placeholder="Search users..." oninput="handleSearch(event)"></div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('Id')" style="cursor:pointer;"># <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('FullName')" style="cursor:pointer;">Full Name <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Email')" style="cursor:pointer;">Email <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Role')" style="cursor:pointer;">Role <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('LastLogin')" style="cursor:pointer;">Last Login <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">Showing <span id="showingStart">0</span> to <span id="showingEnd">0</span> of <span id="totalRecords">0</span> records</div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows:</label>
                        <select id="pageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changePageSize()"><option value="5">5</option><option value="10" selected>10</option><option value="25">25</option><option value="50">50</option></select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="prevBtn" style="padding:6px 12px;" onclick="prevPage()"><i class="bi bi-chevron-left"></i></button>
                            <span id="pageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="nextBtn" style="padding:6px 12px;" onclick="nextPage()"><i class="bi bi-chevron-right"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div class="tally-modal-overlay" id="userModal">
        <div class="tally-modal" style="max-width:700px;">
            <div class="modal-header">
                <div class="modal-title" id="modalTitle">New System User</div>
                <div class="modal-close" onclick="closeModal('userModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Full Name *</label><input type="text" class="form-control-tally" id="FullName"><div class="field-error" id="error-FullName"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Email *</label><input type="email" class="form-control-tally" id="Email"><div class="field-error" id="error-Email"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Role</label><select class="form-control-tally" id="Role"><option value="Admin">Administrator</option><option value="Manager">Branch Manager</option><option value="Accountant">Accountant</option><option value="User">Standard User</option></select><div class="field-error" id="error-Role"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Status</label><select class="form-control-tally" id="Status"><option value="Active">Active</option><option value="Locked">Locked</option><option value="Inactive">Inactive</option></select><div class="field-error" id="error-Status"></div></div></div>
                    <div class="col-md-12"><div class="form-group"><label class="form-label">Module Access (Comma separated)</label><input type="text" class="form-control-tally" id="ModuleAccess" placeholder="Accounting, Payroll, Inventory"><div class="field-error" id="error-ModuleAccess"></div></div></div>
                    <div class="col-md-12" id="passwordRow"><div class="form-group"><label class="form-label">Password *</label><input type="password" class="form-control-tally" id="PasswordHash"><div class="field-error" id="error-PasswordHash"></div></div></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('userModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveRecord()"><i class="bi bi-check-lg"></i> Save User</button>
            </div>
        </div>
    </div>

    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;"><div class="del-icon">🗑️</div><h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete User?</h5><p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone. All access will be revoked immediately.</p><div class="d-flex justify-content-center gap-3"><button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button><button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()"><i class="bi bi-trash"></i> Yes, Delete</button></div></div>
    </div>

    <div class="toast-container" id="toastContainer"></div>
    <partial name="_Scripts" />

    <script>
        let st = { data: [], page: 1, pageSize: 10, totalCount: 0, totalPages: 0, search: '', sortColumn: 'Id', sortDirection: 'asc', hasPreviousPage: false, hasNextPage: false, editingId: null };
        let deleteTarget = null; let searchTimer = null;

        function openModal(id, item = null) { const o = document.getElementById(id); if (!o) return; o.classList.add('open'); if (id === 'userModal') { clearErrors(); if (item) { st.editingId = item.id; document.getElementById('modalTitle').textContent = 'Edit System User'; document.getElementById('FullName').value = item.fullName||''; document.getElementById('Email').value = item.email||''; document.getElementById('Role').value = item.role||'User'; document.getElementById('Status').value = item.status||'Active'; document.getElementById('ModuleAccess').value = item.moduleAccess||''; document.getElementById('passwordRow').style.display = 'none'; } else { st.editingId = null; document.getElementById('modalTitle').textContent = 'New System User'; ['FullName','Email','ModuleAccess','PasswordHash'].forEach(f=>document.getElementById(f).value=''); document.getElementById('Role').value='User'; document.getElementById('Status').value='Active'; document.getElementById('passwordRow').style.display = 'block'; } } }
        function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }
        function clearErrors() { document.querySelectorAll('.field-error').forEach(el => el.textContent = ''); }
        function showFieldError(f, msg) { const el = document.getElementById('error-' + f); if (el) el.textContent = msg; }

        async function loadData() {
            const params = new URLSearchParams({ page: st.page, pageSize: st.pageSize, search: st.search, sortColumn: st.sortColumn, sortDirection: st.sortDirection });
            try { const r = await fetch(`/SystemUser/api/index?${params}`); if (!r.ok) throw new Error(); const d = await r.json(); Object.assign(st, { data: d.data||[], totalCount: d.totalCount||0, totalPages: d.totalPages||0, page: d.page||1, hasPreviousPage: d.hasPreviousPage||false, hasNextPage: d.hasNextPage||false }); renderTable(); renderPagination(); renderSummary(); } catch(e) { showToast('Failed to load','error'); }
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody'); tbody.innerHTML = '';
            if (!st.data.length) { tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text-muted);">No users found</td></tr>'; return; }
            const s = ((st.page-1)*st.pageSize)+1;
            st.data.forEach((item, i) => {
                const sBadge = {'Active':'badge-success','Locked':'badge-danger','Inactive':'badge-warning'};
                const row = document.createElement('tr');
                row.innerHTML = `<td>${s+i}</td><td style="font-weight:600">${esc(item.fullName)}</td><td class="text-mono">${esc(item.email)}</td><td><span class="badge-tally badge-info">${esc(item.role)}</span></td><td>${item.lastLogin ? new Date(item.lastLogin).toLocaleString() : 'Never'}</td><td><span class="badge-tally ${sBadge[item.status]||'badge-info'}">${esc(item.status)}</span></td><td><button class="btn-tally-edit" onclick="editItem(${item.id})"><i class="bi bi-pencil"></i></button> <button class="btn-tally-danger" onclick="deleteItem(${item.id})"><i class="bi bi-trash"></i></button></td>`;
                tbody.appendChild(row);
            });
            document.getElementById('showingStart').textContent = st.totalCount > 0 ? s : 0; document.getElementById('showingEnd').textContent = Math.min(s+st.pageSize-1, st.totalCount); document.getElementById('totalRecords').textContent = st.totalCount;
        }

        function renderSummary() {
            document.getElementById('summaryCards').innerHTML = `<div class="col-md-4"><div class="stat-card" style="--card-accent:var(--accent)"><div class="stat-label">Total Users</div><div class="stat-value">${st.totalCount}</div></div></div><div class="col-md-4"><div class="stat-card" style="--card-accent:var(--success)"><div class="stat-label">Active Users</div><div class="stat-value">${st.data.filter(u=>u.status==='Active').length}</div></div></div><div class="col-md-4"><div class="stat-card" style="--card-accent:var(--danger)"><div class="stat-label">Locked Accounts</div><div class="stat-value">${st.data.filter(u=>u.status==='Locked').length}</div></div></div>`;
        }

        function renderPagination() { const el = document.getElementById('pageNumbers'); el.innerHTML = ''; const max=5; let s=Math.max(1,st.page-Math.floor(max/2)); let e=Math.min(st.totalPages,s+max-1); if(e-s<max-1) s=Math.max(1,e-max+1); for(let i=s;i<=e;i++){const b=document.createElement('button');b.className=`btn-tally-outline ${i===st.page?'active':''}`;b.style.cssText='padding:6px 10px;min-width:36px;';b.textContent=i;b.onclick=()=>goToPage(i);el.appendChild(b);} document.getElementById('prevBtn').disabled=!st.hasPreviousPage; document.getElementById('nextBtn').disabled=!st.hasNextPage; }

        function goToPage(p){if(p<1||p>st.totalPages)return;st.page=p;loadData();} function prevPage(){if(st.hasPreviousPage)goToPage(st.page-1);} function nextPage(){if(st.hasNextPage)goToPage(st.page+1);} function changePageSize(){st.pageSize=parseInt(document.getElementById('pageSizeSelect').value);st.page=1;loadData();}
        function sortBy(col){if(st.sortColumn===col)st.sortDirection=st.sortDirection==='asc'?'desc':'asc';else{st.sortColumn=col;st.sortDirection='asc';}st.page=1;loadData();}
        function handleSearch(e){clearTimeout(searchTimer);searchTimer=setTimeout(()=>{st.search=e.target.value.trim();st.page=1;loadData();},500);}

        async function saveRecord(){clearErrors();const fd={fullName:document.getElementById('FullName').value.trim(),email:document.getElementById('Email').value.trim(),role:document.getElementById('Role').value,status:document.getElementById('Status').value,moduleAccess:document.getElementById('ModuleAccess').value.trim(),passwordHash:document.getElementById('PasswordHash').value};try{const url=st.editingId?`/SystemUser/update/${st.editingId}`:`/SystemUser/create`;const m=st.editingId?'PUT':'POST';const r=await fetch(url,{method:m,headers:{'Content-Type':'application/json'},body:JSON.stringify(fd)});const d=await r.json();if(!r.ok){if(r.status===400&&d.errors){for(const[f,msgs]of Object.entries(d.errors))showFieldError(f,msgs.join(', '));return;}throw new Error(d.message||'Failed');}closeModal('userModal');showToast(st.editingId?'Updated!':'Saved!','success');loadData();}catch(e){showToast('Save failed: '+e.message,'error');}}

        function editItem(id){const item=st.data.find(i=>i.id===id);if(item)openModal('userModal',item);} function deleteItem(id){deleteTarget={id};openModal('deleteModal');}
        async function confirmDelete(){if(!deleteTarget)return;try{const r=await fetch(`/SystemUser/delete/${deleteTarget.id}`,{method:'DELETE'});if(!r.ok)throw new Error();closeModal('deleteModal');showToast('Deleted','success');loadData();}catch(e){showToast('Delete failed','error');}finally{deleteTarget=null;}}

        function esc(t){if(!t)return'';const d=document.createElement('div');d.textContent=t;return d.innerHTML;} function fmt(n){return parseFloat(n||0).toLocaleString('en-IN',{maximumFractionDigits:2});}
        function showToast(msg,type='success'){const icons={success:'✅',error:'❌',info:'ℹ️'};const c=document.getElementById('toastContainer');if(!c)return;const t=document.createElement('div');t.className=`tally-toast ${type}`;t.innerHTML=`<span style="font-size:16px">${icons[type]}</span><span>${msg}</span>`;c.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(20px)';t.style.transition='0.3s ease';setTimeout(()=>t.remove(),300);},3000);}

        document.addEventListener('DOMContentLoaded',()=>{loadData();document.querySelectorAll('.tally-modal-overlay').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)closeModal(this.id);}));});
        document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.tally-modal-overlay.open').forEach(m=>m.classList.remove('open'));});
    </script>
</body>
</html>
