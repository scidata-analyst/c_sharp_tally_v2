@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Data Encryption & Security</title>
    <partial name="_Styles" />
</head>
<body>
    <partial name="_Sidebar" />
    <partial name="_Header" model='@("Security Settings")' />

    <main class="main-content">
        <div class="page active" id="page-security">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Security & Encryption</div>
                    <div class="page-subtitle">Security · Configure system-wide encryption and backup policies</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('settingsModal')"><i class="bi bi-shield-lock"></i> Update Settings</button>
            </div>
            
            <div class="row g-3 mb-4" id="summaryCards"></div>

            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Configuration History</div>
                    <div class="table-actions"><input class="table-search" placeholder="Search settings..." oninput="handleSearch(event)"></div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('Id')" style="cursor:pointer;"># <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('EncryptionType')" style="cursor:pointer;">Encryption Type <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>SSL / 2FA</th>
                            <th>Backup Schedule</th>
                            <th onclick="sortBy('LastBackup')" style="cursor:pointer;">Last Backup <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">Showing <span id="showingStart">0</span> to <span id="showingEnd">0</span> of <span id="totalRecords">0</span> records</div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows:</label>
                        <select id="pageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changePageSize()"><option value="5">5</option><option value="10" selected>10</option><option value="25">25</option><option value="50">50</option></select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="prevBtn" style="padding:6px 12px;" onclick="prevPage()"><i class="bi bi-chevron-left"></i></button>
                            <span id="pageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="nextBtn" style="padding:6px 12px;" onclick="nextPage()"><i class="bi bi-chevron-right"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div class="tally-modal-overlay" id="settingsModal">
        <div class="tally-modal" style="max-width:600px;">
            <div class="modal-header">
                <div class="modal-title" id="modalTitle">Security Configuration</div>
                <div class="modal-close" onclick="closeModal('settingsModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Encryption Type *</label><select class="form-control-tally" id="EncryptionType"><option value="AES-256">AES-256 (Recommended)</option><option value="RSA-4096">RSA-4096</option><option value="ChaCha20">ChaCha20</option></select><div class="field-error" id="error-EncryptionType"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">SSL Configuration</label><select class="form-control-tally" id="Ssl"><option value="TLS 1.3">TLS 1.3</option><option value="TLS 1.2">TLS 1.2</option></select><div class="field-error" id="error-Ssl"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">2FA Policy</label><select class="form-control-tally" id="TwoFactorAuth"><option value="Mandatory">Mandatory</option><option value="Optional">Optional</option><option value="Disabled">Disabled</option></select><div class="field-error" id="error-TwoFactorAuth"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Backup Schedule</label><select class="form-control-tally" id="BackupSchedule"><option value="Daily">Daily</option><option value="Weekly">Weekly</option><option value="Hourly">Hourly</option></select><div class="field-error" id="error-BackupSchedule"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Cloud Backup</label><select class="form-control-tally" id="CloudBackup"><option value="Enabled">Enabled</option><option value="Disabled">Disabled</option></select><div class="field-error" id="error-CloudBackup"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">System Status</label><select class="form-control-tally" id="Status"><option value="Secure">Secure</option><option value="Vulnerable">Vulnerable</option><option value="Updating">Updating</option></select><div class="field-error" id="error-Status"></div></div></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('settingsModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveRecord()"><i class="bi bi-shield-check"></i> Save Settings</button>
            </div>
        </div>
    </div>

    <div class="toast-container" id="toastContainer"></div>
    <partial name="_Scripts" />

    <script>
        let st = { data: [], page: 1, pageSize: 10, totalCount: 0, totalPages: 0, search: '', sortColumn: 'Id', sortDirection: 'desc', hasPreviousPage: false, hasNextPage: false, editingId: null };
        let searchTimer = null;

        function openModal(id, item = null) { const o = document.getElementById(id); if (!o) return; o.classList.add('open'); if (id === 'settingsModal') { clearErrors(); if (item) { st.editingId = item.id; document.getElementById('EncryptionType').value = item.encryptionType||'AES-256'; document.getElementById('Ssl').value = item.ssl||'TLS 1.3'; document.getElementById('TwoFactorAuth').value = item.twoFactorAuth||'Mandatory'; document.getElementById('BackupSchedule').value = item.backupSchedule||'Daily'; document.getElementById('CloudBackup').value = item.cloudBackup||'Enabled'; document.getElementById('Status').value = item.status||'Secure'; } else { st.editingId = null; document.getElementById('EncryptionType').value='AES-256'; document.getElementById('Ssl').value='TLS 1.3'; document.getElementById('TwoFactorAuth').value='Mandatory'; document.getElementById('BackupSchedule').value='Daily'; document.getElementById('CloudBackup').value='Enabled'; document.getElementById('Status').value='Secure'; } } }
        function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }
        function clearErrors() { document.querySelectorAll('.field-error').forEach(el => el.textContent = ''); }
        function showFieldError(f, msg) { const el = document.getElementById('error-' + f); if (el) el.textContent = msg; }

        async function loadData() {
            const params = new URLSearchParams({ page: st.page, pageSize: st.pageSize, search: st.search, sortColumn: st.sortColumn, sortDirection: st.sortDirection });
            try { const r = await fetch(`/SecuritySettings/api/index?${params}`); if (!r.ok) throw new Error(); const d = await r.json(); Object.assign(st, { data: d.data||[], totalCount: d.totalCount||0, totalPages: d.totalPages||0, page: d.page||1, hasPreviousPage: d.hasPreviousPage||false, hasNextPage: d.hasNextPage||false }); renderTable(); renderPagination(); renderSummary(); } catch(e) { showToast('Failed to load','error'); }
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody'); tbody.innerHTML = '';
            if (!st.data.length) { tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text-muted);">No records found</td></tr>'; return; }
            const s = ((st.page-1)*st.pageSize)+1;
            st.data.forEach((item, i) => {
                const sBadge = {'Secure':'badge-success','Vulnerable':'badge-danger','Updating':'badge-warning'};
                const row = document.createElement('tr');
                row.innerHTML = `<td>${s+i}</td><td><span class="badge-tally badge-info">${esc(item.encryptionType)}</span></td><td><small>SSL: ${esc(item.ssl)}<br>2FA: ${esc(item.twoFactorAuth)}</small></td><td>${esc(item.backupSchedule)} (Cloud: ${esc(item.cloudBackup)})</td><td>${new Date(item.lastBackup).toLocaleString()}</td><td><span class="badge-tally ${sBadge[item.status]||'badge-info'}">${esc(item.status)}</span></td><td><button class="btn-tally-edit" onclick="editItem(${item.id})"><i class="bi bi-pencil"></i></button></td>`;
                tbody.appendChild(row);
            });
            document.getElementById('showingStart').textContent = st.totalCount > 0 ? s : 0; document.getElementById('showingEnd').textContent = Math.min(s+st.pageSize-1, st.totalCount); document.getElementById('totalRecords').textContent = st.totalCount;
        }

        function renderSummary() {
            document.getElementById('summaryCards').innerHTML = `<div class="col-md-4"><div class="stat-card" style="--card-accent:var(--success)"><div class="stat-label">Encryption Level</div><div class="stat-value">High</div></div></div><div class="col-md-4"><div class="stat-card" style="--card-accent:var(--primary)"><div class="stat-label">Cloud Sync</div><div class="stat-value">Active</div></div></div><div class="col-md-4"><div class="stat-card" style="--card-accent:var(--accent)"><div class="stat-label">System Health</div><div class="stat-value">Optimal</div></div></div>`;
        }

        function renderPagination() { const el = document.getElementById('pageNumbers'); el.innerHTML = ''; const max=5; let s=Math.max(1,st.page-Math.floor(max/2)); let e=Math.min(st.totalPages,s+max-1); if(e-s<max-1) s=Math.max(1,e-max+1); for(let i=s;i<=e;i++){const b=document.createElement('button');b.className=`btn-tally-outline ${i===st.page?'active':''}`;b.style.cssText='padding:6px 10px;min-width:36px;';b.textContent=i;b.onclick=()=>goToPage(i);el.appendChild(b);} document.getElementById('prevBtn').disabled=!st.hasPreviousPage; document.getElementById('nextBtn').disabled=!st.hasNextPage; }

        function goToPage(p){if(p<1||p>st.totalPages)return;st.page=p;loadData();} function prevPage(){if(st.hasPreviousPage)goToPage(st.page-1);} function nextPage(){if(st.hasNextPage)goToPage(st.page+1);} function changePageSize(){st.pageSize=parseInt(document.getElementById('pageSizeSelect').value);st.page=1;loadData();}
        function sortBy(col){if(st.sortColumn===col)st.sortDirection=st.sortDirection==='asc'?'desc':'asc';else{st.sortColumn=col;st.sortDirection='asc';}st.page=1;loadData();}
        function handleSearch(e){clearTimeout(searchTimer);searchTimer=setTimeout(()=>{st.search=e.target.value.trim();st.page=1;loadData();},500);}

        async function saveRecord(){clearErrors();const fd={encryptionType:document.getElementById('EncryptionType').value,ssl:document.getElementById('Ssl').value,twoFactorAuth:document.getElementById('TwoFactorAuth').value,backupSchedule:document.getElementById('BackupSchedule').value,cloudBackup:document.getElementById('CloudBackup').value,status:document.getElementById('Status').value,lastBackup:new Date().toISOString()};try{const url=st.editingId?`/SecuritySettings/update/${st.editingId}`:`/SecuritySettings/create`;const m=st.editingId?'PUT':'POST';const r=await fetch(url,{method:m,headers:{'Content-Type':'application/json'},body:JSON.stringify(fd)});const d=await r.json();if(!r.ok){if(r.status===400&&d.errors){for(const[f,msgs]of Object.entries(d.errors))showFieldError(f,msgs.join(', '));return;}throw new Error(d.message||'Failed');}closeModal('settingsModal');showToast('Settings saved!','success');loadData();}catch(e){showToast('Save failed: '+e.message,'error');}}

        function editItem(id){const item=st.data.find(i=>i.id===id);if(item)openModal('settingsModal',item);}

        function esc(t){if(!t)return'';const d=document.createElement('div');d.textContent=t;return d.innerHTML;} function showToast(msg,type='success'){const icons={success:'✅',error:'❌',info:'ℹ️'};const c=document.getElementById('toastContainer');if(!c)return;const t=document.createElement('div');t.className=`tally-toast ${type}`;t.innerHTML=`<span style="font-size:16px">${icons[type]}</span><span>${msg}</span>`;c.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(20px)';t.style.transition='0.3s ease';setTimeout(()=>t.remove(),300);},3000);}

        document.addEventListener('DOMContentLoaded',()=>{loadData();document.querySelectorAll('.tally-modal-overlay').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)closeModal(this.id);}));});
    </script>
</body>
</html>



