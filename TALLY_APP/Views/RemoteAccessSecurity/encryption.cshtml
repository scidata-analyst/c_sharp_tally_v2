@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- External CSS -->
    <link rel="stylesheet" href="~/css/styles.css" />
</head>

<body>

        <partial name="_Sidebar" />

    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Data Encryption & Backup</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== DATA ENCRYPTION & BACKUP ===================== -->
        <div class="page active" id="page-encryption">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Data Encryption & Backup</div>
                    <div class="page-subtitle">Manage security settings and data backups</div>
                </div><button class="btn-tally-primary"><i class="bi bi-cloud-upload"></i> Backup Now</button>
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="tally-card">
                        <div class="card-label mb-3">Last Backup</div>
                        <div style="font-size:13px;color:var(--text-muted)">11-03-2026 at 02:00 AM (Auto)</div>
                        <div class="mt-3"><span class="badge-tally badge-success"><i
                                    class="bi bi-shield-check me-1"></i>AES-256
                                Encrypted</span></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="tally-card">
                        <div class="card-label mb-3">Backup Schedule</div>
                        <div class="info-row"><span class="info-key">Daily Auto Backup</span><span
                                class="info-val"><span class="badge-tally badge-success">ON</span></span></div>
                        <div class="info-row"><span class="info-key">Cloud Backup</span><span class="info-val"><span
                                    class="badge-tally badge-success">ON</span></span></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="tally-card">
                        <div class="card-label mb-3">Security</div>
                        <div class="info-row"><span class="info-key">2FA</span><span class="info-val"><span
                                    class="badge-tally badge-success">Enabled</span></span></div>
                        <div class="info-row"><span class="info-key">SSL</span><span class="info-val"><span
                                    class="badge-tally badge-success">Active</span></span></div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // page script same as others, with currentPage = 'encryption'
    </script>
</body>

</html>

