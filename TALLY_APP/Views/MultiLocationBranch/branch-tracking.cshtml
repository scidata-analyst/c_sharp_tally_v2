@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <partial name="_Styles" />
</head>

<body>

        <partial name="_Sidebar" />

    <partial name="_Header" model='@("Stock & Sales Tracking per Branch")' />

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== STOCK & SALES TRACKING PER BRANCH ===================== -->
        <div class="page active" id="page-branch-tracking">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Stock & Sales Tracking per Branch</div>
                    <div class="page-subtitle">Branch-level stock and performance tracking</div>
                </div>
            </div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Branch Performance Matrix</div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th>Branch</th>
                            <th>Opening Stock</th>
                            <th>Received</th>
                            <th>Sold</th>
                            <th>Closing Stock</th>
                            <th>Revenue</th>
                            <th>Target</th>
                            <th>Achieved</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Mumbai HQ</td>
                            <td>₹20L</td>
                            <td class="amount-positive">₹15L</td>
                            <td class="amount-negative">₹16.6L</td>
                            <td>₹18.4L</td>
                            <td class="amount-positive">₹24.1L</td>
                            <td>₹22L</td>
                            <td><span class="badge-tally badge-success">110%</span></td>
                        </tr>
                        <tr>
                            <td>Delhi Branch</td>
                            <td>₹10L</td>
                            <td class="amount-positive">₹6L</td>
                            <td class="amount-negative">₹7.8L</td>
                            <td>₹8.2L</td>
                            <td class="amount-positive">₹12.5L</td>
                            <td>₹14L</td>
                            <td><span class="badge-tally badge-warning">89%</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <partial name="_Scripts" />
    <script>
        // page script same as others, with currentPage = 'branch-tracking'
    </script>
</body>

</html>

