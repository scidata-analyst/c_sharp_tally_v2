@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- External CSS -->
    <link rel="stylesheet" href="~/css/styles.css" />
</head>

<body>

        <partial name="_Sidebar" />

    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Stock & Sales Tracking per Branch</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== STOCK & SALES TRACKING PER BRANCH ===================== -->
        <div class="page active" id="page-branch-tracking">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Stock & Sales Tracking per Branch</div>
                    <div class="page-subtitle">Branch-level stock and performance tracking</div>
                </div>
            </div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Branch Performance Matrix</div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th>Branch</th>
                            <th>Opening Stock</th>
                            <th>Received</th>
                            <th>Sold</th>
                            <th>Closing Stock</th>
                            <th>Revenue</th>
                            <th>Target</th>
                            <th>Achieved</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Mumbai HQ</td>
                            <td>₹20L</td>
                            <td class="amount-positive">₹15L</td>
                            <td class="amount-negative">₹16.6L</td>
                            <td>₹18.4L</td>
                            <td class="amount-positive">₹24.1L</td>
                            <td>₹22L</td>
                            <td><span class="badge-tally badge-success">110%</span></td>
                        </tr>
                        <tr>
                            <td>Delhi Branch</td>
                            <td>₹10L</td>
                            <td class="amount-positive">₹6L</td>
                            <td class="amount-negative">₹7.8L</td>
                            <td>₹8.2L</td>
                            <td class="amount-positive">₹12.5L</td>
                            <td>₹14L</td>
                            <td><span class="badge-tally badge-warning">89%</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // page script same as others, with currentPage = 'branch-tracking'
    </script>
</body>

</html>

