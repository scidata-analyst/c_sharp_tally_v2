@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- External CSS -->
    <link rel="stylesheet" href="~/css/styles.css" />
</head>

<body>

        <partial name="_Sidebar" />

    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Consolidation of Accounts</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== CONSOLIDATION OF ACCOUNTS ===================== -->
        <div class="page active" id="page-consolidation">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Consolidation of Accounts</div>
                    <div class="page-subtitle">Consolidated financial view across all branches</div>
                </div>
            </div>
            <div class="tally-card">
                <div class="card-label mb-3">Consolidated Balance — All Branches</div>
                <div class="info-row"><span class="info-key">Mumbai HQ Revenue</span><span
                        class="info-val amount-positive">₹24,10,000</span></div>
                <div class="info-row"><span class="info-key">Delhi Branch Revenue</span><span
                        class="info-val amount-positive">₹12,50,000</span></div>
                <div class="info-row"><span class="info-key">Bangalore Branch Revenue</span><span
                        class="info-val amount-positive">₹8,20,000</span></div>
                <div class="info-row"><span class="info-key">Chennai Branch Revenue</span><span
                        class="info-val amount-positive">₹3,40,000</span></div>
                <div class="border-sep"></div>
                <div class="info-row"><span class="info-key fw-800">CONSOLIDATED TOTAL</span><span
                        class="info-val fw-800" style="color:var(--primary);font-size:18px;">₹48,20,000</span></div>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // page script same as others, with currentPage = 'consolidation'
    </script>
</body>

</html>

