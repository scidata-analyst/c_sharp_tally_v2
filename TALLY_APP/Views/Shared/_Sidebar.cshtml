@{
    var currentPath = Context.Request.Path.ToString().ToLower();

    string IsActive(string path)
    {
        return currentPath == path.ToLower() || currentPath == path.ToLower() + "/" ? "active" : "";
    }

    string IsParentOpen(params string[] paths)
    {
        foreach (var path in paths)
        {
            if (currentPath.Equals(path.ToLower(), StringComparison.OrdinalIgnoreCase)) return "open";
        }
        return "";
    }
}
