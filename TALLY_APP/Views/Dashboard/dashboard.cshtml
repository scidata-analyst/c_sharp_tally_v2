@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- External CSS -->
    <link rel="stylesheet" href="~/css/styles.css" />
</head>

<body>

        <partial name="_Sidebar" />

    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Dashboard</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== DASHBOARD PAGE ===================== -->
        <div class="page active" id="page-dashboard">
            <!-- Hero -->
            <div class="dashboard-hero">
                <div class="row align-items-center">
                    <div class="col-lg-7">
                        <div class="hero-greeting">Good Morning, Admin</div>
                        <div class="hero-title">Financial Overview<br><span style="color:var(--primary)">FY
                                2024-25</span></div>
                        <div class="hero-date"><i class="bi bi-calendar3 me-1"></i>Wednesday, March 11, 2026 · Q4 Review
                            Period
                        </div>
                        <div class="hero-stats-row">
                            <div class="hero-stat">
                                <div class="hero-stat-label">Net Revenue</div>
                                <div class="hero-stat-val" style="color:var(--primary)">₹48.2L</div>
                            </div>
                            <div class="hero-stat">
                                <div class="hero-stat-label">Expenses</div>
                                <div class="hero-stat-val" style="color:var(--danger)">₹31.4L</div>
                            </div>
                            <div class="hero-stat">
                                <div class="hero-stat-label">Net Profit</div>
                                <div class="hero-stat-val" style="color:var(--accent)">₹16.8L</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-5 d-none d-lg-block text-end">
                        <div style="font-size:80px;opacity:0.1;filter:blur(1px)">📊</div>
                    </div>
                </div>
            </div>

            <!-- KPI Row -->
            <div class="row g-3 mb-4 dashboard-kpi-row">
                <div class="col-xl-3 col-md-6">
                    <div class="stat-card" style="--card-accent:var(--primary); --card-icon-bg:var(--primary-glow)">
                        <div class="stat-icon">💳</div>
                        <div class="stat-label">Total Receivable</div>
                        <div class="stat-value">₹12.4L</div>
                        <div class="stat-change up"><i class="bi bi-arrow-up-short"></i>+8.3% vs last month</div>
                        <div class="mini-chart" style="margin-top:10px;">
                            <div class="mini-bar" style="height:40%"></div>
                            <div class="mini-bar" style="height:60%"></div>
                            <div class="mini-bar" style="height:45%"></div>
                            <div class="mini-bar" style="height:80%"></div>
                            <div class="mini-bar" style="height:65%"></div>
                            <div class="mini-bar" style="height:90%"></div>
                            <div class="mini-bar" style="height:75%"></div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="stat-card" style="--card-accent:var(--danger); --card-icon-bg:rgba(255,82,82,0.15)">
                        <div class="stat-icon">📤</div>
                        <div class="stat-label">Total Payable</div>
                        <div class="stat-value">₹7.8L</div>
                        <div class="stat-change down"><i class="bi bi-arrow-down-short"></i>-2.1% vs last month</div>
                        <div class="mini-chart">
                            <div class="mini-bar accent" style="height:60%"></div>
                            <div class="mini-bar accent" style="height:40%"></div>
                            <div class="mini-bar accent" style="height:70%"></div>
                            <div class="mini-bar accent" style="height:50%"></div>
                            <div class="mini-bar accent" style="height:80%"></div>
                            <div class="mini-bar accent" style="height:60%"></div>
                            <div class="mini-bar accent" style="height:45%"></div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="stat-card" style="--card-accent:var(--accent); --card-icon-bg:rgba(245,166,35,0.12)">
                        <div class="stat-icon">📦</div>
                        <div class="stat-label">Stock Value</div>
                        <div class="stat-value">₹34.2L</div>
                        <div class="stat-change up"><i class="bi bi-arrow-up-short"></i>+12% vs last month</div>
                        <div class="mini-chart">
                            <div class="mini-bar" style="height:55%;background:rgba(245,166,35,0.2)"></div>
                            <div class="mini-bar" style="height:70%;background:rgba(245,166,35,0.2)"></div>
                            <div class="mini-bar" style="height:50%;background:rgba(245,166,35,0.2)"></div>
                            <div class="mini-bar" style="height:85%;background:rgba(245,166,35,0.2)"></div>
                            <div class="mini-bar" style="height:65%;background:rgba(245,166,35,0.2)"></div>
                            <div class="mini-bar" style="height:90%;background:rgba(245,166,35,0.2)"></div>
                            <div class="mini-bar" style="height:75%;background:rgba(245,166,35,0.2)"></div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="stat-card" style="--card-accent:var(--accent2); --card-icon-bg:rgba(108,99,255,0.15)">
                        <div class="stat-icon">💼</div>
                        <div class="stat-label">GST Liability</div>
                        <div class="stat-value">₹3.6L</div>
                        <div class="stat-change up"><i class="bi bi-arrow-up-short"></i>+4.7% this quarter</div>
                        <div class="mini-chart">
                            <div class="mini-bar" style="height:30%;background:rgba(108,99,255,0.2)"></div>
                            <div class="mini-bar" style="height:50%;background:rgba(108,99,255,0.2)"></div>
                            <div class="mini-bar" style="height:40%;background:rgba(108,99,255,0.2)"></div>
                            <div class="mini-bar" style="height:70%;background:rgba(108,99,255,0.2)"></div>
                            <div class="mini-bar" style="height:55%;background:rgba(108,99,255,0.2)"></div>
                            <div class="mini-bar" style="height:85%;background:rgba(108,99,255,0.2)"></div>
                            <div class="mini-bar" style="height:65%;background:rgba(108,99,255,0.2)"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Module Overview -->
            <div class="tally-card mb-4">
                <div class="card-header-row">
                    <div class="card-label">All Modules</div>
                    <span class="badge-tally badge-success">9 Active</span>
                </div>
                <div class="row g-3">
                    <div class="col-xl-4 col-md-6">
                        <div class="module-card" onclick="window.location.href='ledger.html'"
                            style="--card-accent:#00C896;--card-icon-bg:rgba(0,200,150,0.12)">
                            <div class="module-count">6 Sub-modules</div>
                            <div class="module-icon">🧾</div>
                            <h5>Accounting & Finance</h5>
                            <p>Ledger, vouchers, payables, receivables, multi-currency</p>
                        </div>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <div class="module-card" onclick="window.location.href='stock-items.html'"
                            style="--card-accent:#F5A623;--card-icon-bg:rgba(245,166,35,0.12)">
                            <div class="module-count">5 Sub-modules</div>
                            <div class="module-icon">📦</div>
                            <h5>Inventory Management</h5>
                            <p>Stock items, batches, serial tracking, godowns</p>
                        </div>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <div class="module-card" onclick="window.location.href='gst-calc.html'"
                            style="--card-accent:#6C63FF;--card-icon-bg:rgba(108,99,255,0.12)">
                            <div class="module-count">4 Sub-modules</div>
                            <div class="module-icon">💰</div>
                            <h5>GST & Taxation</h5>
                            <p>GST filing, GSTR1/2/3B reports, TDS/TCS</p>
                        </div>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <div class="module-card" onclick="window.location.href='employees.html'"
                            style="--card-accent:#29B6F6;--card-icon-bg:rgba(41,182,246,0.12)">
                            <div class="module-count">4 Sub-modules</div>
                            <div class="module-icon">👥</div>
                            <h5>Payroll Management</h5>
                            <p>Employees, payslips, PF/ESI/TDS deductions</p>
                        </div>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <div class="module-card" onclick="window.location.href='payments.html'"
                            style="--card-accent:#FF5252;--card-icon-bg:rgba(255,82,82,0.12)">
                            <div class="module-count">4 Sub-modules</div>
                            <div class="module-icon">🏦</div>
                            <h5>Banking & Payments</h5>
                            <p>Cheques, online transfers, reconciliation</p>
                        </div>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <div class="module-card" onclick="window.location.href='trial-balance.html'"
                            style="--card-accent:#FFB300;--card-icon-bg:rgba(255,179,0,0.12)">
                            <div class="module-count">4 Sub-modules</div>
                            <div class="module-icon">📊</div>
                            <h5>Reporting & Analytics</h5>
                            <p>Trial balance, P&L, cash flow, stock reports</p>
                        </div>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <div class="module-card" onclick="window.location.href='branches.html'"
                            style="--card-accent:#00BCD4;--card-icon-bg:rgba(0,188,212,0.12)">
                            <div class="module-count">3 Sub-modules</div>
                            <div class="module-icon">🌍</div>
                            <h5>Multi-location / Branch</h5>
                            <p>Branch accounting, consolidation, tracking</p>
                        </div>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <div class="module-card" onclick="window.location.href='user-access.html'"
                            style="--card-accent:#E91E63;--card-icon-bg:rgba(233,30,99,0.12)">
                            <div class="module-count">3 Sub-modules</div>
                            <div class="module-icon">🔒</div>
                            <h5>Remote Access & Security</h5>
                            <p>User roles, encryption, audit trails</p>
                        </div>
                    </div>
                    <div class="col-xl-4 col-md-6">
                        <div class="module-card" onclick="window.location.href='automation.html'"
                            style="--card-accent:#9C27B0;--card-icon-bg:rgba(156,39,176,0.12)">
                            <div class="module-count">4 Sub-modules</div>
                            <div class="module-icon">⚙️</div>
                            <h5>Additional Features</h5>
                            <p>Automation, budgeting, custom reports</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="row g-3">
                <div class="col-lg-6">
                    <div class="tally-card">
                        <div class="card-header-row">
                            <div class="card-label">Recent Transactions</div>
                            <button class="btn-tally-outline" style="font-size:11px;padding:5px 10px;">View All</button>
                        </div>
                        <div class="activity-item">
                            <div class="activity-dot" style="background:var(--primary)"></div>
                            <div class="activity-content">
                                <div class="activity-text"><strong>Payment Voucher #PV-2024-891</strong> recorded
                                    against Supplier ABC
                                </div>
                                <div class="activity-time">2 min ago · ₹45,000</div>
                            </div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-dot" style="background:var(--accent2)"></div>
                            <div class="activity-content">
                                <div class="activity-text"><strong>Sales Invoice #SI-2024-3421</strong> created for
                                    Client XYZ</div>
                                <div class="activity-time">18 min ago · ₹1,20,000</div>
                            </div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-dot" style="background:var(--accent)"></div>
                            <div class="activity-content">
                                <div class="activity-text"><strong>Stock Transfer</strong> from Main Godown → Delhi
                                    Branch</div>
                                <div class="activity-time">1 hour ago · 150 units</div>
                            </div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-dot" style="background:var(--danger)"></div>
                            <div class="activity-content">
                                <div class="activity-text"><strong>GST GSTR-3B</strong> filed for January 2025</div>
                                <div class="activity-time">3 hours ago · ₹3,62,100</div>
                            </div>
                        </div>
                        <div class="activity-item">
                            <div class="activity-dot" style="background:var(--info)"></div>
                            <div class="activity-content">
                                <div class="activity-text"><strong>Payroll Processed</strong> for 34 employees —
                                    February</div>
                                <div class="activity-time">5 hours ago · ₹8,40,000</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="tally-card">
                        <div class="card-header-row">
                            <div class="card-label">Cash & Bank Summary</div>
                            <span class="badge-tally badge-success">Live</span>
                        </div>
                        <div class="info-row"><span class="info-key">HDFC Bank — Current A/c</span><span
                                class="info-val amount-positive">₹18,42,300</span></div>
                        <div class="info-row"><span class="info-key">ICICI Bank — Savings A/c</span><span
                                class="info-val amount-positive">₹6,10,000</span></div>
                        <div class="info-row"><span class="info-key">SBI Bank — OD Account</span><span
                                class="info-val amount-negative">-₹2,50,000</span></div>
                        <div class="info-row"><span class="info-key">Petty Cash — Mumbai HQ</span><span
                                class="info-val amount-positive">₹45,200</span></div>
                        <div class="info-row"><span class="info-key">Petty Cash — Delhi Branch</span><span
                                class="info-val amount-positive">₹28,600</span></div>
                        <div class="border-sep"></div>
                        <div class="info-row"><span class="info-key"
                                style="font-weight:700;color:var(--text-primary)">Total Cash &
                                Bank</span><span class="info-val"
                                style="font-size:16px;color:var(--primary)">₹22,76,100</span></div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- ===================== MODALS ===================== -->

    <!-- Ledger Modal -->
    <div class="tally-modal-overlay" id="ledgerModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title" id="ledgerModalTitle">Create New Ledger</div>
                <div class="modal-close" onclick="closeModal('ledgerModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="form-group"><label class="form-label">Ledger Name *</label><input type="text"
                                class="form-control-tally" placeholder="e.g. HDFC Bank Account" id="ledgerName"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Ledger Code</label><input type="text"
                                class="form-control-tally" placeholder="e.g. 001"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Under Group *</label><select
                                class="form-control-tally">
                                <option>Cash-in-Hand</option>
                                <option>Bank Accounts</option>
                                <option>Sundry Debtors</option>
                                <option>Sundry Creditors</option>
                                <option>Sales Accounts</option>
                                <option>Purchase Accounts</option>
                                <option>Duties & Taxes</option>
                                <option>Fixed Assets</option>
                                <option>Investments</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Account Type *</label><select
                                class="form-control-tally">
                                <option>Asset</option>
                                <option>Liability</option>
                                <option>Revenue</option>
                                <option>Expense</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Opening Balance</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Balance Type</label><select
                                class="form-control-tally">
                                <option>Debit (Dr)</option>
                                <option>Credit (Cr)</option>
                            </select></div>
                    </div>
                    <div class="col-12">
                        <div class="form-group"><label class="form-label">Description / Notes</label><textarea
                                class="form-control-tally" rows="2" placeholder="Optional description..."></textarea>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Currency</label><select
                                class="form-control-tally">
                                <option>INR — Indian Rupee</option>
                                <option>USD — US Dollar</option>
                                <option>EUR — Euro</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Status</label><select
                                class="form-control-tally">
                                <option>Active</option>
                                <option>Inactive</option>
                            </select></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('ledgerModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveLedger()"><i class="bi bi-check-lg"></i> Save
                    Ledger</button>
            </div>
        </div>
    </div>

    <!-- Voucher Modal -->
    <div class="tally-modal-overlay" id="voucherModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Create Voucher</div>
                <div class="modal-close" onclick="closeModal('voucherModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Voucher Type *</label><select
                                class="form-control-tally">
                                <option>Payment</option>
                                <option>Receipt</option>
                                <option>Journal</option>
                                <option>Contra</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Voucher Date *</label><input type="date"
                                class="form-control-tally"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Party / Account *</label><input type="text"
                                class="form-control-tally" placeholder="Select or type party name"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Amount *</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Payment Mode</label><select
                                class="form-control-tally">
                                <option>Cash</option>
                                <option>Bank Transfer</option>
                                <option>Cheque</option>
                                <option>UPI</option>
                                <option>NEFT/RTGS</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Reference No.</label><input type="text"
                                class="form-control-tally" placeholder="Cheque / UTR / Ref No."></div>
                    </div>
                    <div class="col-12">
                        <div class="form-group"><label class="form-label">Narration</label><textarea
                                class="form-control-tally" rows="2"
                                placeholder="Brief description of this voucher..."></textarea></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('voucherModal')">Cancel</button>
                <button class="btn-tally-outline" onclick="showToast('Saved as Draft','info')"><i
                        class="bi bi-file-earmark"></i> Save Draft</button>
                <button class="btn-tally-primary"
                    onclick="closeModal('voucherModal');showToast('Voucher created successfully!','success')"><i
                        class="bi bi-check-lg"></i> Post Voucher</button>
            </div>
        </div>
    </div>

    <!-- Stock Item Modal -->
    <div class="tally-modal-overlay" id="stockModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Add Stock Item</div>
                <div class="modal-close" onclick="closeModal('stockModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="form-group"><label class="form-label">Item Name *</label><input type="text"
                                class="form-control-tally" placeholder="e.g. Steel Pipe 2 inch"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Item Code</label><input type="text"
                                class="form-control-tally" placeholder="ITM-001"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Category *</label><select
                                class="form-control-tally">
                                <option>Electrical</option>
                                <option>Pipes & Fittings</option>
                                <option>Building Materials</option>
                                <option>Electronics</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Unit of Measure *</label><select
                                class="form-control-tally">
                                <option>Pcs</option>
                                <option>Kg</option>
                                <option>Litre</option>
                                <option>Roll</option>
                                <option>Bag</option>
                                <option>Box</option>
                            </select></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Opening Qty</label><input type="number"
