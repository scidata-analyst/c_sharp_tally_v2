@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <partial name="_Styles" />
</head>
<body>
    <partial name="_Sidebar" />
    <partial name="_Header" model='@("Dashboard")' />

    <main class="main-content">
        <div class="page active" id="page-dashboard">
            <!-- Hero -->
            <div class="dashboard-hero">
                <div class="row align-items-center">
                    <div class="col-lg-7">
                        <div class="hero-greeting" id="greeting">Good Morning, Admin</div>
                        <div class="hero-title">Financial Overview<br><span style="color:var(--primary)">FY 2024-25</span></div>
                        <div class="hero-date"><i class="bi bi-calendar3 me-1"></i> <span id="currentDate"></span> · Q4 Review Period</div>
                        <div class="hero-stats-row">
                            <div class="hero-stat"><div class="hero-stat-label">Net Revenue</div><div class="hero-stat-val" id="netRevenue" style="color:var(--primary)">₹0</div></div>
                            <div class="hero-stat"><div class="hero-stat-label">Expenses</div><div class="hero-stat-val" id="expenses" style="color:var(--danger)">₹0</div></div>
                            <div class="hero-stat"><div class="hero-stat-label">Net Profit</div><div class="hero-stat-val" id="netProfit" style="color:var(--accent)">₹0</div></div>
                        </div>
                    </div>
                    <div class="col-lg-5 d-none d-lg-block text-end">
                        <div style="font-size:80px;opacity:0.1;filter:blur(1px)">📊</div>
                    </div>
                </div>
            </div>

            <!-- KPI Row -->
            <div class="row g-3 mb-4 dashboard-kpi-row">
                <div class="col-xl-3 col-md-6">
                    <div class="stat-card" style="--card-accent:var(--primary); --card-icon-bg:var(--primary-glow)">
                        <div class="stat-icon">💳</div><div class="stat-label">Total Receivable</div><div class="stat-value" id="kpiReceivable">₹0</div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="stat-card" style="--card-accent:var(--danger); --card-icon-bg:rgba(255,82,82,0.15)">
                        <div class="stat-icon">📤</div><div class="stat-label">Total Payable</div><div class="stat-value" id="kpiPayable">₹0</div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="stat-card" style="--card-accent:var(--accent); --card-icon-bg:rgba(245,166,35,0.12)">
                        <div class="stat-icon">📦</div><div class="stat-label">Stock Value</div><div class="stat-value" id="kpiStock">₹0</div>
                    </div>
                </div>
                <div class="col-xl-3 col-md-6">
                    <div class="stat-card" style="--card-accent:var(--accent2); --card-icon-bg:rgba(108,99,255,0.15)">
                        <div class="stat-icon">💼</div><div class="stat-label">GST Liability</div><div class="stat-value" id="kpiGst">₹0</div>
                    </div>
                </div>
            </div>

            <!-- Module Overview -->
            <div class="tally-card mb-4">
                <div class="card-header-row"><div class="card-label">All Modules</div><span class="badge-tally badge-success">9 Active</span></div>
                <div class="row g-3">
                    <div class="col-xl-4 col-md-6"><div class="module-card" onclick="location.href='/Voucher'" style="--card-accent:#00C896;--card-icon-bg:rgba(0,200,150,0.12)"><div class="module-icon">🧾</div><h5>Accounting & Finance</h5><p>Ledger, vouchers, payables, receivables</p></div></div>
                    <div class="col-xl-4 col-md-6"><div class="module-card" onclick="location.href='/StockReport'" style="--card-accent:#F5A623;--card-icon-bg:rgba(245,166,35,0.12)"><div class="module-icon">📦</div><h5>Inventory Management</h5><p>Stock items, batches, godowns</p></div></div>
                    <div class="col-xl-4 col-md-6"><div class="module-card" onclick="location.href='/GSTReturn'" style="--card-accent:#6C63FF;--card-icon-bg:rgba(108,99,255,0.12)"><div class="module-icon">💰</div><h5>GST & Taxation</h5><p>GST filing, GSTR reports, TDS</p></div></div>
                </div>
            </div>

            <!-- Activity & Bank -->
            <div class="row g-3">
                <div class="col-lg-6">
                    <div class="tally-card" id="activityCard">
                        <div class="card-header-row"><div class="card-label">Recent Transactions</div></div>
                        <div id="activityList"></div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="tally-card">
                        <div class="card-header-row"><div class="card-label">Cash & Bank Summary</div><span class="badge-tally badge-success">Live</span></div>
                        <div id="bankList"></div>
                        <div class="border-sep"></div>
                        <div class="info-row"><span class="info-key" style="font-weight:700;color:var(--text-primary)">Total Cash & Bank</span><span class="info-val" id="totalBank" style="font-size:16px;color:var(--primary)">₹0</span></div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <partial name="_Scripts" />
    <script>
        async function loadDashboard() {
            document.getElementById('currentDate').textContent = new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
            try {
                const r = await fetch('/Dashboard/api/summary');
                const d = await r.json();
                
                document.getElementById('netRevenue').textContent = '₹' + (d.netRevenue/100000).toFixed(1) + 'L';
                document.getElementById('expenses').textContent = '₹' + (d.expenses/100000).toFixed(1) + 'L';
                document.getElementById('netProfit').textContent = '₹' + (d.netProfit/100000).toFixed(1) + 'L';
                
                document.getElementById('kpiReceivable').textContent = '₹' + (d.totalReceivable/100000).toFixed(1) + 'L';
                document.getElementById('kpiPayable').textContent = '₹' + (d.totalPayable/100000).toFixed(1) + 'L';
                document.getElementById('kpiStock').textContent = '₹' + (d.stockValue/100000).toFixed(1) + 'L';
                document.getElementById('kpiGst').textContent = '₹' + (d.gstLiability/100000).toFixed(1) + 'L';
                
                const alist = document.getElementById('activityList'); alist.innerHTML = '';
                d.recentActivities.forEach(a => {
                    alist.innerHTML += `<div class="activity-item"><div class="activity-dot" style="background:var(--${a.type})"></div><div class="activity-content"><div class="activity-text"><strong>${a.title}</strong> ${a.description}</div><div class="activity-time">${a.timeAgo} · ${a.amount}</div></div></div>`;
                });
                
                const blist = document.getElementById('bankList'); blist.innerHTML = '';
                let total = 0;
                d.bankBalances.forEach(b => {
                    total += b.balance;
                    blist.innerHTML += `<div class="info-row"><span class="info-key">${b.bankName}</span><span class="info-val ${b.isPositive?'amount-positive':'amount-negative'}">₹${b.balance.toLocaleString()}</span></div>`;
                });
                document.getElementById('totalBank').textContent = '₹' + total.toLocaleString();
            } catch(e) { console.error('Dashboard failed to load', e); }
        }
        document.addEventListener('DOMContentLoaded', loadDashboard);
    </script>
</body>
</html>
