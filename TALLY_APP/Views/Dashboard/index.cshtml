  <!-- Toast Container -->
  <div class="toast-container" id="toastContainer"></div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // ============================================================
    // STATE
    // ============================================================
    let currentPage = 'dashboard';
    let ledgerData = [];
    let deleteTarget = null;

    // ============================================================
    // PAGE NAVIGATION
    // ============================================================
    const pageTitles = {
      'dashboard': 'Dashboard',
      'ledger': 'Ledger Management',
      'voucher': 'Voucher Entry',
      'payable': 'Accounts Payable & Receivable',
      'bank-recon': 'Bank Reconciliation',
      'bank-recon2': 'Bank Reconciliation',
      'cash-bank': 'Cash & Bank Management',
      'multicurrency': 'Multi-currency Support',
      'stock-items': 'Stock Items & Categories',
      'stock-groups': 'Stock Groups & Valuation',
      'batch-tracking': 'Batch / Expiry / Serial',
      'stock-movement': 'Stock In/Out & Transfer',
      'godown': 'Godown / Warehouse',
      'gst-calc': 'GST Calculation & Filing',
      'vat-service': 'VAT / Service Tax',
      'tax-reports': 'Tax Reports',
      'tds-tcs': 'TDS / TCS Management',
      'employees': 'Employee Management',
      'payroll-calc': 'Payroll Calculation',
      'payslip': 'Payslip Generation',
      'deductions': 'PF / ESI / TDS',
      'payments': 'Cheque / Online Payments',
      'reminders': 'Payment Reminders',
      'banking-integration': 'Banking Integration',
      'trial-balance': 'Trial Balance / BS / P&L',
      'cashflow': 'Cash Flow Statements',
      'stock-reports': 'Stock & Inventory Reports',
      'sales-purchase': 'Sales & Purchase Summary',
      'branches': 'Branch Accounting',
      'consolidation': 'Consolidation of Accounts',
      'branch-tracking': 'Stock & Sales per Branch',
      'user-access': 'User Access Control',
      'encryption': 'Data Encryption & Backup',
      'audit': 'Audit Trails & Logs',
      'automation': 'Voucher Automation',
      'budget': 'Budgeting & Cost Centers',
      'multi-curr-tx': 'Multi-currency Transactions',
      'custom-reports': 'Custom Reports',
    };

    function showPage(pageId) {
      // Hide all pages
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      // Show target
      const target = document.getElementById('page-' + pageId);
      if (target) {
        target.classList.add('active');
        currentPage = pageId;
        document.getElementById('breadcrumbCurrent').textContent = pageTitles[pageId] || pageId;
        // Update active nav links
        document.querySelectorAll('.nav-link, .nav-sublink').forEach(l => l.classList.remove('active'));
      }
      // Scroll to top
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function toggleNav(navId) {
      const item = document.getElementById(navId);
      if (!item) return;
      const isOpen = item.classList.contains('open');
      // Close all others
      document.querySelectorAll('.nav-item.open').forEach(i => {
        if (i.id !== navId) i.classList.remove('open');
      });
      item.classList.toggle('open', !isOpen);
    }

    // ============================================================
    // MODAL MANAGEMENT
    // ============================================================
    function openModal(modalId, title) {
      const overlay = document.getElementById(modalId);
      if (overlay) {
        overlay.classList.add('open');
        if (title) {
          const titleEl = document.getElementById(modalId + 'Title');
          if (titleEl) titleEl.textContent = 'Add ' + title;
        }
      }
    }

    function closeModal(modalId) {
      const overlay = document.getElementById(modalId);
      if (overlay) overlay.classList.remove('open');
    }

    // Close on overlay click
    document.querySelectorAll('.tally-modal-overlay').forEach(overlay => {
      overlay.addEventListener('click', function (e) {
        if (e.target === this) closeModal(this.id);
      });
    });

    // ============================================================
    // LEDGER CRUD
    // ============================================================
    function saveLedger() {
      const name = document.getElementById('ledgerName').value.trim();
      if (!name) { showToast('Ledger name is required!', 'error'); return; }
      const ledger = {
        id: Date.now(),
        name: name,
        date: new Date().toLocaleDateString('en-IN')
      };
      ledgerData.push(ledger);
      closeModal('ledgerModal');
      showToast('Ledger "' + name + '" created!', 'success');
      document.getElementById('ledgerName').value = '';
    }

    function editLedger(id) {
      document.getElementById('ledgerModalTitle').textContent = 'Edit Ledger';
      openModal('ledgerModal');
    }

    function deleteLedger(id) {
      deleteTarget = { type: 'ledger', id: id };
      openModal('deleteModal');
    }

    function confirmDelete() {
      closeModal('deleteModal');
      showToast('Record deleted successfully', 'info');
      deleteTarget = null;
    }

    // ============================================================
    // VOUCHER TYPE SELECTION
    // ============================================================
    function selectVoucherType(btn, type) {
      document.querySelectorAll('.voucher-type-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    }

    // ============================================================
    // TAB SWITCHING
    // ============================================================
    function switchTab(btn, contentId) {
      // Find sibling tabs
      const tabs = btn.closest('.tally-tabs');
      if (tabs) tabs.querySelectorAll('.tally-tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');

      // Find sibling content divs — we look for the next div after tabs
      const page = btn.closest('.page');
      const allTabContents = page.querySelectorAll('[id^="tab-"],[id^="rpt-"]');
      allTabContents.forEach(c => c.style.display = 'none');
      const target = document.getElementById(contentId);
      if (target) target.style.display = 'block';
    }

    // ============================================================
    // TOAST NOTIFICATIONS
    // ============================================================
    function showToast(message, type = 'success') {
      const icons = { success: '✅', error: '❌', info: 'ℹ️' };
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = `tally-toast ${type}`;
      toast.innerHTML = `<span style="font-size:16px">${icons[type]}</span><span>${message}</span>`;
      container.appendChild(toast);
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translateX(20px)';
        toast.style.transition = '0.3s ease';
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    // ============================================================
    // MODULE SEARCH
    // ============================================================
    document.getElementById('moduleSearch').addEventListener('input', function () {
      const q = this.value.toLowerCase();
      document.querySelectorAll('.nav-sublink').forEach(link => {
        const text = link.textContent.toLowerCase();
        const item = link.closest('.nav-item');
        if (q && text.includes(q)) {
          link.style.display = 'flex';
          if (item) item.classList.add('open');
          link.style.background = 'rgba(0,200,150,0.1)';
          link.style.color = 'var(--primary)';
        } else if (!q) {
          link.style.display = '';
          link.style.background = '';
          link.style.color = '';
        } else {
          link.style.display = 'none';
        }
      });
      if (!q) {
        document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('open'));
      }
    });

    // ============================================================
    // TABLE SEARCH
    // ============================================================
    document.querySelectorAll('.table-search').forEach(input => {
      input.addEventListener('input', function () {
        const q = this.value.toLowerCase();
        const table = this.closest('.data-table-wrapper').querySelector('.tally-table');
        if (!table) return;
        table.querySelectorAll('tbody tr').forEach(row => {
          row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
      });
    });

    // ============================================================
    // FULLSCREEN
    // ============================================================
    document.querySelector('[title="Full Screen"]').addEventListener('click', function () {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen();
        this.querySelector('i').className = 'bi bi-fullscreen-exit';
      } else {
        document.exitFullscreen();
        this.querySelector('i').className = 'bi bi-fullscreen';
      }
    });

    // ============================================================
    // KEYBOARD SHORTCUTS
    // ============================================================
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.tally-modal-overlay.open').forEach(m => m.classList.remove('open'));
      }
      if (e.ctrlKey && e.key === 'l') { e.preventDefault(); showPage('ledger'); }
      if (e.ctrlKey && e.key === 'v') { e.preventDefault(); showPage('voucher'); openModal('voucherModal'); }
    });

    // ============================================================
    // INIT
    // ============================================================
    document.addEventListener('DOMContentLoaded', function () {
      showToast('Welcome to TallyPro Enterprise! 🚀', 'info');

      // Set today's date in date inputs
      const today = new Date().toISOString().split('T')[0];
      document.querySelectorAll('input[type=date]').forEach(input => { if (!input.value) input.value = today; });
    });
  </script>
</body>

</html>