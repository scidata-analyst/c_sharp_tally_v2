@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- External CSS -->
    <link rel="stylesheet" href="~/css/styles.css" />
</head>

<body>

    <!-- ===== SIDEBAR ===== -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-logo">T</div>
            <div class="brand-text">
                <h1>TallyPro</h1>
                <span>v3.1 Enterprise</span>
            </div>
        </div>

        <div class="sidebar-search position-relative">
            <i class="bi bi-search search-icon"></i>
            <input type="text" placeholder="Search modules..." id="moduleSearch" />
        </div>

        <nav class="sidebar-nav" id="sidebarNav">

            <!-- Dashboard -->
            <div class="nav-section-label">Main</div>
            <div class="nav-item">
                <div class="nav-link" onclick="window.location.href='dashboard.html'">
                    <span class="nav-icon">🏠</span>
                    <span class="nav-label">Dashboard</span>
                </div>
            </div>

            <!-- 1. Accounting & Finance -->
            <div class="nav-section-label">Core Modules</div>
            <div class="nav-item" id="nav-accounting">
                <div class="nav-link" onclick="toggleNav('nav-accounting')">
                    <span class="nav-icon">🧾</span>
                    <span class="nav-label">Accounting & Finance</span>
                    <span class="nav-arrow"><i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="nav-submenu">
                    <div class="nav-sublink" onclick="window.location.href='cash-bank.html'"><span
                            class="sub-dot"></span>Cash & Bank Management</div>
                    <div class="nav-sublink" onclick="window.location.href='multicurrency.html'"><span
                            class="sub-dot"></span>Multi-currency Support</div>
                </div>
            </div>

            <!-- 2. Inventory -->
            <div class="nav-item" id="nav-inventory">
                <div class="nav-link" onclick="toggleNav('nav-inventory')">
                    <span class="nav-icon">📦</span>
                    <span class="nav-label">Inventory Management</span>
                    <span class="nav-arrow"><i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="nav-submenu">
                    <div class="nav-sublink" onclick="window.location.href='stock-items.html'"><span
                            class="sub-dot"></span>Stock Items &
                        Categories</div>
                    <div class="nav-sublink" onclick="window.location.href='stock-groups.html'"><span
                            class="sub-dot"></span>Stock Groups &
                        Valuation</div>
                    <div class="nav-sublink" onclick="window.location.href='batch-tracking.html'"><span
                            class="sub-dot"></span>Batch / Expiry / Serial</div>
                    <div class="nav-sublink" onclick="window.location.href='stock-movement.html'"><span
                            class="sub-dot"></span>Stock In/Out &
                        Transfer</div>
                    <div class="nav-sublink" onclick="window.location.href='godown.html'"><span
                            class="sub-dot"></span>Godown / Warehouse</div>
                </div>
            </div>

            <!-- 3. GST -->
            <div class="nav-item" id="nav-gst">
                <div class="nav-link" onclick="toggleNav('nav-gst')">
                    <span class="nav-icon">💰</span>
                    <span class="nav-label">GST & Taxation</span>
                    <span class="nav-arrow"><i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="nav-submenu">
                    <div class="nav-sublink" onclick="window.location.href='gst-calc.html'"><span
                            class="sub-dot"></span>GST Calculation & Filing
                    </div>
                    <div class="nav-sublink" onclick="window.location.href='vat-service.html'"><span
                            class="sub-dot"></span>VAT / Service Tax</div>
                    <div class="nav-sublink" onclick="window.location.href='tax-reports.html'"><span
                            class="sub-dot"></span>Tax Reports (GSTR1/2/3B)</div>
                    <div class="nav-sublink" onclick="window.location.href='tds-tcs.html'"><span
                            class="sub-dot"></span>TDS / TCS Management</div>
                </div>
            </div>

            <!-- 4. Payroll -->
            <div class="nav-item" id="nav-payroll">
                <div class="nav-link" onclick="toggleNav('nav-payroll')">
                    <span class="nav-icon">👥</span>
                    <span class="nav-label">Payroll Management</span>
                    <span class="nav-arrow"><i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="nav-submenu">
                    <div class="nav-sublink" onclick="window.location.href='employees.html'"><span
                            class="sub-dot"></span>Employee Info & Salary
                        Structure</div>
                    <div class="nav-sublink" onclick="window.location.href='payroll-calc.html'"><span
                            class="sub-dot"></span>Payroll Calculation</div>
                    <div class="nav-sublink" onclick="window.location.href='payslip.html'"><span
                            class="sub-dot"></span>Payslip Generation</div>
                    <div class="nav-sublink" onclick="window.location.href='deductions.html'"><span
                            class="sub-dot"></span>PF / ESI / TDS Deductions</div>
                </div>
            </div>

            <!-- 5. Banking -->
            <div class="nav-item open" id="nav-banking">
                <div class="nav-link" onclick="toggleNav('nav-banking')">
                    <span class="nav-icon">🏦</span>
                    <span class="nav-label">Banking & Payments</span>
                    <span class="nav-arrow"><i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="nav-submenu">
                    <div class="nav-sublink" onclick="window.location.href='payments.html'"><span
                            class="sub-dot"></span>Cheque / Online Payments</div>
                    <div class="nav-sublink" onclick="window.location.href='reminders.html'"><span
                            class="sub-dot"></span>Payment Reminders</div>
                    <div class="nav-sublink active"><span class="sub-dot"></span>Online Banking Integration</div>
                </div>
            </div>

            <!-- 6. Reports -->
            <div class="nav-item" id="nav-reports">
                <div class="nav-link" onclick="toggleNav('nav-reports')">
                    <span class="nav-icon">📊</span>
                    <span class="nav-label">Reporting & Analytics</span>
                    <span class="nav-arrow"><i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="nav-submenu">
                    <div class="nav-sublink" onclick="window.location.href='trial-balance.html'"><span
                            class="sub-dot"></span>Trial Balance / B.Sheet / P&L</div>
                    <div class="nav-sublink" onclick="window.location.href='cashflow.html'"><span
                            class="sub-dot"></span>Cash Flow Statements
                    </div>
                    <div class="nav-sublink" onclick="window.location.href='stock-reports.html'"><span
                            class="sub-dot"></span>Stock & Inventory
                        Reports</div>
                    <div class="nav-sublink" onclick="window.location.href='sales-purchase.html'"><span
                            class="sub-dot"></span>Sales & Purchase
                        Summary</div>
                </div>
            </div>

            <!-- 7. Multi-location -->
            <div class="nav-item" id="nav-multiloc">
                <div class="nav-link" onclick="toggleNav('nav-multiloc')">
                    <span class="nav-icon">🌍</span>
                    <span class="nav-label">Multi-location / Branch</span>
                    <span class="nav-arrow"><i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="nav-submenu">
                    <div class="nav-sublink" onclick="window.location.href='branches.html'"><span
                            class="sub-dot"></span>Branch Accounting</div>
                    <div class="nav-sublink" onclick="window.location.href='consolidation.html'"><span
                            class="sub-dot"></span>Consolidation of
                        Accounts</div>
                    <div class="nav-sublink" onclick="window.location.href='branch-tracking.html'"><span
                            class="sub-dot"></span>Stock & Sales per
                        Branch</div>
                </div>
            </div>

            <!-- 8. Security -->
            <div class="nav-item" id="nav-security">
                <div class="nav-link" onclick="toggleNav('nav-security')">
                    <span class="nav-icon">🔒</span>
                    <span class="nav-label">Remote Access & Security</span>
                    <span class="nav-arrow"><i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="nav-submenu">
                    <div class="nav-sublink" onclick="window.location.href='user-access.html'"><span
                            class="sub-dot"></span>User Access Control
                    </div>
                    <div class="nav-sublink" onclick="window.location.href='encryption.html'"><span
                            class="sub-dot"></span>Data Encryption &
                        Backup</div>
                    <div class="nav-sublink" onclick="window.location.href='audit.html'"><span
                            class="sub-dot"></span>Audit Trails & Logs</div>
                </div>
            </div>

            <!-- 9. Additional -->
            <div class="nav-item" id="nav-addons">
                <div class="nav-link" onclick="toggleNav('nav-addons')">
                    <span class="nav-icon">⚙️</span>
                    <span class="nav-label">Additional Features</span>
                    <span class="nav-arrow"><i class="bi bi-chevron-right"></i></span>
                </div>
                <div class="nav-submenu">
                    <div class="nav-sublink" onclick="window.location.href='automation.html'"><span
                            class="sub-dot"></span>Voucher Automation
                    </div>
                    <div class="nav-sublink" onclick="window.location.href='budget.html'"><span
                            class="sub-dot"></span>Budgeting & Cost Centers
                    </div>
                    <div class="nav-sublink" onclick="window.location.href='multi-curr-tx.html'"><span
                            class="sub-dot"></span>Multi-currency
                        Transactions</div>
                    <div class="nav-sublink" onclick="window.location.href='custom-reports.html'"><span
                            class="sub-dot"></span>Custom Reports
                    </div>
                </div>
            </div>

        </nav>

        <div class="sidebar-footer">
            <div class="user-card">
                <div class="user-avatar">AD</div>
                <div class="user-info">
                    <h6>Admin User</h6>
                    <small>Super Administrator</small>
                </div>
                <i class="bi bi-three-dots-vertical ms-auto" style="color:var(--text-muted);font-size:14px;"></i>
            </div>
        </div>
    </aside>

    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Online Banking Integration</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== ONLINE BANKING INTEGRATION ===================== -->
        <div class="page active" id="page-banking-integration">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Online Banking Integration</div>
                    <div class="page-subtitle">Connect and sync bank accounts automatically</div>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="tally-card" style="text-align:center;padding:30px 20px">
                        <div style="font-size:40px;margin-bottom:12px;">🏦</div>
                        <div class="card-label mb-1">HDFC Bank</div>
                        <div class="mb-3" style="font-size:12px;color:var(--text-muted)">Current Account •••• 4821</div>
                        <span class="badge-tally badge-success">Connected</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="tally-card" style="text-align:center;padding:30px 20px">
                        <div style="font-size:40px;margin-bottom:12px;">🏛️</div>
                        <div class="card-label mb-1">ICICI Bank</div>
                        <div class="mb-3" style="font-size:12px;color:var(--text-muted)">Savings Account •••• 3210</div>
                        <span class="badge-tally badge-success">Connected</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="tally-card" style="text-align:center;padding:30px 20px">
                        <div style="font-size:40px;margin-bottom:12px;">➕</div>
                        <div class="card-label mb-1">Add New Bank</div>
                        <div class="mb-3" style="font-size:12px;color:var(--text-muted)">Connect via Net Banking API
                        </div><button class="btn-tally-outline">Connect Bank</button>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- ===================== MODALS ===================== -->

    <!-- Voucher Modal -->
    <div class="tally-modal-overlay" id="voucherModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Create Voucher</div>
                <div class="modal-close" onclick="closeModal('voucherModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Voucher Type *</label><select
                                class="form-control-tally">
                                <option>Payment</option>
                                <option>Receipt</option>
                                <option>Journal</option>
                                <option>Contra</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Voucher Date *</label><input type="date"
                                class="form-control-tally"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Party / Account *</label><input type="text"
                                class="form-control-tally" placeholder="Select or type party name"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Amount *</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Payment Mode</label><select
                                class="form-control-tally">
                                <option>Cash</option>
                                <option>Bank Transfer</option>
                                <option>Cheque</option>
                                <option>UPI</option>
                                <option>NEFT/RTGS</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Reference No.</label><input type="text"
                                class="form-control-tally" placeholder="Cheque / UTR / Ref No."></div>
                    </div>
                    <div class="col-12">
                        <div class="form-group"><label class="form-label">Narration</label><textarea
                                class="form-control-tally" rows="2"
                                placeholder="Brief description of this voucher..."></textarea></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('voucherModal')">Cancel</button>
                <button class="btn-tally-outline" onclick="showToast('Saved as Draft','info')"><i
                        class="bi bi-file-earmark"></i> Save Draft</button>
                <button class="btn-tally-primary"
                    onclick="closeModal('voucherModal');showToast('Voucher created successfully!','success')"><i
                        class="bi bi-check-lg"></i> Post Voucher</button>
            </div>
        </div>
    </div>

    <!-- Ledger Modal -->
    <div class="tally-modal-overlay" id="ledgerModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title" id="ledgerModalTitle">Create New Ledger</div>
                <div class="modal-close" onclick="closeModal('ledgerModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="form-group"><label class="form-label">Ledger Name *</label><input type="text"
                                class="form-control-tally" placeholder="e.g. HDFC Bank Account" id="ledgerName"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Ledger Code</label><input type="text"
                                class="form-control-tally" placeholder="e.g. 001"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Under Group *</label><select
                                class="form-control-tally">
                                <option>Cash-in-Hand</option>
                                <option>Bank Accounts</option>
                                <option>Sundry Debtors</option>
                                <option>Sundry Creditors</option>
                                <option>Sales Accounts</option>
                                <option>Purchase Accounts</option>
                                <option>Duties & Taxes</option>
                                <option>Fixed Assets</option>
                                <option>Investments</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Account Type *</label><select
                                class="form-control-tally">
                                <option>Asset</option>
                                <option>Liability</option>
                                <option>Revenue</option>
                                <option>Expense</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Opening Balance</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Balance Type</label><select
                                class="form-control-tally">
                                <option>Debit (Dr)</option>
                                <option>Credit (Cr)</option>
                            </select></div>
                    </div>
                    <div class="col-12">
                        <div class="form-group"><label class="form-label">Description / Notes</label><textarea
                                class="form-control-tally" rows="2" placeholder="Optional description..."></textarea>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Currency</label><select
                                class="form-control-tally">
                                <option>INR — Indian Rupee</option>
                                <option>USD — US Dollar</option>
                                <option>EUR — Euro</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Status</label><select
                                class="form-control-tally">
                                <option>Active</option>
                                <option>Inactive</option>
                            </select></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('ledgerModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveLedger()"><i class="bi bi-check-lg"></i> Save
                    Ledger</button>
            </div>
        </div>
    </div>

    <!-- Stock Item Modal -->
    <div class="tally-modal-overlay" id="stockModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Add Stock Item</div>
                <div class="modal-close" onclick="closeModal('stockModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="form-group"><label class="form-label">Item Name *</label><input type="text"
                                class="form-control-tally" placeholder="e.g. Steel Pipe 2 inch"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Item Code</label><input type="text"
                                class="form-control-tally" placeholder="ITM-001"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Category *</label><select
                                class="form-control-tally">
                                <option>Electrical</option>
                                <option>Pipes & Fittings</option>
                                <option>Building Materials</option>
                                <option>Electronics</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Unit of Measure *</label><select
                                class="form-control-tally">
                                <option>Pcs</option>
                                <option>Kg</option>
                                <option>Litre</option>
                                <option>Roll</option>
                                <option>Bag</option>
                                <option>Box</option>
                            </select></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Opening Qty</label><input type="number"
                                class="form-control-tally" placeholder="0"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Purchase Rate</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Selling Rate</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Valuation Method</label><select
                                class="form-control-tally">
                                <option>FIFO</option>
                                <option>LIFO</option>
                                <option>Average Cost</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Reorder Level</label><input type="number"
                                class="form-control-tally" placeholder="Minimum stock level"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">GST Rate (%)</label><select
                                class="form-control-tally">
                                <option>0%</option>
                                <option>5%</option>
                                <option>12%</option>
                                <option>18%</option>
                                <option>28%</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">HSN / SAC Code</label><input type="text"
                                class="form-control-tally" placeholder="8-digit HSN code"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('stockModal')">Cancel</button>
                <button class="btn-tally-primary"
                    onclick="closeModal('stockModal');showToast('Stock item added!','success')"><i
                        class="bi bi-check-lg"></i> Save Item</button>
            </div>
        </div>
    </div>

    <!-- Employee Modal -->
    <div class="tally-modal-overlay" id="employeeModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Add Employee</div>
                <div class="modal-close" onclick="closeModal('employeeModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">First Name *</label><input type="text"
                                class="form-control-tally" placeholder="First Name"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Last Name *</label><input type="text"
                                class="form-control-tally" placeholder="Last Name"></div>
                    </div>
