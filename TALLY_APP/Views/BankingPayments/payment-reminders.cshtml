@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Payment Reminders</title>
    <partial name="_Styles" />
</head>
<body>
    <partial name="_Sidebar" />
    <partial name="_Header" model='@("Payment Reminders")' />

    <main class="main-content">
        <div class="page active" id="page-payment-reminders">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Payment Reminders</div>
                    <div class="page-subtitle">Banking & Payments · Track and send invoice reminders</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('reminderModal')"><i class="bi bi-bell"></i> New Reminder</button>
            </div>
            <div class="row g-3 mb-4" id="summaryCards"></div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Overdue Invoices</div>
                    <div class="table-actions"><input class="table-search" placeholder="Search reminders..." oninput="handleSearch(event)"></div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('Id')" style="cursor:pointer;"># <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('PartyName')" style="cursor:pointer;">Party <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('InvoiceNumber')" style="cursor:pointer;">Invoice No <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Amount')" style="cursor:pointer;">Amount <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('OverdueBy')" style="cursor:pointer;">Overdue (Days) <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('ReminderNumber')" style="cursor:pointer;">Reminder # <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('LastSent')" style="cursor:pointer;">Last Sent <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">Showing <span id="showingStart">0</span> to <span id="showingEnd">0</span> of <span id="totalRecords">0</span> records</div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows:</label>
                        <select id="pageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changePageSize()"><option value="5">5</option><option value="10" selected>10</option><option value="25">25</option><option value="50">50</option></select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="prevBtn" style="padding:6px 12px;" onclick="prevPage()"><i class="bi bi-chevron-left"></i></button>
                            <span id="pageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="nextBtn" style="padding:6px 12px;" onclick="nextPage()"><i class="bi bi-chevron-right"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Reminder Modal -->
    <div class="tally-modal-overlay" id="reminderModal">
        <div class="tally-modal" style="max-width:700px;">
            <div class="modal-header">
                <div class="modal-title" id="modalTitle">Schedule Reminder</div>
                <div class="modal-close" onclick="closeModal('reminderModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Party Name *</label><input type="text" class="form-control-tally" id="PartyName"><div class="field-error" id="error-PartyName"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Party ID</label><input type="number" class="form-control-tally" id="PartyId"><div class="field-error" id="error-PartyId"></div></div></div>

                    <div class="col-md-6"><div class="form-group"><label class="form-label">Invoice Number *</label><input type="text" class="form-control-tally" id="InvoiceNumber"><div class="field-error" id="error-InvoiceNumber"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Amount Due *</label><input type="number" step="0.01" class="form-control-tally" id="Amount"><div class="field-error" id="error-Amount"></div></div></div>

                    <div class="col-md-6"><div class="form-group"><label class="form-label">Overdue By (Days) *</label><input type="number" class="form-control-tally" id="OverdueBy"><div class="field-error" id="error-OverdueBy"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Reminder #</label><select class="form-control-tally" id="ReminderNumber"><option value="First">First</option><option value="Second">Second</option><option value="Final">Final</option></select><div class="field-error" id="error-ReminderNumber"></div></div></div>

                    <div class="col-md-6"><div class="form-group"><label class="form-label">Last Sent</label><input type="date" class="form-control-tally" id="LastSent"><div class="field-error" id="error-LastSent"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Status</label><select class="form-control-tally" id="Status"><option value="Pending">Pending</option><option value="Sent">Sent</option><option value="Resolved">Resolved</option></select><div class="field-error" id="error-Status"></div></div></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('reminderModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveRecord()"><i class="bi bi-check-lg"></i> Save Reminder</button>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;"><div class="del-icon">🗑️</div><h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete Reminder?</h5><p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone.</p><div class="d-flex justify-content-center gap-3"><button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button><button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()"><i class="bi bi-trash"></i> Yes, Delete</button></div></div>
    </div>

    <div class="toast-container" id="toastContainer"></div>
    <partial name="_Scripts" />

    <script>
        let st = { data: [], page: 1, pageSize: 10, totalCount: 0, totalPages: 0, search: '', sortColumn: 'Id', sortDirection: 'desc', hasPreviousPage: false, hasNextPage: false, editingId: null };
        let deleteTarget = null; let searchTimer = null;

        function openModal(id, item = null) { const o = document.getElementById(id); if (!o) return; o.classList.add('open'); if (id === 'reminderModal') { clearErrors(); if (item) { st.editingId = item.id; document.getElementById('modalTitle').textContent = 'Edit Reminder'; document.getElementById('PartyName').value = item.partyName||''; document.getElementById('PartyId').value = item.partyId||''; document.getElementById('InvoiceNumber').value = item.invoiceNumber||''; document.getElementById('Amount').value = item.amount||0; document.getElementById('OverdueBy').value = item.overdueBy||0; document.getElementById('ReminderNumber').value = item.reminderNumber||'First'; document.getElementById('LastSent').value = item.lastSent ? item.lastSent.substring(0,10) : ''; document.getElementById('Status').value = item.status||'Pending'; } else { st.editingId = null; document.getElementById('modalTitle').textContent = 'Schedule Reminder'; ['PartyName','PartyId','InvoiceNumber','LastSent'].forEach(f=>document.getElementById(f).value=''); ['Amount','OverdueBy'].forEach(f=>document.getElementById(f).value='0'); document.getElementById('ReminderNumber').value='First'; document.getElementById('Status').value='Pending'; } } }
        function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }
        function clearErrors() { document.querySelectorAll('.field-error').forEach(el => el.textContent = ''); }
        function showFieldError(f, msg) { const el = document.getElementById('error-' + f); if (el) el.textContent = msg; }

        async function loadData() {
            const params = new URLSearchParams({ page: st.page, pageSize: st.pageSize, search: st.search, sortColumn: st.sortColumn, sortDirection: st.sortDirection });
            try { const r = await fetch(`/PaymentReminder/api/index?${params}`); if (!r.ok) throw new Error(); const d = await r.json(); Object.assign(st, { data: d.data||[], totalCount: d.totalCount||0, totalPages: d.totalPages||0, page: d.page||1, hasPreviousPage: d.hasPreviousPage||false, hasNextPage: d.hasNextPage||false }); renderTable(); renderPagination(); renderSummary(); } catch(e) { showToast('Failed to load','error'); }
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody'); tbody.innerHTML = '';
            if (!st.data.length) { tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--text-muted);">No records found</td></tr>'; return; }
            const s = ((st.page-1)*st.pageSize)+1;
            st.data.forEach((item, i) => {
                const badge = {'Sent':'badge-success','Pending':'badge-warning','Resolved':'badge-accent'};
                const overdueColor = item.overdueBy > 30 ? 'color:var(--danger);font-weight:600;' : '';
                const row = document.createElement('tr');
                row.innerHTML = `<td>${s+i}</td><td style="font-weight:600">${esc(item.partyName)}</td><td class="text-mono">${esc(item.invoiceNumber)}</td><td>₹${fmt(item.amount)}</td><td style="${overdueColor}">${item.overdueBy}</td><td>${esc(item.reminderNumber)}</td><td>${item.lastSent?new Date(item.lastSent).toLocaleDateString('en-IN'):'Not sent'}</td><td><span class="badge-tally ${badge[item.status]||'badge-info'}">${esc(item.status)}</span></td><td><button class="btn-tally-outline" style="padding:4px 8px;font-size:12px;margin-right:4px;" onclick="send(${item.id})"><i class="bi bi-send"></i></button><button class="btn-tally-edit" onclick="editItem(${item.id})"><i class="bi bi-pencil"></i></button> <button class="btn-tally-danger" onclick="deleteItem(${item.id})"><i class="bi bi-trash"></i></button></td>`;
                tbody.appendChild(row);
            });
            document.getElementById('showingStart').textContent = st.totalCount > 0 ? s : 0; document.getElementById('showingEnd').textContent = Math.min(s+st.pageSize-1, st.totalCount); document.getElementById('totalRecords').textContent = st.totalCount;
        }

        function renderSummary() {
            document.getElementById('summaryCards').innerHTML = `<div class="col-md-3"><div class="stat-card" style="--card-accent:var(--accent)"><div class="stat-label">Total Reminders</div><div class="stat-value">${st.totalCount}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--danger)"><div class="stat-label">Overdue Amount</div><div class="stat-value">₹${fmt(st.data.filter(i=>i.status!=='Resolved').reduce((a,i)=>a+i.amount,0))}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--warning)"><div class="stat-label">Pending Send</div><div class="stat-value">${st.data.filter(i=>i.status==='Pending').length}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--success)"><div class="stat-label">Resolved</div><div class="stat-value">${st.data.filter(i=>i.status==='Resolved').length}</div></div></div>`;
        }

        function renderPagination() { const el = document.getElementById('pageNumbers'); el.innerHTML = ''; const max=5; let s=Math.max(1,st.page-Math.floor(max/2)); let e=Math.min(st.totalPages,s+max-1); if(e-s<max-1) s=Math.max(1,e-max+1); for(let i=s;i<=e;i++){const b=document.createElement('button');b.className=`btn-tally-outline ${i===st.page?'active':''}`;b.style.cssText='padding:6px 10px;min-width:36px;';b.textContent=i;b.onclick=()=>goToPage(i);el.appendChild(b);} document.getElementById('prevBtn').disabled=!st.hasPreviousPage; document.getElementById('nextBtn').disabled=!st.hasNextPage; document.getElementById('pageSizeSelect').value=st.pageSize; }

        function goToPage(p){if(p<1||p>st.totalPages)return;st.page=p;loadData();} function prevPage(){if(st.hasPreviousPage)goToPage(st.page-1);} function nextPage(){if(st.hasNextPage)goToPage(st.page+1);} function changePageSize(){st.pageSize=parseInt(document.getElementById('pageSizeSelect').value);st.page=1;loadData();}
        function sortBy(col){if(st.sortColumn===col)st.sortDirection=st.sortDirection==='asc'?'desc':'asc';else{st.sortColumn=col;st.sortDirection='asc';}st.page=1;loadData();}
        function handleSearch(e){clearTimeout(searchTimer);searchTimer=setTimeout(()=>{st.search=e.target.value.trim();st.page=1;loadData();},500);}

        async function send(id) {
            showToast('Sending email/SMS reminder...','info');
            setTimeout(() => { showToast('Reminder sent!','success'); loadData(); }, 1500);
        }

        async function saveRecord(){clearErrors();const fd={partyName:document.getElementById('PartyName').value.trim(),partyId: (document.getElementById("PartyId").value) ? parseInt(document.getElementById("PartyId").value) : null,invoiceNumber:document.getElementById('InvoiceNumber').value.trim(),amount: (document.getElementById("Amount").value) ? parseFloat(document.getElementById("Amount").value) : null,overdueBy:parseInt(document.getElementById('OverdueBy').value)||0,reminderNumber:document.getElementById('ReminderNumber').value,lastSent:document.getElementById('LastSent').value||new Date().toISOString().substring(0,10),status:document.getElementById('Status').value};try{const url=st.editingId?`/PaymentReminder/update/${st.editingId}`:`/PaymentReminder/create`;const m=st.editingId?'PUT':'POST';const r=await fetch(url,{method:m,headers:{'Content-Type':'application/json'},body:JSON.stringify(fd)});const d=await r.json();if(!r.ok){if(r.status===400&&d.errors){for(const[f,msgs]of Object.entries(d.errors))showFieldError(f,msgs.join(', '));return;}throw new Error(d.message||'Failed');}closeModal('reminderModal');showToast(st.editingId?'Updated!':'Scheduled!','success');loadData();}catch(e){showToast('Save failed: '+e.message,'error');}}

        function editItem(id){const item=st.data.find(i=>i.id===id);if(item)openModal('reminderModal',item);} function deleteItem(id){deleteTarget={id};openModal('deleteModal');}
        async function confirmDelete(){if(!deleteTarget)return;try{const r=await fetch(`/PaymentReminder/delete/${deleteTarget.id}`,{method:'DELETE'});if(!r.ok)throw new Error();closeModal('deleteModal');showToast('Deleted','success');loadData();}catch(e){showToast('Delete failed','error');}finally{deleteTarget=null;}}

        function esc(t){if(!t)return'';const d=document.createElement('div');d.textContent=t;return d.innerHTML;} function fmt(n){return parseFloat(n||0).toLocaleString('en-IN',{maximumFractionDigits:2});}
        function showToast(msg,type='success'){const icons={success:'✅',error:'❌',info:'ℹ️'};const c=document.getElementById('toastContainer');if(!c)return;const t=document.createElement('div');t.className=`tally-toast ${type}`;t.innerHTML=`<span style="font-size:16px">${icons[type]}</span><span>${msg}</span>`;c.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(20px)';t.style.transition='0.3s ease';setTimeout(()=>t.remove(),300);},3000);}

        document.addEventListener('DOMContentLoaded',()=>{loadData();document.querySelectorAll('.tally-modal-overlay').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)closeModal(this.id);}));});
        document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.tally-modal-overlay.open').forEach(m=>m.classList.remove('open'));});
    </script>
</body>
</html>





