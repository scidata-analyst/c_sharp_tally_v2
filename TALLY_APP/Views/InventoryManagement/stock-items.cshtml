@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Stock Items & Categories</title>
    <partial name="_Styles" />
</head>

<body>

    <partial name="_Sidebar" />

    <partial name="_Header" model='@("Stock Items & Categories")' />

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <div class="page active" id="page-stock-items">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Stock Items & Categories</div>
                    <div class="page-subtitle">Inventory Management · Manage all stock items and categories</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('stockModal')"><i class="bi bi-plus-lg"></i> Add Stock Item</button>
            </div>
            <div class="row g-3 mb-4" id="stockSummaryCards">
                <!-- Loaded via API -->
            </div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Stock Items</div>
                    <div class="table-actions">
                        <input class="table-search" placeholder="Search items..." oninput="handleSearch(event)">
                    </div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('Id')" style="cursor:pointer;"># <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('ItemName')" style="cursor:pointer;">Item Name <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('ItemCode')" style="cursor:pointer;">Code <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Category')" style="cursor:pointer;">Category <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('OpeningQty')" style="cursor:pointer;">Qty <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('PurchaseRate')" style="cursor:pointer;">Purchase ₹ <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('SellingRate')" style="cursor:pointer;">Selling ₹ <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="stockTableBody">
                        <!-- Loaded via API -->
                    </tbody>
                </table>

                <!-- Pagination -->
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">
                        Showing <span id="showingStart">0</span> to <span id="showingEnd">0</span> of <span id="totalRecords">0</span> records
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows per page:</label>
                        <select id="pageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changePageSize()">
                            <option value="5">5</option>
                            <option value="10" selected>10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="prevBtn" style="padding:6px 12px;" onclick="prevPage()"><i class="bi bi-chevron-left"></i></button>
                            <span id="pageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="nextBtn" style="padding:6px 12px;" onclick="nextPage()"><i class="bi bi-chevron-right"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- Stock Item Modal -->
    <div class="tally-modal-overlay" id="stockModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title" id="stockModalTitle">Add Stock Item</div>
                <div class="modal-close" onclick="closeModal('stockModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="form-group"><label class="form-label">Item Name *</label><input type="text" class="form-control-tally" placeholder="e.g. Steel Pipe 2 inch" id="ItemName">
                            <div class="field-error" id="error-ItemName"></div></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Item Code *</label><input type="text" class="form-control-tally" placeholder="ITM-001" id="ItemCode">
                            <div class="field-error" id="error-ItemCode"></div></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Category *</label><select class="form-control-tally" id="Category">
                                <option value="">-- Select Category --</option>
                                <option value="Electrical">Electrical</option>
                                <option value="Pipes & Fittings">Pipes & Fittings</option>
                                <option value="Building Materials">Building Materials</option>
                                <option value="Electronics">Electronics</option>
                            </select>
                            <div class="field-error" id="error-Category"></div></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Unit of Measure *</label><select class="form-control-tally" id="UnitOfMeasure">
                                <option value="Pcs">Pcs</option>
                                <option value="Kg">Kg</option>
                                <option value="Litre">Litre</option>
                                <option value="Roll">Roll</option>
                                <option value="Bag">Bag</option>
                                <option value="Box">Box</option>
                            </select>
                            <div class="field-error" id="error-UnitOfMeasure"></div></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Opening Qty</label><input type="number" class="form-control-tally" placeholder="0" id="OpeningQty">
                            <div class="field-error" id="error-OpeningQty"></div></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Purchase Rate</label><input type="number" class="form-control-tally" placeholder="0.00" step="0.01" id="PurchaseRate">
                            <div class="field-error" id="error-PurchaseRate"></div></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Selling Rate</label><input type="number" class="form-control-tally" placeholder="0.00" step="0.01" id="SellingRate">
                            <div class="field-error" id="error-SellingRate"></div></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Valuation Method *</label><select class="form-control-tally" id="ValuationMethod">
                                <option value="FIFO">FIFO</option>
                                <option value="LIFO">LIFO</option>
                                <option value="Average Cost">Average Cost</option>
                            </select>
                            <div class="field-error" id="error-ValuationMethod"></div></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Reorder Level</label><input type="number" class="form-control-tally" placeholder="0" id="ReorderLevel">
                            <div class="field-error" id="error-ReorderLevel"></div></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">GST Rate (%)</label><select class="form-control-tally" id="GstRate">
                                <option value="0">0%</option>
                                <option value="5">5%</option>
                                <option value="12">12%</option>
                                <option value="18">18%</option>
                                <option value="28">28%</option>
                            </select>
                            <div class="field-error" id="error-GstRate"></div></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">HSN / SAC Code *</label><input type="text" class="form-control-tally" placeholder="8-digit HSN code" id="HsnSacCode">
                            <div class="field-error" id="error-HsnSacCode"></div></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Status</label><select class="form-control-tally" id="Status">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                            <div class="field-error" id="error-Status"></div></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('stockModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveStockItem()"><i class="bi bi-check-lg"></i> Save Item</button>
            </div>
        </div>
    </div>

    <!-- Delete Confirm Modal -->
    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;">
            <div class="del-icon">🗑️</div>
            <h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete Item?</h5>
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone. The record will be permanently removed.</p>
            <div class="d-flex justify-content-center gap-3">
                <button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button>
                <button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()"><i class="bi bi-trash"></i> Yes, Delete</button>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <partial name="_Scripts" />

    <script>
        let stockState = {
            data: [], page: 1, pageSize: 10, totalCount: 0, totalPages: 0,
            search: '', sortColumn: 'Id', sortDirection: 'asc',
            hasPreviousPage: false, hasNextPage: false, editingId: null
        };
        let deleteTarget = null;
        let searchDebounceTimer = null;

        function openModal(modalId, item = null) {
            const overlay = document.getElementById(modalId);
            if (overlay) {
                overlay.classList.add('open');
                if (modalId === 'stockModal') {
                    if (item) {
                        stockState.editingId = item.id;
                        document.getElementById('stockModalTitle').textContent = 'Edit Stock Item';
                        populateForm(item);
                    } else {
                        stockState.editingId = null;
                        document.getElementById('stockModalTitle').textContent = 'Add Stock Item';
                        clearForm();
                    }
                    clearErrors();
                }
            }
        }

        function closeModal(modalId) {
            document.getElementById(modalId)?.classList.remove('open');
        }

        function populateForm(item) {
            document.getElementById('ItemName').value = item.itemName || '';
            document.getElementById('ItemCode').value = item.itemCode || '';
            document.getElementById('Category').value = item.category || '';
            document.getElementById('UnitOfMeasure').value = item.unitOfMeasure || 'Pcs';
            document.getElementById('OpeningQty').value = item.openingQty || '';
            document.getElementById('PurchaseRate').value = item.purchaseRate || '';
            document.getElementById('SellingRate').value = item.sellingRate || '';
            document.getElementById('ValuationMethod').value = item.valuationMethod || 'FIFO';
            document.getElementById('ReorderLevel').value = item.reorderLevel || '';
            document.getElementById('GstRate').value = item.gstRate || '0';
            document.getElementById('HsnSacCode').value = item.hsnSacCode || '';
            document.getElementById('Status').value = item.status || 'Active';
        }

        function clearForm() {
            ['ItemName','ItemCode','OpeningQty','PurchaseRate','SellingRate','ReorderLevel','HsnSacCode'].forEach(id => document.getElementById(id).value = '');
            document.getElementById('Category').value = '';
            document.getElementById('UnitOfMeasure').value = 'Pcs';
            document.getElementById('ValuationMethod').value = 'FIFO';
            document.getElementById('GstRate').value = '0';
            document.getElementById('Status').value = 'Active';
        }

        function clearErrors() { document.querySelectorAll('.field-error').forEach(el => el.textContent = ''); }
        function showFieldError(fieldId, message) { const el = document.getElementById('error-' + fieldId); if (el) el.textContent = message; }

        async function loadStockItems() {
            const params = new URLSearchParams({
                page: stockState.page, pageSize: stockState.pageSize, search: stockState.search,
                sortColumn: stockState.sortColumn, sortDirection: stockState.sortDirection
            });
            try {
                const response = await fetch(`/StockItem/api/index?${params}`);
                if (!response.ok) throw new Error('Load failed');
                const result = await response.json();
                stockState.data = result.data || [];
                stockState.totalCount = result.totalCount || 0;
                stockState.totalPages = result.totalPages || 0;
                stockState.page = result.page || 1;
                stockState.hasPreviousPage = result.hasPreviousPage || false;
                stockState.hasNextPage = result.hasNextPage || false;
                renderTable(); renderPagination(); updateSortIcons(); renderSummary();
            } catch (error) { console.error(error); showToast('Failed to load stock items', 'error'); }
        }

        function renderTable() {
            const tbody = document.getElementById('stockTableBody');
            tbody.innerHTML = '';
            if (stockState.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--text-muted);">No records found</td></tr>';
                return;
            }
            const start = ((stockState.page - 1) * stockState.pageSize) + 1;
            stockState.data.forEach((item, index) => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${start + index}</td>
                    <td>${escapeHtml(item.itemName)}</td>
                    <td class="text-mono">${escapeHtml(item.itemCode)}</td>
                    <td>${escapeHtml(item.category)}</td>
                    <td>${item.openingQty}</td>
                    <td>₹${formatNumber(item.purchaseRate)}</td>
                    <td>₹${formatNumber(item.sellingRate)}</td>
                    <td><span class="badge-tally ${item.status === 'Active' ? 'badge-success' : 'badge-warning'}">${escapeHtml(item.status)}</span></td>
                    <td>
                        <button class="btn-tally-edit" onclick="editItem(${item.id})"><i class="bi bi-pencil"></i></button>
                        <button class="btn-tally-danger" onclick="deleteItem(${item.id})"><i class="bi bi-trash"></i></button>
                    </td>`;
                tbody.appendChild(row);
            });
            document.getElementById('showingStart').textContent = stockState.totalCount > 0 ? start : 0;
            document.getElementById('showingEnd').textContent = Math.min(start + stockState.pageSize - 1, stockState.totalCount);
            document.getElementById('totalRecords').textContent = stockState.totalCount;
        }

        function renderSummary() {
            const container = document.getElementById('stockSummaryCards');
            const total = stockState.totalCount;
            container.innerHTML = `
                <div class="col-md-3"><div class="stat-card" style="--card-accent:var(--accent)"><div class="stat-label">Total Items</div><div class="stat-value">${total.toLocaleString('en-IN')}</div></div></div>
                <div class="col-md-3"><div class="stat-card" style="--card-accent:var(--primary)"><div class="stat-label">Active</div><div class="stat-value">${stockState.data.filter(i => i.status === 'Active').length}</div></div></div>
                <div class="col-md-3"><div class="stat-card" style="--card-accent:var(--warning)"><div class="stat-label">Low Stock</div><div class="stat-value">${stockState.data.filter(i => i.openingQty > 0 && i.openingQty <= i.reorderLevel).length}</div></div></div>
                <div class="col-md-3"><div class="stat-card" style="--card-accent:var(--danger)"><div class="stat-label">Out of Stock</div><div class="stat-value">${stockState.data.filter(i => i.openingQty === 0).length}</div></div></div>`;
        }

        function renderPagination() {
            const el = document.getElementById('pageNumbers'); el.innerHTML = '';
            const max = 5; let s = Math.max(1, stockState.page - Math.floor(max/2));
            let e = Math.min(stockState.totalPages, s + max - 1);
            if (e - s < max - 1) s = Math.max(1, e - max + 1);
            for (let i = s; i <= e; i++) {
                const btn = document.createElement('button');
                btn.className = `btn-tally-outline ${i === stockState.page ? 'active' : ''}`;
                btn.style.cssText = 'padding:6px 10px;min-width:36px;'; btn.textContent = i;
                btn.onclick = () => goToPage(i); el.appendChild(btn);
            }
            document.getElementById('prevBtn').disabled = !stockState.hasPreviousPage;
            document.getElementById('nextBtn').disabled = !stockState.hasNextPage;
            document.getElementById('pageSizeSelect').value = stockState.pageSize;
        }

        function goToPage(p) { if (p < 1 || p > stockState.totalPages) return; stockState.page = p; loadStockItems(); }
        function prevPage() { if (stockState.hasPreviousPage) goToPage(stockState.page - 1); }
        function nextPage() { if (stockState.hasNextPage) goToPage(stockState.page + 1); }
        function changePageSize() { stockState.pageSize = parseInt(document.getElementById('pageSizeSelect').value); stockState.page = 1; loadStockItems(); }

        function sortBy(column) {
            if (stockState.sortColumn === column) { stockState.sortDirection = stockState.sortDirection === 'asc' ? 'desc' : 'asc'; }
            else { stockState.sortColumn = column; stockState.sortDirection = 'asc'; }
            stockState.page = 1; loadStockItems();
        }

        function updateSortIcons() {
            document.querySelectorAll('th[onclick^="sortBy"]').forEach(th => {
                const icon = th.querySelector('i'); if (!icon) return;
                const m = th.getAttribute('onclick').match(/'([^']+)'/); if (!m) return;
                if (m[1] === stockState.sortColumn) { icon.className = `bi bi-sort-${stockState.sortDirection === 'asc' ? 'down' : 'up'} ms-1`; icon.style.color = 'var(--primary)'; }
                else { icon.className = 'bi bi-arrow-down-up ms-1'; icon.style.color = 'var(--text-muted)'; }
            });
        }

        function handleSearch(e) {
            clearTimeout(searchDebounceTimer);
            searchDebounceTimer = setTimeout(() => { stockState.search = e.target.value.trim(); stockState.page = 1; loadStockItems(); }, 500);
        }

        async function saveStockItem() {
            clearErrors();
            const formData = {
                itemName: document.getElementById('ItemName').value.trim(),
                itemCode: document.getElementById('ItemCode').value.trim(),
                category: document.getElementById('Category').value,
                unitOfMeasure: document.getElementById('UnitOfMeasure').value,
                openingQty: parseInt(document.getElementById('OpeningQty').value) || 0,
                purchaseRate: parseFloat(document.getElementById('PurchaseRate').value) || 0,
                sellingRate: parseFloat(document.getElementById('SellingRate').value) || 0,
                valuationMethod: document.getElementById('ValuationMethod').value,
                reorderLevel: parseInt(document.getElementById('ReorderLevel').value) || 0,
                gstRate: parseFloat(document.getElementById('GstRate').value) || 0,
                hsnSacCode: document.getElementById('HsnSacCode').value.trim(),
                status: document.getElementById('Status').value
            };
            try {
                const url = stockState.editingId ? `/StockItem/update/${stockState.editingId}` : `/StockItem/create`;
                const method = stockState.editingId ? 'PUT' : 'POST';
                const response = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(formData) });
                const result = await response.json();
                if (!response.ok) {
                    if (response.status === 400 && result.errors) {
                        for (const [field, messages] of Object.entries(result.errors)) showFieldError(field, messages.join(', '));
                        return;
                    }
                    throw new Error(result.message || 'Save failed');
                }
                closeModal('stockModal');
                showToast(stockState.editingId ? 'Stock item updated!' : 'Stock item created!', 'success');
                loadStockItems();
            } catch (error) { showToast('Failed to save: ' + error.message, 'error'); }
        }

        function editItem(id) { const item = stockState.data.find(i => i.id === id); if (item) openModal('stockModal', item); }
        function deleteItem(id) { deleteTarget = { id }; openModal('deleteModal'); }

        async function confirmDelete() {
            if (!deleteTarget) return;
            try {
                const response = await fetch(`/StockItem/delete/${deleteTarget.id}`, { method: 'DELETE' });
                if (!response.ok) throw new Error('Delete failed');
                closeModal('deleteModal'); showToast('Item deleted', 'success'); loadStockItems();
            } catch (error) { showToast('Delete failed', 'error'); }
            finally { deleteTarget = null; }
        }

        function escapeHtml(text) { if (!text) return ''; const d = document.createElement('div'); d.textContent = text; return d.innerHTML; }
        function formatNumber(num) { if (num === null || num === undefined) return '0'; return parseFloat(num).toLocaleString('en-IN', { maximumFractionDigits: 2 }); }

        function showToast(message, type = 'success') {
            const icons = { success: '✅', error: '❌', info: 'ℹ️' };
            const container = document.getElementById('toastContainer'); if (!container) return;
            const toast = document.createElement('div'); toast.className = `tally-toast ${type}`;
            toast.innerHTML = `<span style="font-size:16px">${icons[type]}</span><span>${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => { toast.style.opacity = '0'; toast.style.transform = 'translateX(20px)'; toast.style.transition = '0.3s ease'; setTimeout(() => toast.remove(), 300); }, 3000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadStockItems();
            document.querySelectorAll('.tally-modal-overlay').forEach(o => o.addEventListener('click', function(e) { if (e.target === this) closeModal(this.id); }));
        });
        document.addEventListener('keydown', e => { if (e.key === 'Escape') document.querySelectorAll('.tally-modal-overlay.open').forEach(m => m.classList.remove('open')); });
    </script>
</body>

</html>
