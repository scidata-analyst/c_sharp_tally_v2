@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Employees</title>
    <partial name="_Styles" />
</head>
<body>
    <partial name="_Sidebar" />
    <partial name="_Header" model='@("Employees")' />

    <main class="main-content">
        <div class="page active" id="page-employees">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Employee Directory</div>
                    <div class="page-subtitle">Payroll Management · Manage all employee records</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('employeeModal')"><i class="bi bi-plus-lg"></i> Add Employee</button>
            </div>
            <div class="row g-3 mb-4" id="summaryCards"></div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Employees</div>
                    <div class="table-actions"><input class="table-search" placeholder="Search employees..." oninput="handleSearch(event)"></div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('Id')" style="cursor:pointer;"># <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('EmployeeId')" style="cursor:pointer;">Emp ID <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('FirstName')" style="cursor:pointer;">Name <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Department')" style="cursor:pointer;">Department <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Designation')" style="cursor:pointer;">Designation <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('JoiningDate')" style="cursor:pointer;">Joining Date <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('GrossSalary')" style="cursor:pointer;">Gross Salary <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">Showing <span id="showingStart">0</span> to <span id="showingEnd">0</span> of <span id="totalRecords">0</span> records</div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows:</label>
                        <select id="pageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changePageSize()"><option value="5">5</option><option value="10" selected>10</option><option value="25">25</option><option value="50">50</option></select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="prevBtn" style="padding:6px 12px;" onclick="prevPage()"><i class="bi bi-chevron-left"></i></button>
                            <span id="pageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="nextBtn" style="padding:6px 12px;" onclick="nextPage()"><i class="bi bi-chevron-right"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Employee Modal -->
    <div class="tally-modal-overlay" id="employeeModal">
        <div class="tally-modal" style="max-width: 800px;">
            <div class="modal-header">
                <div class="modal-title" id="modalTitle">Add Employee</div>
                <div class="modal-close" onclick="closeModal('employeeModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <h6 style="margin-bottom: 15px; color: var(--primary);">Personal Details</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Employee ID *</label><input type="text" class="form-control-tally" id="EmployeeId"><div class="field-error" id="error-EmployeeId"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">First Name *</label><input type="text" class="form-control-tally" id="FirstName"><div class="field-error" id="error-FirstName"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Last Name *</label><input type="text" class="form-control-tally" id="LastName"><div class="field-error" id="error-LastName"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Joining Date *</label><input type="date" class="form-control-tally" id="JoiningDate"><div class="field-error" id="error-JoiningDate"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Department *</label><input type="text" class="form-control-tally" id="Department"><div class="field-error" id="error-Department"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Designation *</label><input type="text" class="form-control-tally" id="Designation"><div class="field-error" id="error-Designation"></div></div></div>
                </div>

                <h6 style="margin-bottom: 15px; color: var(--primary);">Salary Details</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Basic Salary *</label><input type="number" class="form-control-tally" step="0.01" id="BasicSalary"><div class="field-error" id="error-BasicSalary"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">HRA</label><input type="number" class="form-control-tally" step="0.01" id="Hra"><div class="field-error" id="error-Hra"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Allowances</label><input type="number" class="form-control-tally" step="0.01" id="Allowances"><div class="field-error" id="error-Allowances"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Gross Salary</label><input type="number" class="form-control-tally" step="0.01" id="GrossSalary" readonly style="background: var(--bg-tertiary);"><div class="field-error" id="error-GrossSalary"></div></div></div>
                </div>

                <h6 style="margin-bottom: 15px; color: var(--primary);">Statutory Details</h6>
                <div class="row g-3">
                    <div class="col-md-4"><div class="form-group"><label class="form-label">PAN Number</label><input type="text" class="form-control-tally" id="PanNumber"><div class="field-error" id="error-PanNumber"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Aadhar Number</label><input type="text" class="form-control-tally" id="AadharNumber"><div class="field-error" id="error-AadharNumber"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Status</label><select class="form-control-tally" id="Status"><option value="Active">Active</option><option value="Inactive">Inactive</option></select><div class="field-error" id="error-Status"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">PF Applicable</label><select class="form-control-tally" id="PfApplicable"><option value="Yes">Yes</option><option value="No">No</option></select><div class="field-error" id="error-PfApplicable"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">ESI Applicable</label><select class="form-control-tally" id="EsiApplicable"><option value="Yes">Yes</option><option value="No">No</option></select><div class="field-error" id="error-EsiApplicable"></div></div></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('employeeModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveRecord()"><i class="bi bi-check-lg"></i> Save Employee</button>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;"><div class="del-icon">🗑️</div><h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete Employee?</h5><p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone.</p><div class="d-flex justify-content-center gap-3"><button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button><button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()"><i class="bi bi-trash"></i> Yes, Delete</button></div></div>
    </div>

    <div class="toast-container" id="toastContainer"></div>
    <partial name="_Scripts" />

    <script>
        let st = { data: [], page: 1, pageSize: 10, totalCount: 0, totalPages: 0, search: '', sortColumn: 'Id', sortDirection: 'desc', hasPreviousPage: false, hasNextPage: false, editingId: null };
        let deleteTarget = null; let searchTimer = null;

        function openModal(id, item = null) { const o = document.getElementById(id); if (!o) return; o.classList.add('open'); if (id === 'employeeModal') { clearErrors(); if (item) { st.editingId = item.id; document.getElementById('modalTitle').textContent = 'Edit Employee'; document.getElementById('EmployeeId').value = item.employeeId||''; document.getElementById('FirstName').value = item.firstName||''; document.getElementById('LastName').value = item.lastName||''; document.getElementById('JoiningDate').value = item.joiningDate ? item.joiningDate.substring(0,10) : ''; document.getElementById('Department').value = item.department||''; document.getElementById('Designation').value = item.designation||''; document.getElementById('BasicSalary').value = item.basicSalary||0; document.getElementById('Hra').value = item.hra||0; document.getElementById('Allowances').value = item.allowances||0; document.getElementById('GrossSalary').value = item.grossSalary||0; document.getElementById('PanNumber').value = item.panNumber||''; document.getElementById('AadharNumber').value = item.aadharNumber||''; document.getElementById('PfApplicable').value = item.pfApplicable||'Yes'; document.getElementById('EsiApplicable').value = item.esiApplicable||'No'; document.getElementById('Status').value = item.status||'Active'; } else { st.editingId = null; document.getElementById('modalTitle').textContent = 'Add Employee'; ['EmployeeId','FirstName','LastName','JoiningDate','Department','Designation','PanNumber','AadharNumber'].forEach(f=>document.getElementById(f).value=''); ['BasicSalary','Hra','Allowances','GrossSalary'].forEach(f=>document.getElementById(f).value='0'); document.getElementById('Status').value='Active'; document.getElementById('PfApplicable').value='Yes'; document.getElementById('EsiApplicable').value='No'; } } }
        function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }
        function clearErrors() { document.querySelectorAll('.field-error').forEach(el => el.textContent = ''); }
        function showFieldError(f, msg) { const el = document.getElementById('error-' + f); if (el) el.textContent = msg; }

        ['BasicSalary', 'Hra', 'Allowances'].forEach(id => {
            document.getElementById(id).addEventListener('input', () => {
                const b = parseFloat(document.getElementById('BasicSalary').value) || 0;
                const h = parseFloat(document.getElementById('Hra').value) || 0;
                const a = parseFloat(document.getElementById('Allowances').value) || 0;
                document.getElementById('GrossSalary').value = (b + h + a).toFixed(2);
            });
        });

        async function loadData() {
            const params = new URLSearchParams({ page: st.page, pageSize: st.pageSize, search: st.search, sortColumn: st.sortColumn, sortDirection: st.sortDirection });
            try { const r = await fetch(`/Employee/api/index?${params}`); if (!r.ok) throw new Error(); const d = await r.json(); Object.assign(st, { data: d.data||[], totalCount: d.totalCount||0, totalPages: d.totalPages||0, page: d.page||1, hasPreviousPage: d.hasPreviousPage||false, hasNextPage: d.hasNextPage||false }); renderTable(); renderPagination(); renderSummary(); } catch(e) { showToast('Failed to load','error'); }
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody'); tbody.innerHTML = '';
            if (!st.data.length) { tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--text-muted);">No records found</td></tr>'; return; }
            const s = ((st.page-1)*st.pageSize)+1;
            st.data.forEach((item, i) => {
                const row = document.createElement('tr');
                row.innerHTML = `<td>${s+i}</td><td class="text-mono">${esc(item.employeeId)}</td><td style="font-weight:600">${esc(item.firstName)} ${esc(item.lastName)}</td><td>${esc(item.department)}</td><td>${esc(item.designation)}</td><td>${item.joiningDate?new Date(item.joiningDate).toLocaleDateString('en-IN'):'-'}</td><td>₹${fmt(item.grossSalary)}</td><td><span class="badge-tally ${item.status==='Active'?'badge-success':'badge-warning'}">${esc(item.status)}</span></td><td><button class="btn-tally-edit" onclick="editItem(${item.id})"><i class="bi bi-pencil"></i></button> <button class="btn-tally-danger" onclick="deleteItem(${item.id})"><i class="bi bi-trash"></i></button></td>`;
                tbody.appendChild(row);
            });
            document.getElementById('showingStart').textContent = st.totalCount > 0 ? s : 0; document.getElementById('showingEnd').textContent = Math.min(s+st.pageSize-1, st.totalCount); document.getElementById('totalRecords').textContent = st.totalCount;
        }

        function renderSummary() {
            document.getElementById('summaryCards').innerHTML = `<div class="col-md-3"><div class="stat-card" style="--card-accent:var(--accent)"><div class="stat-label">Total Employees</div><div class="stat-value">${st.totalCount}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--primary)"><div class="stat-label">Active</div><div class="stat-value">${st.data.filter(i=>i.status==='Active').length}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--danger)"><div class="stat-label">Inactive</div><div class="stat-value">${st.data.filter(i=>i.status!=='Active').length}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--warning)"><div class="stat-label">Avg Gross Salary</div><div class="stat-value">₹${fmt(st.data.length ? st.data.reduce((a,i)=>a+i.grossSalary,0)/st.data.length : 0)}</div></div></div>`;
        }

        function renderPagination() { const el = document.getElementById('pageNumbers'); el.innerHTML = ''; const max=5; let s=Math.max(1,st.page-Math.floor(max/2)); let e=Math.min(st.totalPages,s+max-1); if(e-s<max-1) s=Math.max(1,e-max+1); for(let i=s;i<=e;i++){const b=document.createElement('button');b.className=`btn-tally-outline ${i===st.page?'active':''}`;b.style.cssText='padding:6px 10px;min-width:36px;';b.textContent=i;b.onclick=()=>goToPage(i);el.appendChild(b);} document.getElementById('prevBtn').disabled=!st.hasPreviousPage; document.getElementById('nextBtn').disabled=!st.hasNextPage; document.getElementById('pageSizeSelect').value=st.pageSize; }

        function goToPage(p){if(p<1||p>st.totalPages)return;st.page=p;loadData();} function prevPage(){if(st.hasPreviousPage)goToPage(st.page-1);} function nextPage(){if(st.hasNextPage)goToPage(st.page+1);} function changePageSize(){st.pageSize=parseInt(document.getElementById('pageSizeSelect').value);st.page=1;loadData();}
        function sortBy(col){if(st.sortColumn===col)st.sortDirection=st.sortDirection==='asc'?'desc':'asc';else{st.sortColumn=col;st.sortDirection='asc';}st.page=1;loadData();}
        function handleSearch(e){clearTimeout(searchTimer);searchTimer=setTimeout(()=>{st.search=e.target.value.trim();st.page=1;loadData();},500);}

        async function saveRecord(){clearErrors();const fd={employeeId:document.getElementById('EmployeeId').value.trim(),firstName:document.getElementById('FirstName').value.trim(),lastName:document.getElementById('LastName').value.trim(),joiningDate:document.getElementById('JoiningDate').value||new Date().toISOString().substring(0,10),department:document.getElementById('Department').value.trim(),designation:document.getElementById('Designation').value.trim(),basicSalary: (document.getElementById("BasicSalary").value) ? parseFloat(document.getElementById("BasicSalary").value) : null,hra:parseFloat(document.getElementById('Hra').value)||0,allowances:parseFloat(document.getElementById('Allowances').value)||0,grossSalary: (document.getElementById("GrossSalary").value) ? parseFloat(document.getElementById("GrossSalary").value) : null,panNumber:document.getElementById('PanNumber').value.trim(),aadharNumber:document.getElementById('AadharNumber').value.trim(),pfApplicable:document.getElementById('PfApplicable').value,esiApplicable:document.getElementById('EsiApplicable').value,status:document.getElementById('Status').value};try{const url=st.editingId?`/Employee/update/${st.editingId}`:`/Employee/create`;const m=st.editingId?'PUT':'POST';const r=await fetch(url,{method:m,headers:{'Content-Type':'application/json'},body:JSON.stringify(fd)});const d=await r.json();if(!r.ok){if(r.status===400&&d.errors){for(const[f,msgs]of Object.entries(d.errors))showFieldError(f,msgs.join(', '));return;}throw new Error(d.message||'Failed');}closeModal('employeeModal');showToast(st.editingId?'Employee updated!':'Employee created!','success');loadData();}catch(e){showToast('Save failed: '+e.message,'error');}}

        function editItem(id){const item=st.data.find(i=>i.id===id);if(item)openModal('employeeModal',item);} function deleteItem(id){deleteTarget={id};openModal('deleteModal');}
        async function confirmDelete(){if(!deleteTarget)return;try{const r=await fetch(`/Employee/delete/${deleteTarget.id}`,{method:'DELETE'});if(!r.ok)throw new Error();closeModal('deleteModal');showToast('Employee deleted','success');loadData();}catch(e){showToast('Delete failed','error');}finally{deleteTarget=null;}}

        function esc(t){if(!t)return'';const d=document.createElement('div');d.textContent=t;return d.innerHTML;} function fmt(n){return parseFloat(n||0).toLocaleString('en-IN',{maximumFractionDigits:2});}
        function showToast(msg,type='success'){const icons={success:'✅',error:'❌',info:'ℹ️'};const c=document.getElementById('toastContainer');if(!c)return;const t=document.createElement('div');t.className=`tally-toast ${type}`;t.innerHTML=`<span style="font-size:16px">${icons[type]}</span><span>${msg}</span>`;c.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(20px)';t.style.transition='0.3s ease';setTimeout(()=>t.remove(),300);},3000);}

        document.addEventListener('DOMContentLoaded',()=>{loadData();document.querySelectorAll('.tally-modal-overlay').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)closeModal(this.id);}));});
        document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.tally-modal-overlay.open').forEach(m=>m.classList.remove('open'));});
    </script>
</body>
</html>



