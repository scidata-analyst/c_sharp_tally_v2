@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Payslips</title>
    <partial name="_Styles" />
</head>
<body>
    <partial name="_Sidebar" />
    <partial name="_Header" model='@("Payslips")' />

    <main class="main-content">
        <div class="page active" id="page-payslips">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Employee Payslips</div>
                    <div class="page-subtitle">Payroll Management · Generate and view payslips</div>
                </div>
                <button class="btn-tally-primary" onclick="openModal('payslipModal')"><i class="bi bi-file-earmark-text"></i> Generate Payslip</button>
            </div>
            <div class="row g-3 mb-4" id="summaryCards"></div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Generated Payslips</div>
                    <div class="table-actions"><input class="table-search" placeholder="Search payslips..." oninput="handleSearch(event)"></div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('Id')" style="cursor:pointer;"># <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Period')" style="cursor:pointer;">Period <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Employee</th>
                            <th onclick="sortBy('GrossPay')" style="cursor:pointer;">Gross Pay <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Total Deductions</th>
                            <th onclick="sortBy('NetPay')" style="cursor:pointer;">Net Pay <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('Status')" style="cursor:pointer;">Status <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th onclick="sortBy('CreatedAt')" style="cursor:pointer;">Generated On <i class="bi bi-arrow-down-up ms-1" style="font-size:10px"></i></th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">Showing <span id="showingStart">0</span> to <span id="showingEnd">0</span> of <span id="totalRecords">0</span> records</div>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <label style="font-size:13px;color:var(--text-muted);">Rows:</label>
                        <select id="pageSizeSelect" class="form-control-tally" style="width:70px;padding:4px 8px;" onchange="changePageSize()"><option value="5">5</option><option value="10" selected>10</option><option value="25">25</option><option value="50">50</option></select>
                        <div style="display:flex;gap:4px;">
                            <button class="btn-tally-outline" id="prevBtn" style="padding:6px 12px;" onclick="prevPage()"><i class="bi bi-chevron-left"></i></button>
                            <span id="pageNumbers" style="display:flex;gap:2px;"></span>
                            <button class="btn-tally-outline" id="nextBtn" style="padding:6px 12px;" onclick="nextPage()"><i class="bi bi-chevron-right"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Payslip Modal -->
    <div class="tally-modal-overlay" id="payslipModal">
        <div class="tally-modal" style="max-width:800px;">
            <div class="modal-header">
                <div class="modal-title" id="modalTitle">Generate Payslip</div>
                <div class="modal-close" onclick="closeModal('payslipModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-4">
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Employee ID *</label><input type="number" class="form-control-tally" id="EmployeeId"><div class="field-error" id="error-EmployeeId"></div></div></div>
                    <div class="col-md-6"><div class="form-group"><label class="form-label">Period (Month/Year) *</label><input type="month" class="form-control-tally" id="Period"><div class="field-error" id="error-Period"></div></div></div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Basic Salary</label><input type="number" step="0.01" class="form-control-tally calc" id="BasicSalary"><div class="field-error" id="error-BasicSalary"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">HRA</label><input type="number" step="0.01" class="form-control-tally calc" id="Hra"><div class="field-error" id="error-Hra"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Allowances</label><input type="number" step="0.01" class="form-control-tally calc" id="Allowances"><div class="field-error" id="error-Allowances"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">PF Deduction</label><input type="number" step="0.01" class="form-control-tally calc" id="PfDeduction"><div class="field-error" id="error-PfDeduction"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">ESI Deduction</label><input type="number" step="0.01" class="form-control-tally calc" id="EsiDeduction"><div class="field-error" id="error-EsiDeduction"></div></div></div>
                </div>

                <div class="row g-3">
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Gross Pay</label><input type="number" step="0.01" class="form-control-tally" id="GrossPay" readonly style="background:var(--bg-tertiary);"><div class="field-error" id="error-GrossPay"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Net Pay</label><input type="number" step="0.01" class="form-control-tally" id="NetPay" readonly style="background:var(--success);color:white;font-weight:600;"><div class="field-error" id="error-NetPay"></div></div></div>
                    <div class="col-md-4"><div class="form-group"><label class="form-label">Status</label><select class="form-control-tally" id="Status"><option value="Generated">Generated</option><option value="Published">Published</option></select><div class="field-error" id="error-Status"></div></div></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('payslipModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveRecord()"><i class="bi bi-check-lg"></i> Save Payslip</button>
            </div>
        </div>
    </div>

    <!-- Print Modal -->
    <div class="tally-modal-overlay" id="printModal">
        <div class="tally-modal" style="max-width:600px;">
            <div class="modal-header">
                <div class="modal-title">Payslip Details</div>
                <div class="modal-close" onclick="closeModal('printModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body" id="printContent" style="font-family: monospace; background: white; padding: 20px; border: 1px solid #eee; min-height: 300px;">
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('printModal')">Close</button>
                <button class="btn-tally-primary" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="tally-modal-overlay" id="deleteModal">
        <div class="delete-confirm" style="margin:auto;"><div class="del-icon">🗑️</div><h5 style="font-family:var(--font-display);color:var(--text-primary);margin-bottom:8px;">Delete Payslip?</h5><p style="font-size:13px;color:var(--text-muted);margin-bottom:20px;">This action cannot be undone.</p><div class="d-flex justify-content-center gap-3"><button class="btn-tally-outline" onclick="closeModal('deleteModal')">Cancel</button><button class="btn-tally-danger" style="padding:8px 20px;font-size:13px;" onclick="confirmDelete()"><i class="bi bi-trash"></i> Yes, Delete</button></div></div>
    </div>

    <div class="toast-container" id="toastContainer"></div>
    <partial name="_Scripts" />

    <script>
        let st = { data: [], page: 1, pageSize: 10, totalCount: 0, totalPages: 0, search: '', sortColumn: 'Id', sortDirection: 'desc', hasPreviousPage: false, hasNextPage: false, editingId: null };
        let deleteTarget = null; let searchTimer = null;

        function openModal(id, item = null) { const o = document.getElementById(id); if (!o) return; o.classList.add('open'); if (id === 'payslipModal') { clearErrors(); if (item) { st.editingId = item.id; document.getElementById('modalTitle').textContent = 'Edit Payslip'; document.getElementById('EmployeeId').value = item.employeeId||''; document.getElementById('Period').value = item.period||''; document.getElementById('BasicSalary').value = item.basicSalary||0; document.getElementById('Hra').value = item.hra||0; document.getElementById('Allowances').value = item.allowances||0; document.getElementById('PfDeduction').value = item.pfDeduction||0; document.getElementById('EsiDeduction').value = item.esiDeduction||0; document.getElementById('GrossPay').value = item.grossPay||0; document.getElementById('NetPay').value = item.netPay||0; document.getElementById('Status').value = item.status||'Generated'; } else { st.editingId = null; document.getElementById('modalTitle').textContent = 'Generate Payslip'; document.getElementById('EmployeeId').value = ''; document.getElementById('Period').value = ''; ['BasicSalary','Hra','Allowances','PfDeduction','EsiDeduction','GrossPay','NetPay'].forEach(f=>document.getElementById(f).value='0'); document.getElementById('Status').value='Generated'; } } }
        function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }
        function clearErrors() { document.querySelectorAll('.field-error').forEach(el => el.textContent = ''); }
        function showFieldError(f, msg) { const el = document.getElementById('error-' + f); if (el) el.textContent = msg; }

        function calc() {
            const b=parseFloat(document.getElementById('BasicSalary').value)||0, h=parseFloat(document.getElementById('Hra').value)||0, a=parseFloat(document.getElementById('Allowances').value)||0;
            const pf=parseFloat(document.getElementById('PfDeduction').value)||0, esi=parseFloat(document.getElementById('EsiDeduction').value)||0;
            document.getElementById('GrossPay').value = (b+h+a).toFixed(2);
            document.getElementById('NetPay').value = ((b+h+a)-(pf+esi)).toFixed(2);
        }
        document.querySelectorAll('.calc').forEach(el=>el.addEventListener('input', calc));

        async function loadData() {
            const params = new URLSearchParams({ page: st.page, pageSize: st.pageSize, search: st.search, sortColumn: st.sortColumn, sortDirection: st.sortDirection });
            try { const r = await fetch(`/Payslip/api/index?${params}`); if (!r.ok) throw new Error(); const d = await r.json(); Object.assign(st, { data: d.data||[], totalCount: d.totalCount||0, totalPages: d.totalPages||0, page: d.page||1, hasPreviousPage: d.hasPreviousPage||false, hasNextPage: d.hasNextPage||false }); renderTable(); renderPagination(); renderSummary(); } catch(e) { showToast('Failed to load','error'); }
        }

        function renderTable() {
            const tbody = document.getElementById('tableBody'); tbody.innerHTML = '';
            if (!st.data.length) { tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--text-muted);">No records found</td></tr>'; return; }
            const s = ((st.page-1)*st.pageSize)+1;
            st.data.forEach((item, i) => {
                const empName = item.employee ? `${item.employee.firstName} ${item.employee.lastName}` : (item.employeeId||'-');
                const row = document.createElement('tr');
                row.innerHTML = `<td>${s+i}</td><td class="text-mono">${esc(item.period)}</td><td>${esc(empName)}</td><td>₹${fmt(item.grossPay)}</td><td>₹${fmt(item.pfDeduction+item.esiDeduction)}</td><td style="font-weight:600;color:var(--success)">₹${fmt(item.netPay)}</td><td><span class="badge-tally ${item.status==='Published'?'badge-success':'badge-accent'}">${esc(item.status)}</span></td><td>${item.createdAt?new Date(item.createdAt).toLocaleDateString('en-IN'):'-'}</td><td><button class="btn-tally-outline" style="padding:4px 8px;font-size:12px;margin-right:4px;" onclick="viewPayslip(${item.id})"><i class="bi bi-eye"></i></button><button class="btn-tally-edit" onclick="editItem(${item.id})"><i class="bi bi-pencil"></i></button> <button class="btn-tally-danger" onclick="deleteItem(${item.id})"><i class="bi bi-trash"></i></button></td>`;
                tbody.appendChild(row);
            });
            document.getElementById('showingStart').textContent = st.totalCount > 0 ? s : 0; document.getElementById('showingEnd').textContent = Math.min(s+st.pageSize-1, st.totalCount); document.getElementById('totalRecords').textContent = st.totalCount;
        }

        function renderSummary() {
            document.getElementById('summaryCards').innerHTML = `<div class="col-md-3"><div class="stat-card" style="--card-accent:var(--accent)"><div class="stat-label">Total Payslips</div><div class="stat-value">${st.totalCount}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--success)"><div class="stat-label">Published</div><div class="stat-value">${st.data.filter(i=>i.status==='Published').length}</div></div></div><div class="col-md-3"><div class="stat-card" style="--card-accent:var(--warning)"><div class="stat-label">Draft / Generated</div><div class="stat-value">${st.data.filter(i=>i.status==='Generated').length}</div></div></div>`;
        }

        function renderPagination() { const el = document.getElementById('pageNumbers'); el.innerHTML = ''; const max=5; let s=Math.max(1,st.page-Math.floor(max/2)); let e=Math.min(st.totalPages,s+max-1); if(e-s<max-1) s=Math.max(1,e-max+1); for(let i=s;i<=e;i++){const b=document.createElement('button');b.className=`btn-tally-outline ${i===st.page?'active':''}`;b.style.cssText='padding:6px 10px;min-width:36px;';b.textContent=i;b.onclick=()=>goToPage(i);el.appendChild(b);} document.getElementById('prevBtn').disabled=!st.hasPreviousPage; document.getElementById('nextBtn').disabled=!st.hasNextPage; document.getElementById('pageSizeSelect').value=st.pageSize; }

        function goToPage(p){if(p<1||p>st.totalPages)return;st.page=p;loadData();} function prevPage(){if(st.hasPreviousPage)goToPage(st.page-1);} function nextPage(){if(st.hasNextPage)goToPage(st.page+1);} function changePageSize(){st.pageSize=parseInt(document.getElementById('pageSizeSelect').value);st.page=1;loadData();}
        function sortBy(col){if(st.sortColumn===col)st.sortDirection=st.sortDirection==='asc'?'desc':'asc';else{st.sortColumn=col;st.sortDirection='asc';}st.page=1;loadData();}
        function handleSearch(e){clearTimeout(searchTimer);searchTimer=setTimeout(()=>{st.search=e.target.value.trim();st.page=1;loadData();},500);}

        async function saveRecord(){clearErrors();const fd={employeeId:parseInt(document.getElementById('EmployeeId').value)||null,period:document.getElementById('Period').value.trim(),basicSalary:parseFloat(document.getElementById('BasicSalary').value)||0,hra:parseFloat(document.getElementById('Hra').value)||0,allowances:parseFloat(document.getElementById('Allowances').value)||0,grossPay:parseFloat(document.getElementById('GrossPay').value)||0,pfDeduction:parseFloat(document.getElementById('PfDeduction').value)||0,esiDeduction:parseFloat(document.getElementById('EsiDeduction').value)||0,netPay:parseFloat(document.getElementById('NetPay').value)||0,status:document.getElementById('Status').value,payslipData:'{}'};try{const url=st.editingId?`/Payslip/update/${st.editingId}`:`/Payslip/create`;const m=st.editingId?'PUT':'POST';const r=await fetch(url,{method:m,headers:{'Content-Type':'application/json'},body:JSON.stringify(fd)});const d=await r.json();if(!r.ok){if(r.status===400&&d.errors){for(const[f,msgs]of Object.entries(d.errors))showFieldError(f,msgs.join(', '));return;}throw new Error(d.message||'Failed');}closeModal('payslipModal');showToast(st.editingId?'Payslip updated!':'Payslip generated!','success');loadData();}catch(e){showToast('Save failed: '+e.message,'error');}}

        function viewPayslip(id) {
            const item = st.data.find(i=>i.id===id);
            if(!item) return;
            const e = item.employee ? `${item.employee.firstName} ${item.employee.lastName}` : `Emp ID: ${item.employeeId}`;
            const html = `<div style="text-align:center;border-bottom:1px solid #ccc;padding-bottom:10px;margin-bottom:20px;"><h2>TALLY PRO ENTERPRISES</h2><p>Payslip for the month of ${item.period}</p></div>
            <div style="display:flex;justify-content:space-between;margin-bottom:20px;"><div><strong>Employee:</strong> ${e}</div><div><strong>Status:</strong> ${item.status}</div></div>
            <table style="width:100%;border-collapse:collapse;margin-bottom:20px;"><tr><th style="text-align:left;border-bottom:1px solid #ccc;padding:8px;">Earnings</th><th style="text-align:right;border-bottom:1px solid #ccc;padding:8px;">Amount</th><th style="text-align:left;border-bottom:1px solid #ccc;padding:8px;padding-left:20px;">Deductions</th><th style="text-align:right;border-bottom:1px solid #ccc;padding:8px;">Amount</th></tr>
            <tr><td style="padding:8px;">Basic</td><td style="text-align:right;padding:8px;">${fmt(item.basicSalary)}</td><td style="padding:8px;padding-left:20px;">PF</td><td style="text-align:right;padding:8px;">${fmt(item.pfDeduction)}</td></tr>
            <tr><td style="padding:8px;">HRA</td><td style="text-align:right;padding:8px;">${fmt(item.hra)}</td><td style="padding:8px;padding-left:20px;">ESI</td><td style="text-align:right;padding:8px;">${fmt(item.esiDeduction)}</td></tr>
            <tr><td style="padding:8px;border-bottom:1px solid #ccc;">Allowances</td><td style="text-align:right;padding:8px;border-bottom:1px solid #ccc;">${fmt(item.allowances)}</td><td style="padding:8px;padding-left:20px;border-bottom:1px solid #ccc;"></td><td style="border-bottom:1px solid #ccc;"></td></tr>
            <tr><td style="padding:8px;font-weight:bold;">Gross Pay</td><td style="text-align:right;padding:8px;font-weight:bold;">${fmt(item.grossPay)}</td><td style="padding:8px;padding-left:20px;font-weight:bold;">Total Deductions</td><td style="text-align:right;padding:8px;font-weight:bold;">${fmt(item.pfDeduction+item.esiDeduction)}</td></tr>
            </table><div style="text-align:right;font-size:18px;"><strong>Net Pay: ₹${fmt(item.netPay)}</strong></div>`;
            document.getElementById('printContent').innerHTML = html;
            openModal('printModal');
        }

        function editItem(id){const item=st.data.find(i=>i.id===id);if(item)openModal('payslipModal',item);} function deleteItem(id){deleteTarget={id};openModal('deleteModal');}
        async function confirmDelete(){if(!deleteTarget)return;try{const r=await fetch(`/Payslip/delete/${deleteTarget.id}`,{method:'DELETE'});if(!r.ok)throw new Error();closeModal('deleteModal');showToast('Payslip deleted','success');loadData();}catch(e){showToast('Delete failed','error');}finally{deleteTarget=null;}}

        function esc(t){if(!t)return'';const d=document.createElement('div');d.textContent=t;return d.innerHTML;} function fmt(n){return parseFloat(n||0).toLocaleString('en-IN',{maximumFractionDigits:2});}
        function showToast(msg,type='success'){const icons={success:'✅',error:'❌',info:'ℹ️'};const c=document.getElementById('toastContainer');if(!c)return;const t=document.createElement('div');t.className=`tally-toast ${type}`;t.innerHTML=`<span style="font-size:16px">${icons[type]}</span><span>${msg}</span>`;c.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(20px)';t.style.transition='0.3s ease';setTimeout(()=>t.remove(),300);},3000);}

        document.addEventListener('DOMContentLoaded',()=>{loadData();document.querySelectorAll('.tally-modal-overlay').forEach(o=>o.addEventListener('click',function(e){if(e.target===this)closeModal(this.id);}));});
        document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.tally-modal-overlay.open').forEach(m=>m.classList.remove('open'));});
    </script>
</body>
</html>
