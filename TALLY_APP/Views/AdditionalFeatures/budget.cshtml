@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- External CSS -->
    <link rel="stylesheet" href="~/css/styles.css" />
</head>

<body>

        <partial name="_Sidebar" />

    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Budgeting & Cost Centers</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== BUDGETING & COST CENTERS ===================== -->
        <div class="page active" id="page-budget">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Budgeting & Cost Centers</div>
                    <div class="page-subtitle">Plan and track departmental budgets</div>
                </div><button class="btn-tally-primary" onclick="openModal('genericModal','Budget')"><i
                        class="bi bi-plus-lg"></i> New Budget</button>
            </div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Budget vs Actual — FY 2024-25</div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th>Cost Center</th>
                            <th>Annual Budget</th>
                            <th>Spent (YTD)</th>
                            <th>Remaining</th>
                            <th>% Used</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Marketing</td>
                            <td>₹5,00,000</td>
                            <td class="amount-negative">₹3,20,000</td>
                            <td class="amount-positive">₹1,80,000</td>
                            <td>
                                <div class="progress-tally" style="width:120px;display:inline-block">
                                    <div class="progress-bar-tally" style="width:64%"></div>
                                </div> 64%
                            </td>
                            <td><span class="badge-tally badge-success">On Track</span></td>
                        </tr>
                        <tr>
                            <td>Operations</td>
                            <td>₹8,00,000</td>
                            <td class="amount-negative">₹7,80,000</td>
                            <td class="amount-positive">₹20,000</td>
                            <td>
                                <div class="progress-tally" style="width:120px;display:inline-block">
                                    <div class="progress-bar-tally" style="width:97.5%;background:var(--danger)"></div>
                                </div> 97.5%
                            </td>
                            <td><span class="badge-tally badge-danger">Critical</span></td>
                        </tr>
                        <tr>
                            <td>IT</td>
                            <td>₹3,00,000</td>
                            <td class="amount-negative">₹1,40,000</td>
                            <td class="amount-positive">₹1,60,000</td>
                            <td>
                                <div class="progress-tally" style="width:120px;display:inline-block">
                                    <div class="progress-bar-tally" style="width:46%"></div>
                                </div> 46%
                            </td>
                            <td><span class="badge-tally badge-success">Good</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // page script same as others, with currentPage = 'budget'
    </script>
</body>

</html>

