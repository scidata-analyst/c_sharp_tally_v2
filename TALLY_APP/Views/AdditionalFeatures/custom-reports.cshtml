@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <partial name="_Styles" />
</head>

<body>

        <partial name="_Sidebar" />

    <partial name="_Header" model='@("Custom Reports")' />

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== CUSTOM REPORTS ===================== -->
        <div class="page active" id="page-custom-reports">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Custom Reports</div>
                    <div class="page-subtitle">Create and manage custom report templates</div>
                </div><button class="btn-tally-primary" onclick="openModal('genericModal','Report Template')"><i
                        class="bi bi-plus-lg"></i> New Report</button>
            </div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Saved Report Templates</div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th>Report Name</th>
                            <th>Module</th>
                            <th>Format</th>
                            <th>Last Generated</th>
                            <th>Schedule</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Monthly Sales Summary</td>
                            <td>Sales</td>
                            <td><span class="badge-tally badge-info">Excel</span></td>
                            <td>01-03-2026</td>
                            <td>Monthly</td>
                            <td><button class="btn-tally-primary" style="font-size:11px;padding:5px 10px;"><i
                                        class="bi bi-play-fill"></i> Run</button> <button class="btn-tally-edit"><i
                                        class="bi bi-pencil"></i></button></td>
                        </tr>
                        <tr>
                            <td>GST Compliance Report</td>
                            <td>GST</td>
                            <td><span class="badge-tally badge-danger">PDF</span></td>
                            <td>11-03-2026</td>
                            <td>Quarterly</td>
                            <td><button class="btn-tally-primary" style="font-size:11px;padding:5px 10px;"><i
                                        class="bi bi-play-fill"></i> Run</button> <button class="btn-tally-edit"><i
                                        class="bi bi-pencil"></i></button></td>
                        </tr>
                        <tr>
                            <td>Employee Cost Analysis</td>
                            <td>Payroll</td>
                            <td><span class="badge-tally badge-info">Excel</span></td>
                            <td>28-02-2026</td>
                            <td>Monthly</td>
                            <td><button class="btn-tally-primary" style="font-size:11px;padding:5px 10px;"><i
                                        class="bi bi-play-fill"></i> Run</button> <button class="btn-tally-edit"><i
                                        class="bi bi-pencil"></i></button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <partial name="_Scripts" />
    <script>
        // page script same as others, with currentPage = 'custom-reports'
    </script>
</body>

</html>

