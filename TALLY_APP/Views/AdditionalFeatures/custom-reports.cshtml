@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- External CSS -->
    <link rel="stylesheet" href="~/css/styles.css" />
</head>

<body>

        <partial name="_Sidebar" />

    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Custom Reports</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== CUSTOM REPORTS ===================== -->
        <div class="page active" id="page-custom-reports">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Custom Reports</div>
                    <div class="page-subtitle">Create and manage custom report templates</div>
                </div><button class="btn-tally-primary" onclick="openModal('genericModal','Report Template')"><i
                        class="bi bi-plus-lg"></i> New Report</button>
            </div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Saved Report Templates</div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th>Report Name</th>
                            <th>Module</th>
                            <th>Format</th>
                            <th>Last Generated</th>
                            <th>Schedule</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Monthly Sales Summary</td>
                            <td>Sales</td>
                            <td><span class="badge-tally badge-info">Excel</span></td>
                            <td>01-03-2026</td>
                            <td>Monthly</td>
                            <td><button class="btn-tally-primary" style="font-size:11px;padding:5px 10px;"><i
                                        class="bi bi-play-fill"></i> Run</button> <button class="btn-tally-edit"><i
                                        class="bi bi-pencil"></i></button></td>
                        </tr>
                        <tr>
                            <td>GST Compliance Report</td>
                            <td>GST</td>
                            <td><span class="badge-tally badge-danger">PDF</span></td>
                            <td>11-03-2026</td>
                            <td>Quarterly</td>
                            <td><button class="btn-tally-primary" style="font-size:11px;padding:5px 10px;"><i
                                        class="bi bi-play-fill"></i> Run</button> <button class="btn-tally-edit"><i
                                        class="bi bi-pencil"></i></button></td>
                        </tr>
                        <tr>
                            <td>Employee Cost Analysis</td>
                            <td>Payroll</td>
                            <td><span class="badge-tally badge-info">Excel</span></td>
                            <td>28-02-2026</td>
                            <td>Monthly</td>
                            <td><button class="btn-tally-primary" style="font-size:11px;padding:5px 10px;"><i
                                        class="bi bi-play-fill"></i> Run</button> <button class="btn-tally-edit"><i
                                        class="bi bi-pencil"></i></button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // page script same as others, with currentPage = 'custom-reports'
    </script>
</body>

</html>

