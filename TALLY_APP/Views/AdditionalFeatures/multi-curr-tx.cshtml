@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- External CSS -->
    <link rel="stylesheet" href="~/css/styles.css" />
</head>

<body>

        <partial name="_Sidebar" />

    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Multi-currency Transactions</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== MULTI-CURRENCY TRANSACTIONS ===================== -->
        <div class="page active" id="page-multi-curr-tx">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Multi-currency Transactions</div>
                    <div class="page-subtitle">Record and track foreign currency transactions with gain/loss</div>
                </div><button class="btn-tally-primary" onclick="openModal('genericModal','Forex Transaction')"><i
                        class="bi bi-plus-lg"></i> New Forex Txn</button>
            </div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Foreign Currency Transactions</div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th>Ref No.</th>
                            <th>Date</th>
                            <th>Party</th>
                            <th>Currency</th>
                            <th>Foreign Amt</th>
                            <th>Exchange Rate</th>
                            <th>INR Amount</th>
                            <th>Forex Gain/Loss</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>FX-001</td>
                            <td>11-03-2026</td>
                            <td>Export Client USA</td>
                            <td class="text-mono">USD</td>
                            <td>$10,000</td>
                            <td class="text-mono">83.24</td>
                            <td class="amount-positive">₹8,32,400</td>
                            <td class="amount-positive">+₹2,100</td>
                            <td><button class="btn-tally-edit"><i class="bi bi-pencil"></i></button></td>
                        </tr>
                        <tr>
                            <td>FX-002</td>
                            <td>08-03-2026</td>
                            <td>UK Supplier</td>
                            <td class="text-mono">GBP</td>
                            <td>£5,000</td>
                            <td class="text-mono">105.61</td>
                            <td class="amount-negative">₹5,28,050</td>
                            <td class="amount-negative">-₹1,200</td>
                            <td><button class="btn-tally-edit"><i class="bi bi-pencil"></i></button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // page script same as others, with currentPage = 'multi-curr-tx'
    </script>
</body>

</html>

