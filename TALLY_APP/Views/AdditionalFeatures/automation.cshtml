@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- External CSS -->
    <link rel="stylesheet" href="~/css/styles.css" />
</head>

<body>

        <partial name="_Sidebar" />

    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Voucher Automation</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== VOUCHER AUTOMATION ===================== -->
        <div class="page active" id="page-automation">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Voucher Automation</div>
                    <div class="page-subtitle">Set up recurring and auto-generated vouchers</div>
                </div><button class="btn-tally-primary" onclick="openModal('genericModal','Automation Rule')"><i
                        class="bi bi-plus-lg"></i> New Rule</button>
            </div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Automation Rules</div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th>Rule Name</th>
                            <th>Type</th>
                            <th>Frequency</th>
                            <th>Next Run</th>
                            <th>Last Run</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Monthly Rent</td>
                            <td><span class="badge-tally badge-danger">Payment</span></td>
                            <td>Monthly</td>
                            <td class="text-mono">01-04-2026</td>
                            <td class="text-mono">01-03-2026</td>
                            <td><span class="badge-tally badge-success">Active</span></td>
                            <td><button class="btn-tally-edit"><i class="bi bi-pencil"></i></button> <button
                                    class="btn-tally-danger"><i class="bi bi-trash"></i></button></td>
                        </tr>
                        <tr>
                            <td>Depreciation Entry</td>
                            <td><span class="badge-tally badge-accent">Journal</span></td>
                            <td>Monthly</td>
                            <td class="text-mono">01-04-2026</td>
                            <td class="text-mono">01-03-2026</td>
                            <td><span class="badge-tally badge-success">Active</span></td>
                            <td><button class="btn-tally-edit"><i class="bi bi-pencil"></i></button> <button
                                    class="btn-tally-danger"><i class="bi bi-trash"></i></button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // page script same as others, with currentPage = 'automation'
    </script>
</body>

</html>

