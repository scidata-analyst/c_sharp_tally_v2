@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- External CSS -->
    <link rel="stylesheet" href="~/css/styles.css" />
</head>

<body>

        <partial name="_Sidebar" />

    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Stock & Inventory Reports</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== STOCK & INVENTORY REPORTS ===================== -->
        <div class="page active" id="page-stock-reports">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Stock & Inventory Reports</div>
                    <div class="page-subtitle">Comprehensive stock analysis and reports</div>
                </div><button class="btn-tally-outline"><i class="bi bi-download"></i> Export</button>
            </div>
            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Stock Summary Report</div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Category</th>
                            <th>Opening</th>
                            <th>In</th>
                            <th>Out</th>
                            <th>Closing</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Steel Pipe 2"</td>
                            <td>Pipes</td>
                            <td>500</td>
                            <td class="amount-positive">200</td>
                            <td class="amount-negative">358</td>
                            <td>342</td>
                            <td class="amount-positive">₹3,42,000</td>
                        </tr>
                        <tr>
                            <td>Copper Wire 1.5mm</td>
                            <td>Electrical</td>
                            <td>200</td>
                            <td class="amount-positive">50</td>
                            <td class="amount-negative">232</td>
                            <td>18</td>
                            <td class="amount-positive">₹36,000</td>
                        </tr>
                        <tr>
                            <td>Laptop Dell XPS 15</td>
                            <td>Electronics</td>
                            <td>50</td>
                            <td class="amount-positive">10</td>
                            <td class="amount-negative">26</td>
                            <td>34</td>
                            <td class="amount-positive">₹34,00,000</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // page script same as others, with currentPage = 'stock-reports'
    </script>
</body>

</html>

