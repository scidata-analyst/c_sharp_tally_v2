    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Cash Flow Statements</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== CASH FLOW STATEMENTS ===================== -->
        <div class="page active" id="page-cashflow">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Cash Flow Statements</div>
                    <div class="page-subtitle">Operating, investing and financing activities</div>
                </div><button class="btn-tally-outline"><i class="bi bi-download"></i> Export</button>
            </div>
            <div class="tally-card">
                <div class="card-label mb-3">Cash Flow — FY 2024-25</div>
                <div class="info-row"><span class="info-key" style="font-weight:700;color:var(--text-primary)">Operating
                        Activities</span><span></span></div>
                <div class="info-row"><span class="info-key" style="padding-left:20px">Net Profit</span><span
                        class="info-val amount-positive">₹16,80,000</span></div>
                <div class="info-row"><span class="info-key" style="padding-left:20px">Add: Depreciation</span><span
                        class="info-val amount-positive">₹1,20,000</span></div>
                <div class="info-row"><span class="info-key" style="padding-left:20px">Less: Increase in
                        Debtors</span><span class="info-val amount-negative">-₹4,00,000</span></div>
                <div class="info-row"><span class="info-key" style="padding-left:20px;font-weight:600">Net from
                        Operations</span><span class="info-val fw-800">₹14,00,000</span></div>
                <div class="border-sep"></div>
                <div class="info-row"><span class="info-key" style="font-weight:700;color:var(--text-primary)">Investing
                        Activities</span><span></span></div>
                <div class="info-row"><span class="info-key" style="padding-left:20px">Purchase of Assets</span><span
                        class="info-val amount-negative">-₹2,50,000</span></div>
                <div class="border-sep"></div>
                <div class="info-row"><span class="info-key fw-800">NET CASH FLOW</span><span class="info-val fw-800"
                        style="color:var(--primary);font-size:18px;">₹11,50,000</span></div>
            </div>
        </div>

    </main>

    <!-- ===================== MODALS ===================== -->

    <!-- Voucher Modal -->
    <div class="tally-modal-overlay" id="voucherModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Create Voucher</div>
                <div class="modal-close" onclick="closeModal('voucherModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Voucher Type *</label><select
                                class="form-control-tally">
                                <option>Payment</option>
                                <option>Receipt</option>
                                <option>Journal</option>
                                <option>Contra</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Voucher Date *</label><input type="date"
                                class="form-control-tally"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Party / Account *</label><input type="text"
                                class="form-control-tally" placeholder="Select or type party name"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Amount *</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Payment Mode</label><select
                                class="form-control-tally">
                                <option>Cash</option>
                                <option>Bank Transfer</option>
                                <option>Cheque</option>
                                <option>UPI</option>
                                <option>NEFT/RTGS</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Reference No.</label><input type="text"
                                class="form-control-tally" placeholder="Cheque / UTR / Ref No."></div>
                    </div>
                    <div class="col-12">
                        <div class="form-group"><label class="form-label">Narration</label><textarea
                                class="form-control-tally" rows="2"
                                placeholder="Brief description of this voucher..."></textarea></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('voucherModal')">Cancel</button>
                <button class="btn-tally-outline" onclick="showToast('Saved as Draft','info')"><i
                        class="bi bi-file-earmark"></i> Save Draft</button>
                <button class="btn-tally-primary"
                    onclick="closeModal('voucherModal');showToast('Voucher created successfully!','success')"><i
                        class="bi bi-check-lg"></i> Post Voucher</button>
            </div>
        </div>
    </div>

    <!-- Ledger Modal -->
    <div class="tally-modal-overlay" id="ledgerModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title" id="ledgerModalTitle">Create New Ledger</div>
                <div class="modal-close" onclick="closeModal('ledgerModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="form-group"><label class="form-label">Ledger Name *</label><input type="text"
                                class="form-control-tally" placeholder="e.g. HDFC Bank Account" id="ledgerName"></div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group"><label class="form-label">Ledger Code</label><input type="text"
                                class="form-control-tally" placeholder="e.g. 001"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Under Group *</label><select
                                class="form-control-tally">
                                <option>Cash-in-Hand</option>
                                <option>Bank Accounts</option>
                                <option>Sundry Debtors</option>
                                <option>Sundry Creditors</option>
                                <option>Sales Accounts</option>
                                <option>Purchase Accounts</option>
                                <option>Duties & Taxes</option>
                                <option>Fixed Assets</option>
                                <option>Investments</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Account Type *</label><select
                                class="form-control-tally">
                                <option>Asset</option>
                                <option>Liability</option>
                                <option>Revenue</option>
                                <option>Expense</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Opening Balance</label><input type="number"
                                class="form-control-tally" placeholder="0.00"></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Balance Type</label><select
                                class="form-control-tally">
                                <option>Debit (Dr)</option>
                                <option>Credit (Cr)</option>
                            </select></div>
                    </div>
                    <div class="col-12">
                        <div class="form-group"><label class="form-label">Description / Notes</label><textarea
                                class="form-control-tally" rows="2" placeholder="Optional description..."></textarea>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Currency</label><select
                                class="form-control-tally">
                                <option>INR — Indian Rupee</option>
                                <option>USD — US Dollar</option>
                                <option>EUR — Euro</option>
                            </select></div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group"><label class="form-label">Status</label><select
                                class="form-control-tally">
                                <option>Active</option>
                                <option>Inactive</option>
                            </select></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-tally-outline" onclick="closeModal('ledgerModal')">Cancel</button>
                <button class="btn-tally-primary" onclick="saveLedger()"><i class="bi bi-check-lg"></i> Save
                    Ledger</button>
            </div>
        </div>
    </div>

    <!-- Stock Item Modal -->
    <div class="tally-modal-overlay" id="stockModal">
        <div class="tally-modal">
            <div class="modal-header">
                <div class="modal-title">Add Stock Item</div>
                <div class="modal-close" onclick="closeModal('stockModal')"><i class="bi bi-x-lg"></i></div>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="form-group"><label class="form-label">Item Name *</label><input type="text"
