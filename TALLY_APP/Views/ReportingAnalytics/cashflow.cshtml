@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Cash Flow Statement</title>
    <partial name="_Styles" />
</head>
<body>
    <partial name="_Sidebar" />
    <partial name="_Header" model='@("Cash Flow")' />

    <main class="main-content">
        <div class="page active">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Cash Flow Statement</div>
                    <div class="page-subtitle">Reporting · Analysis of cash inflows and outflows</div>
                </div>
                <div style="display:flex;gap:10px;">
                    <button class="btn-tally-outline" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
                    <button class="btn-tally-primary" onclick="loadData()"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
                </div>
            </div>
            
            <div class="row g-3 mb-4" id="summaryCards"></div>

            <div class="data-table-wrapper">
                <div class="table-toolbar">
                    <div class="table-title">Period-wise Analysis</div>
                </div>
                <table class="tally-table">
                    <thead>
                        <tr>
                            <th onclick="sortBy('Period')" style="cursor:pointer;">Period</th>
                            <th onclick="sortBy('NetCashFlow')" style="cursor:pointer;">Net Cash Flow</th>
                            <th>Net From Operations</th>
                            <th>Net Profit</th>
                            <th>Depreciation</th>
                            <th>Increase In Debtors</th>
                            <th>Purchase of Assets</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination-wrapper" style="display:flex;align-items:center;justify-content:space-between;padding:15px 10px;border-top:1px solid var(--border);margin-top:10px;">
                    <div style="font-size:13px;color:var(--text-muted);">Showing <span id="showingStart">0</span> to <span id="showingEnd">0</span> of <span id="totalRecords">0</span></div>
                    <div style="display:flex;gap:4px;"><button class="btn-tally-outline" id="prevBtn" onclick="prevPage()"><i class="bi bi-chevron-left"></i></button><button class="btn-tally-outline" id="nextBtn" onclick="nextPage()"><i class="bi bi-chevron-right"></i></button></div>
                </div>
            </div>
        </div>
    </main>

    <div class="toast-container" id="toastContainer"></div>
    <partial name="_Scripts" />

    <script>
        let st = { data: [], page: 1, pageSize: 10, totalCount: 0, totalPages: 0, search: '', sortColumn: 'Id', sortDirection: 'desc' };

        async function loadData() {
            const r = await fetch(`/CashFlowStatement/api/index?page=${st.page}&pageSize=${st.pageSize}&sortColumn=${st.sortColumn}&sortDirection=${st.sortDirection}`);
            const d = await r.json(); Object.assign(st, d); renderTable(); renderSummary();
        }
        function renderTable() {
            const tbody = document.getElementById('tableBody'); tbody.innerHTML = '';
            st.data.forEach((item) => {
                const row = `<tr><td><b>${item.period}</b></td><td class="${item.netCashFlow>=0?'text-success':'text-danger'}"><b>₹${item.netCashFlow.toLocaleString()}</b></td><td>₹${item.netFromOperations.toLocaleString()}</td><td>₹${item.netProfit.toLocaleString()}</td><td>₹${item.depreciation.toLocaleString()}</td><td>₹${item.increaseInDebtors.toLocaleString()}</td><td>₹${item.purchaseOfAssets.toLocaleString()}</td></tr>`;
                tbody.innerHTML += row;
            });
            document.getElementById('prevBtn').disabled = st.page <= 1; document.getElementById('nextBtn').disabled = st.page >= st.totalPages;
        }
        function renderSummary() {
            const last = st.data[0] || { netProfit:0, netFromOperations:0, netCashFlow:0 };
            document.getElementById('summaryCards').innerHTML = `<div class="col-md-4"><div class="stat-card" style="--card-accent:var(--primary)"><div class="stat-label">Net Profit (Last)</div><div class="stat-value">₹${last.netProfit.toLocaleString()}</div></div></div><div class="col-md-4"><div class="stat-card" style="--card-accent:var(--accent)"><div class="stat-label">Net Operations</div><div class="stat-value">₹${last.netFromOperations.toLocaleString()}</div></div></div><div class="col-md-4"><div class="stat-card" style="--card-accent:var(--warning)"><div class="stat-label">Net Cash Flow</div><div class="stat-value">₹${last.netCashFlow.toLocaleString()}</div></div></div>`;
        }
        function sortBy(col) { if(st.sortColumn === col) st.sortDirection = st.sortDirection === 'asc' ? 'desc' : 'asc'; else { st.sortColumn = col; st.sortDirection = 'asc'; } loadData(); }
        function prevPage() { if(st.page > 1) { st.page--; loadData(); } }
        function nextPage() { if(st.page < st.totalPages) { st.page++; loadData(); } }
        document.addEventListener('DOMContentLoaded', loadData);
    </script>
</body>
</html>
