@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <partial name="_Styles" />
</head>

<body>

        <partial name="_Sidebar" />

    <partial name="_Header" model='@("Sales & Purchase Summary")' />

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== SALES & PURCHASE SUMMARY ===================== -->
        <div class="page active" id="page-sales-purchase">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Sales & Purchase Summary</div>
                    <div class="page-subtitle">Month-wise sales and purchase analysis</div>
                </div>
            </div>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--primary)">
                        <div class="stat-label">Total Sales (MTD)</div>
                        <div class="stat-value">₹48,20,000</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--danger)">
                        <div class="stat-label">Total Purchases (MTD)</div>
                        <div class="stat-value">₹31,40,000</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--accent)">
                        <div class="stat-label">Gross Margin</div>
                        <div class="stat-value">34.8%</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--accent2)">
                        <div class="stat-label">Return on Sales</div>
                        <div class="stat-value">₹16,80,000</div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <partial name="_Scripts" />
    <script>
        // page script same as others, with currentPage = 'sales-purchase'
    </script>
</body>

</html>

