@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TallyPro — Enterprise Accounting Suite</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- External CSS -->
    <link rel="stylesheet" href="~/css/styles.css" />
</head>

<body>

        <partial name="_Sidebar" />

    <!-- ===== HEADER ===== -->
    <header class="main-header">
        <div class="header-breadcrumb">
            <span class="breadcrumb-root">TallyPro</span>
            <span class="breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
            <span class="breadcrumb-current" id="breadcrumbCurrent">Sales & Purchase Summary</span>
        </div>

        <div class="header-actions">
            <div class="company-selector">
                <div class="company-dot"></div>
                <span>ABC Enterprises Ltd.</span>
                <i class="bi bi-chevron-down" style="font-size:10px;"></i>
            </div>
            <div class="header-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <div class="notif-badge"></div>
            </div>
            <div class="header-btn" title="Search">
                <i class="bi bi-search"></i>
            </div>
            <div class="header-btn" title="Settings">
                <i class="bi bi-gear"></i>
            </div>
            <div class="header-btn" title="Full Screen">
                <i class="bi bi-fullscreen"></i>
            </div>
        </div>
    </header>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">

        <!-- ===================== SALES & PURCHASE SUMMARY ===================== -->
        <div class="page active" id="page-sales-purchase">
            <div class="page-title-row">
                <div>
                    <div class="page-title">Sales & Purchase Summary</div>
                    <div class="page-subtitle">Month-wise sales and purchase analysis</div>
                </div>
            </div>
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--primary)">
                        <div class="stat-label">Total Sales (MTD)</div>
                        <div class="stat-value">₹48,20,000</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--danger)">
                        <div class="stat-label">Total Purchases (MTD)</div>
                        <div class="stat-value">₹31,40,000</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--accent)">
                        <div class="stat-label">Gross Margin</div>
                        <div class="stat-value">34.8%</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card" style="--card-accent:var(--accent2)">
                        <div class="stat-label">Return on Sales</div>
                        <div class="stat-value">₹16,80,000</div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <!-- remaining modals and scripts identical to other pages (truncated for brevity) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // page script same as others, with currentPage = 'sales-purchase'
    </script>
</body>

</html>

